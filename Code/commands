sudo /usr/lib/vmware-vpx/scripts/cisreg.py list 2>/dev/null || echo "Try PowerCLI instead"

# Get a token (you'll need an SSO user password)
TOKEN=$(curl -k -s -X POST -u 'administrator@vsphere.local' https://localhost/api/session | tr -d '"')

# List all tags and grep for the names
curl -k -s -H "vmware-api-session-id: $TOKEN" https://localhost/api/cis/tagging/tag | head -50


# Search for the working tag in the failure window
