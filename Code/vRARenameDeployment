# VMware Aria Automation - Bulk Deployment Renamer
# Renames deployments based on CSV input (Name column = server to find, Description = new deployment name)

$vraServer = "vra.yourdomain.com"
$csvPath = "C:\Path\To\Servers.csv"
$logPath = "C:\Logs\DeploymentRename_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"

# Initialize CSV log with headers
"Timestamp,Level,Message" | Set-Content -Path $logPath

function Write-Log {
    param($Message, $Color = "White", $Level = "INFO")
    Write-Host $Message -ForegroundColor $Color
    $timestamp = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'
    $escapedMessage = $Message -replace '"', '""'
    "$timestamp,$Level,`"$escapedMessage`"" | Add-Content -Path $logPath
}

# Configure TLS 1.2
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
[System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

# Import CSV
$servers = @(Import-Csv -Path $csvPath)
Write-Host "Loaded $($servers.Count) servers from CSV`n" -ForegroundColor Green

# Authenticate to VMware Aria
Write-Log "=== AUTHENTICATION ===" -Color Cyan -Level "INFO"
$credential = Get-Credential -Message "Enter VMware Aria Automation credentials"

$authBody = @{
    username = $credential.UserName
    password = $credential.GetNetworkCredential().Password
} | ConvertTo-Json

$authResponse = Invoke-RestMethod -Uri "https://$vraServer/csp/gateway/am/api/login" `
    -Method Post -Headers @{"Content-Type"="application/json"} -Body $authBody

$headers = @{
    "Authorization" = "Bearer $($authResponse.cspAuthToken)"
    "Content-Type" = "application/json"
}
Write-Log "Authentication successful!" -Color Green -Level "INFO"

# Get all deployments with pagination
function Get-AllDeployments {
    Write-Log "Fetching all deployments..." -Color Cyan -Level "INFO"
    $allDeployments = @()
    $page = 0
    $size = 100

    do {
        $uri = "https://$vraServer/deployment/api/deployments?page=$page&size=$size&expand=resources"
        Write-Log "  Page $($page + 1)..." -Color Gray -Level "INFO"

        $response = Invoke-RestMethod -Uri $uri -Method Get -Headers $headers
        $deployments = if ($response.content) { $response.content } else { $response }
        $allDeployments += $deployments

        $hasMore = ($response.totalPages -and $page -lt $response.totalPages - 1) -or
                   ($deployments.Count -eq $size)
        $page++
    } while ($hasMore)

    Write-Log "Total deployments: $($allDeployments.Count)" -Color Cyan -Level "INFO"
    return $allDeployments
}

# Find deployment containing the specified server
function Find-Deployment {
    param($ServerName, $AllDeployments)

    foreach ($dep in $AllDeployments) {
        $machines = @($dep.resources | Where-Object { $_.type -eq "Cloud.vSphere.Machine" })

        foreach ($machine in $machines) {
            if ($machine.name -eq $ServerName -or
                $machine.properties.hostname -eq $ServerName -or
                $machine.properties.resourceName -eq $ServerName) {
                return @{
                    DeploymentId = $dep.id
                    CurrentName  = $dep.name
                }
            }
        }
    }
    return $null
}

# Rename deployment via PATCH API
function Rename-Deployment {
    param($DeploymentId, $NewName)

    try {
        $body = @{ name = $NewName } | ConvertTo-Json
        Invoke-RestMethod -Uri "https://$vraServer/deployment/api/deployments/$DeploymentId" `
            -Method Patch -Headers $headers -Body $body -ErrorAction Stop | Out-Null
        return $true
    }
    catch {
        Write-Log "    Error: $($_.Exception.Message)" -Color Red -Level "ERROR"
        return $false
    }
}

# Main processing
$allDeployments = Get-AllDeployments
Write-Log "=== PROCESSING SERVERS ===" -Color Cyan -Level "INFO"
$results = [System.Collections.Generic.List[object]]::new()

for ($i = 0; $i -lt $servers.Count; $i++) {
    $server     = $servers[$i]
    $serverName = $server.Name.Trim()
    $newName    = $server.Description.Trim()

    Write-Log "[$($i+1)/$($servers.Count)] $serverName -> $newName" -Color Yellow -Level "INFO"

    $deployment = Find-Deployment -ServerName $serverName -AllDeployments $allDeployments

    if (-not $deployment) {
        Write-Log "  Not found" -Color Red -Level "WARNING"
        $results.Add([PSCustomObject]@{ ServerName=$serverName; NewName=$newName; Status="Not Found"; OldName="N/A" })
        continue
    }

    Write-Log "  Current: $($deployment.CurrentName)" -Color Gray -Level "INFO"

    if ($deployment.CurrentName -eq $newName) {
        Write-Log "  Already correct" -Color Cyan -Level "INFO"
        $results.Add([PSCustomObject]@{ ServerName=$serverName; NewName=$newName; Status="Already Named"; OldName=$deployment.CurrentName })
        continue
    }

    if (Rename-Deployment -DeploymentId $deployment.DeploymentId -NewName $newName) {
        Write-Log "  Renamed successfully" -Color Green -Level "SUCCESS"
        $results.Add([PSCustomObject]@{ ServerName=$serverName; NewName=$newName; Status="Renamed"; OldName=$deployment.CurrentName })
    }
    else {
        Write-Log "  Failed to rename" -Color Red -Level "ERROR"
        $results.Add([PSCustomObject]@{ ServerName=$serverName; NewName=$newName; Status="Failed"; OldName=$deployment.CurrentName })
    }

    Start-Sleep -Milliseconds 200
}

# Summary
Write-Log "=== SUMMARY ===" -Color Cyan -Level "INFO"
Write-Log "Renamed:       $(($results | Where-Object { $_.Status -eq 'Renamed' }).Count)"       -Color Green  -Level "INFO"
Write-Log "Already Named: $(($results | Where-Object { $_.Status -eq 'Already Named' }).Count)" -Color Cyan   -Level "INFO"
Write-Log "Not Found:     $(($results | Where-Object { $_.Status -eq 'Not Found' }).Count)"     -Color Red    -Level "INFO"
Write-Log "Failed:        $(($results | Where-Object { $_.Status -eq 'Failed' }).Count)"        -Color Red    -Level "INFO"

$resultsPath = "$(Split-Path $logPath -Parent)\Results_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"
$results | Export-Csv -Path $resultsPath -NoTypeInformation
Write-Log "Results saved: $resultsPath" -Color White -Level "INFO"
Write-Log "Activity log:  $logPath"     -Color White -Level "INFO"
