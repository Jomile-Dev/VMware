# Test 3: List all VMs (first page) and search manually
Write-Host "`n=== TEST 3: list all VMs (first 20) ===" -ForegroundColor Yellow
$uri3 = "https://${NSXManager}/policy/api/v1/infra/realized-state/virtual-machines?page_size=20"
Write-Host "URI: $uri3" -ForegroundColor Gray
try {
    $r3 = Invoke-RestMethod -Uri $uri3 -Headers $headers -WebSession $nsxSession -Method Get
    Write-Host "Total VMs in NSX: $($r3.result_count)" -ForegroundColor Green
    Write-Host "First 5:" -ForegroundColor White
    foreach ($vm in ($r3.results | Select-Object -First 5)) {
        $tagCount = if ($vm.tags) { $vm.tags.Count } else { 0 }
        Write-Host "  $($vm.display_name) ($tagCount tags)" -ForegroundColor Cyan
    }
}
catch {
    Write-Host "FAILED: $($_.Exception.Message)" -ForegroundColor Red
}

# Test 4: Fabric VMs API (alternative)
Write-Host "`n=== TEST 4: fabric VMs API ===" -ForegroundColor Yellow
$uri4 = "https://${NSXManager}/api/v1/fabric/virtual-machines?display_name=$TestVMName"
