# VMware Aria Automation - Bulk CMDB Relations Extractor
# Calls the vRO form external-values endpoint to retrieve CMDB data for all VMs
# Uses runspace pooling for parallel execution (ISE compatible)

$vraServer  = "vra.yourdomain.com"
$resultsDir = "C:\Logs"

# Email Configuration
$SendEmail    = $true
$EmailTo      = "admin@company.com"
$EmailFrom    = "vmware-reports@company.com"
$EmailSubject = "CMDB Relations Comparison Report - $(Get-Date -Format 'yyyy-MM-dd')"
$SMTPServer   = "mail.company.com"
$SMTPPort     = 465
$UseSSL       = $true

# vRO action URIs - update these to match your environment
$showVmDetailsUri = "somethingsomething.something.wrappers/showVmDetails"
$getVmAppsUri     = "somethingsomething.something.returns/getVmApplications"

function Write-Log {
    param($Message, $Color = "White")
    Write-Host $Message -ForegroundColor $Color
}

# Configure TLS 1.2
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
[System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

# Authenticate to VMware Aria
Write-Log "=== AUTHENTICATION ===" -Color Cyan
$credential = Get-Credential -Message "Enter VMware Aria Automation credentials"

$authBody = @{
    username = $credential.UserName
    password = $credential.GetNetworkCredential().Password
} | ConvertTo-Json

$authResponse = Invoke-RestMethod -Uri "https://$vraServer/csp/gateway/am/api/login" `
    -Method Post -Headers @{"Content-Type"="application/json"} -Body $authBody

$authToken = $authResponse.cspAuthToken
Write-Log "Authentication successful!" -Color Green

# Normalise application name for comparison
function Normalize-AppName {
    param($Name)
    if (-not $Name) { return "" }
    return ($Name.ToLower().Trim() -replace '[_\s\-\.]+', '')
}

# Fetch all deployments with resources in one pass (size=1000, same as working export script)
Write-Log "`n=== FETCHING DEPLOYMENTS ===" -Color Cyan

$headers = @{
    "Authorization" = "Bearer $authToken"
    "Content-Type"  = "application/json"
}

$vmQueue = [System.Collections.Generic.List[hashtable]]::new()
$page = 0
$size = 1000
$totalProcessed = 0
$skippedCount = 0

do {
    $uri = "https://$vraServer/deployment/api/deployments?page=$page&size=$size&expand=resources"
    Write-Log "  Page $($page + 1)..." -Color Gray

    $response = Invoke-RestMethod -Uri $uri -Method Get -Headers $headers
    $deployments = if ($response.content) { $response.content } else { $response }

    foreach ($dep in $deployments) {
        # Skip deleted/failed deployments
        if ($dep.status -and $dep.status -in @("DELETE_SUCCESSFUL", "FAILED", "DELETE_INPROGRESS")) {
            $skippedCount++
            continue
        }

        $machines = @($dep.resources | Where-Object { $_.type -eq "Cloud.vSphere.Machine" })
        if ($machines.Count -eq 0) { continue }

        foreach ($machine in $machines) {
            # Skip failed or missing VMs
            if ($machine.state -and $machine.state -notin @("OK", "STARTED", "")) { continue }

            $vmName = if ($machine.properties.resourceName) { $machine.properties.resourceName }
                      elseif ($machine.properties.hostname) { $machine.properties.hostname }
                      else { $machine.name }

            # Clean VM name: strip domain suffix and duplicated name patterns (e.g. VMName_VMName_VMName.domain)
            $vmName = ($vmName -split '\.')[0]  # Remove domain suffix
            if ($vmName -match '^([^_]+)(_\1)+$') {
                $vmName = $matches[1]  # Remove duplicated name (VMName_VMName -> VMName)
            }

            $vmQueue.Add(@{
                DeploymentName = $dep.name
                VMName         = $vmName
                ProjectId      = $dep.projectId
                ProjectName    = $dep.projectName
            })
        }
    }

    $totalProcessed += $deployments.Count
    $page++

    $hasMore = if ($response.totalPages) {
        $page -lt $response.totalPages
    } elseif ($response.totalElements) {
        $totalProcessed -lt $response.totalElements
    } else {
        $deployments.Count -eq $size
    }
} while ($hasMore)

Write-Log "Scanned: $totalProcessed deployments (skipped $skippedCount deleted/failed)" -Color Cyan
Write-Log "VMs to process: $($vmQueue.Count)" -Color Cyan

# Scriptblock that runs in each runspace
$scriptBlock = {
    param($VraServer, $AuthToken, $ShowVmDetailsUri, $GetVmAppsUri, $VMName, $ProjectId, $ProjectName, $DeploymentName)

    [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
    [System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

    $headers = @{
        "Authorization" = "Bearer $AuthToken"
        "Content-Type"  = "application/json"
    }

    $uri = "https://$VraServer/form-service/api/forms/renderer/external-values?projectId=$ProjectId"

    $bodyArray = @(
        @{
            uri                     = $ShowVmDetailsUri
            dataSource              = "scriptAction"
            parameters              = @(
                @{ name = "vmName"; value = $VMName }
            )
            useResultsFromRequestId = -1
            fieldType               = @{ dataType = "complex" }
            fields                  = @(
                @{ label = "Scope"; type = @{ dataType = "string" }; id = "scope" },
                @{ label = "Tag";   type = @{ dataType = "string" }; id = "tag" }
            )
            isMultiple              = $true
            requestId               = 1
        },
        @{
            uri                     = $GetVmAppsUri
            dataSource              = "scriptAction"
            parameters              = @(
                @{ name = "vmName";      value = $VMName },
                @{ name = "projectName"; value = $ProjectName }
            )
            useResultsFromRequestId = -1
            fieldType               = @{ dataType = "string" }
            isMultiple              = $true
            requestId               = 2
        }
    )

    $body = "[" + (($bodyArray | ForEach-Object { $_ | ConvertTo-Json -Depth 5 -Compress }) -join ",") + "]"

    try {
        $response = Invoke-RestMethod -Uri $uri -Method Post -Headers $headers -Body $body

        $appApplication = ""
        $infraOs        = ""
        $appLayer       = ""
        $vmApplications = ""

        foreach ($result in $response) {
            switch ($result.requestId) {
                1 {
                    if ($result.data -is [array]) {
                        foreach ($item in $result.data) {
                            if ($item.scope -and $item.tag) {
                                switch ($item.scope) {
                                    "app-application" { $appApplication = $item.tag }
                                    "infra-os"        { $infraOs = $item.tag }
                                    "app-layer"       { $appLayer = $item.tag }
                                }
                            }
                        }
                    }
                }
                2 {
                    if ($result.data -is [array]) {
                        $vmApplications = ($result.data | Where-Object { $_ -and $_ -notmatch "^---" }) -join "; "
                    }
                }
            }
        }

        # Normalise and compare - check each semicolon-separated app for a match
        $norm1 = if ($appApplication) { ($appApplication.ToLower().Trim() -replace '[_\s\-\.]+', '') } else { "" }
        
        $match = "Missing Data"
        if ($norm1 -and $vmApplications) {
            $appList = $vmApplications -split ";\s*"
            $foundMatch = $false
            foreach ($app in $appList) {
                $normApp = ($app.ToLower().Trim() -replace '[_\s\-\.]+', '')
                if ($normApp -and $norm1 -eq $normApp) {
                    $foundMatch = $true
                    break
                }
            }
            $match = if ($foundMatch) { "Match" } else { "Mismatch" }
        }

        return [PSCustomObject]@{
            DeploymentName = $DeploymentName
            VMName         = $VMName
            AppApplication = $appApplication
            InfraOS        = $infraOs
            AppLayer       = $appLayer
            CMDBCI         = $vmApplications
            CompareResult  = $match
            Status         = "Success"
        }
    }
    catch {
        return [PSCustomObject]@{
            DeploymentName = $DeploymentName
            VMName         = $VMName
            AppApplication = ""
            InfraOS        = ""
            AppLayer       = ""
            CMDBCI         = ""
            CompareResult  = ""
            Status         = "Failed: $($_.Exception.Message)"
        }
    }
}

# Process with single runspace pool and timeout per job
$poolSize = 30
$jobTimeoutSeconds = 120
Write-Log "`n=== PROCESSING $($vmQueue.Count) VMs ($poolSize parallel threads, ${jobTimeoutSeconds}s timeout) ===" -Color Cyan
$stopwatch = [System.Diagnostics.Stopwatch]::StartNew()

$runspacePool = [System.Management.Automation.Runspaces.RunspaceFactory]::CreateRunspacePool(1, $poolSize)
$runspacePool.Open()

$results = [System.Collections.Generic.List[object]]::new()
$jobs = [System.Collections.Generic.List[object]]::new()
$completed = 0
$successCount = 0
$failCount = 0

# Queue all jobs
foreach ($vm in $vmQueue) {
    $ps = [PowerShell]::Create().AddScript($scriptBlock)
    $ps.AddArgument($vraServer)          | Out-Null
    $ps.AddArgument($authToken)          | Out-Null
    $ps.AddArgument($showVmDetailsUri)   | Out-Null
    $ps.AddArgument($getVmAppsUri)       | Out-Null
    $ps.AddArgument($vm.VMName)          | Out-Null
    $ps.AddArgument($vm.ProjectId)       | Out-Null
    $ps.AddArgument($vm.ProjectName)     | Out-Null
    $ps.AddArgument($vm.DeploymentName)  | Out-Null
    $ps.RunspacePool = $runspacePool

    $jobs.Add(@{
        PowerShell = $ps
        Handle     = $ps.BeginInvoke()
        VMName     = $vm.VMName
    })
}

# Collect results with timeout
foreach ($job in $jobs) {
    $completed++

    if ($job.Handle.AsyncWaitHandle.WaitOne($jobTimeoutSeconds * 1000)) {
        $result = $job.PowerShell.EndInvoke($job.Handle)

        if ($result) {
            foreach ($r in $result) {
                if ($r.Status -eq "Success") {
                    $successCount++
                    $matchColor = switch ($r.CompareResult) {
                        "Match"    { "Green" }
                        "Mismatch" { "Red" }
                        default    { "Gray" }
                    }

                    # Show what was returned for Missing Data so you can see what's empty
                    if ($r.CompareResult -eq "Missing Data") {
                        $tagVal = if ($r.AppApplication) { $r.AppApplication } else { "(empty)" }
                        $appVal = if ($r.CMDBCI) { $r.CMDBCI } else { "(empty)" }
                        Write-Log "[$completed/$($vmQueue.Count)] $($r.VMName) | Tag: $tagVal | CMDB CI: $appVal | Missing Data" -Color Gray
                    }
                    else {
                        Write-Log "[$completed/$($vmQueue.Count)] $($r.VMName) | $($r.AppApplication) | $($r.CompareResult)" -Color $matchColor
                    }
                }
                else {
                    $failCount++
                    Write-Log "[$completed/$($vmQueue.Count)] $($r.VMName) | FAILED - $($r.Status)" -Color Red
                }

                $results.Add([PSCustomObject]@{
                    DeploymentName = [string]$r.DeploymentName
                    VMName         = [string]$r.VMName
                    AppApplication = [string]$r.AppApplication
                    InfraOS        = [string]$r.InfraOS
                    AppLayer       = [string]$r.AppLayer
                    CMDBCI         = [string]$r.CMDBCI
                    CompareResult  = [string]$r.CompareResult
                })
            }
        }
    }
    else {
        $failCount++
        Write-Log "[$completed/$($vmQueue.Count)] $($job.VMName) | TIMEOUT after ${jobTimeoutSeconds}s" -Color Red
        $job.PowerShell.Stop()
    }

    $job.PowerShell.Dispose()
}

if ($runspacePool) { $runspacePool.Close(); $runspacePool.Dispose() }
$stopwatch.Stop()

# Summary
Write-Log "`n=== SUMMARY ===" -Color Cyan
Write-Log "VMs processed: $($vmQueue.Count)" -Color White
Write-Log "Successful:    $successCount" -Color Green
Write-Log "Failed:        $failCount" -Color Red
Write-Log "Matches:       $(($results | Where-Object { $_.CompareResult -eq 'Match' }).Count)" -Color Green
Write-Log "Mismatches:    $(($results | Where-Object { $_.CompareResult -eq 'Mismatch' }).Count)" -Color Red
Write-Log "Missing Data:  $(($results | Where-Object { $_.CompareResult -eq 'Missing Data' }).Count)" -Color Gray
Write-Log "Time elapsed:  $($stopwatch.Elapsed.ToString('hh\:mm\:ss'))" -Color White

# Export results
$resultsPath = "$resultsDir\CMDBRelations_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"
$results | Export-Csv -Path $resultsPath -NoTypeInformation
Write-Log "`nResults saved: $resultsPath" -Color White

# Email report
if ($SendEmail) {
    Write-Log "`n=== SENDING EMAIL ===" -Color Cyan

    $matchCount    = @($results | Where-Object { $_.CompareResult -eq 'Match' }).Count
    $mismatchCount = @($results | Where-Object { $_.CompareResult -eq 'Mismatch' }).Count
    $missingCount  = @($results | Where-Object { $_.CompareResult -eq 'Missing Data' }).Count
    $totalVMs      = @($results).Count
    $generatedAt   = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'

    $emailBody = "<html>"
    $emailBody += "<body style='font-family: Segoe UI, Arial, sans-serif; color: #333;'>"
    $emailBody += "<h2 style='color: #2c3e50;'>CMDB Relations Comparison Report</h2>"
    $emailBody += "<p>Generated: $generatedAt</p>"
    $emailBody += "<h3 style='color: #2c3e50;'>Summary</h3>"
    $emailBody += "<table style='border-collapse:collapse; margin-bottom:20px;'>"
    $emailBody += "<tr style='background:#2c3e50; color:white;'>"
    $emailBody += "<th style='padding:8px 16px; border:1px solid #ddd; text-align:left;'>Category</th>"
    $emailBody += "<th style='padding:8px 16px; border:1px solid #ddd; text-align:right;'>Count</th>"
    $emailBody += "</tr>"
    $emailBody += "<tr style='background:#e8f5e9;'>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd;'>Match</td>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd; text-align:right; color:green; font-weight:bold;'>$matchCount</td>"
    $emailBody += "</tr>"
    $emailBody += "<tr style='background:#ffebee;'>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd;'>Mismatch</td>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd; text-align:right; color:red; font-weight:bold;'>$mismatchCount</td>"
    $emailBody += "</tr>"
    $emailBody += "<tr style='background:#f5f5f5;'>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd;'>Missing Data</td>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd; text-align:right; color:gray; font-weight:bold;'>$missingCount</td>"
    $emailBody += "</tr>"
    $emailBody += "<tr style='background:#e3f2fd;'>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd; font-weight:bold;'>Total VMs</td>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd; text-align:right; font-weight:bold;'>$totalVMs</td>"
    $emailBody += "</tr>"
    $emailBody += "</table>"
    $emailBody += "</body></html>"

    try {
        $emailParams = @{
            To         = $EmailTo
            From       = $EmailFrom
            Subject    = $EmailSubject
            Body       = $emailBody
            BodyAsHtml = $true
            SmtpServer = $SMTPServer
            Port       = $SMTPPort
            UseSsl     = $UseSSL
            Attachments = $resultsPath
        }

        Send-MailMessage @emailParams

        Write-Log "Email sent to $EmailTo" -Color Green

        # Clean up CSV after sending
        if (Test-Path $resultsPath) {
            Remove-Item -Path $resultsPath -Force
            Write-Log "CSV cleaned up" -Color Gray
        }
    }
    catch {
        Write-Log "Failed to send email: $($_.Exception.Message)" -Color Red
        Write-Log "CSV retained: $resultsPath" -Color Yellow
    }
}
