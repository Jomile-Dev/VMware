# VMware Aria Automation - Bulk CMDB Relations Extractor
# Calls the vRO form external-values endpoint to retrieve CMDB data for all VMs
# Uses runspace pooling for parallel execution (ISE compatible)

$vraServer  = "vra.yourdomain.com"
$resultsDir = "C:\Logs"

# Email Configuration
$SendEmail    = $true
$EmailTo      = "admin@company.com"
$EmailFrom    = "vmware-reports@company.com"
$EmailSubject = "CMDB Relations Comparison Report - $(Get-Date -Format 'yyyy-MM-dd')"
$SMTPServer   = "mail.company.com"
$SMTPPort     = 465
$UseSSL       = $true

# vRO action URIs - update these to match your environment
$showVmDetailsUri = "something.something.something.wrappers/showVmDetails"
$getVmAppsUri     = "something.something.something.returns/getVmApplications"
$getCagAppsUri    = "something.something.something.returns/getCagApplications"
$returnAppVmsUri  = "something.something.something.returns/returnApplicationVms"

# Debug: set this to ONE VMName to dump the raw review-phase response to
# $resultsDir\review_raw_<vm>.json so you can see exactly what the two review
# actions return. Leave "" to disable.
$DebugReviewVMName = ""

# When $true AND $DebugReviewVMName is set, the review phase processes ONLY that one
# VM (1 job instead of 932) so its raw JSON dump appears in seconds. Leave $false for
# a full review run.
$DebugReviewOnly = $false

# Set $true to run a one-time, read-only probe that asks vRO (by action NAME)
# which module getCagApplications / returnApplicationVms actually live in and
# whether they're reachable via the Action REST API. Writes vro_action_probe.json.
# Turn on when a call fails with "not resolved in module".
$ProbeVroActions = $false

# Replay mode: set to a previous CMDBRelations_*.csv to SKIP the slow main match
# pool + NSX fallback and run ONLY the review phase against those saved rows.
# The quick deployment fetch still runs (it supplies ProjectId/ProjectName). "" = normal run.
$ReplayFromCsv = ""

# NSX Manager Configuration (fallback for VMs with empty AppApplication)
$NSXManager       = "nsx-manager.company.com"
$NSXAuthMode      = "vIDM"
$NSXvIDMDomain    = "COMPANY"
$NSXCredPath      = "C:\Scripts\Creds\nsx_cred.xml"

function Write-Log {
    param($Message, $Color = "White")
    Write-Host $Message -ForegroundColor $Color
}

# Configure TLS 1.2 and bypass SSL for vRA
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
[System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

# Authenticate to VMware Aria
Write-Log "=== AUTHENTICATION ===" -Color Cyan
$credential = Get-Credential -Message "Enter VMware Aria Automation credentials"

$authBody = @{
    username = $credential.UserName
    password = $credential.GetNetworkCredential().Password
} | ConvertTo-Json

$authResponse = Invoke-RestMethod -Uri "https://$vraServer/csp/gateway/am/api/login" `
    -Method Post -Headers @{"Content-Type"="application/json"} -Body $authBody

$authToken = $authResponse.cspAuthToken
Write-Log "Authentication successful!" -Color Green

# Normalise application name for comparison
function Normalize-AppName {
    param($Name)
    if (-not $Name) { return "" }
    return ($Name.ToLower().Trim() -replace '[_\s\-\.]+', '')
}

# Fetch all deployments with resources in one pass (size=1000, same as working export script)
Write-Log "`n=== FETCHING DEPLOYMENTS ===" -Color Cyan

$headers = @{
    "Authorization" = "Bearer $authToken"
    "Content-Type"  = "application/json"
}

$vmQueue = [System.Collections.Generic.List[hashtable]]::new()
$page = 0
$size = 1000
$totalProcessed = 0
$skippedCount = 0

do {
    $uri = "https://$vraServer/deployment/api/deployments?page=$page&size=$size&expand=resources"
    Write-Log "  Page $($page + 1)..." -Color Gray

    $response = Invoke-RestMethod -Uri $uri -Method Get -Headers $headers
    $deployments = if ($response.content) { $response.content } else { $response }

    foreach ($dep in $deployments) {
        # Skip deleted/failed deployments
        if ($dep.status -and $dep.status -in @("DELETE_SUCCESSFUL", "FAILED", "DELETE_INPROGRESS")) {
            $skippedCount++
            continue
        }

        $machines = @($dep.resources | Where-Object { $_.type -eq "Cloud.vSphere.Machine" })
        if ($machines.Count -eq 0) { continue }

        foreach ($machine in $machines) {
            # Skip failed or missing VMs
            if ($machine.state -and $machine.state -notin @("OK", "STARTED", "")) { continue }

            $vmName = if ($machine.properties.resourceName) { $machine.properties.resourceName }
                      elseif ($machine.properties.hostname) { $machine.properties.hostname }
                      else { $machine.name }

            $vmQueue.Add(@{
                DeploymentName = $dep.name
                VMName         = $vmName
                ProjectId      = $dep.projectId
                ProjectName    = $dep.projectName
            })
        }
    }

    $totalProcessed += $deployments.Count
    $page++

    $hasMore = if ($response.totalPages) {
        $page -lt $response.totalPages
    } elseif ($response.totalElements) {
        $totalProcessed -lt $response.totalElements
    } else {
        $deployments.Count -eq $size
    }
} while ($hasMore)

Write-Log "Scanned: $totalProcessed deployments (skipped $skippedCount deleted/failed)" -Color Cyan
Write-Log "VMs to process: $($vmQueue.Count)" -Color Cyan

# Scriptblock that runs in each runspace
$scriptBlock = {
    param($VraServer, $AuthToken, $ShowVmDetailsUri, $GetVmAppsUri, $VMName, $ProjectId, $ProjectName, $DeploymentName)

    [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
    [System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

    $headers = @{
        "Authorization" = "Bearer $AuthToken"
        "Content-Type"  = "application/json"
    }

    $uri = "https://$VraServer/form-service/api/forms/renderer/external-values?projectId=$ProjectId"

    $bodyArray = @(
        @{
            uri                     = $ShowVmDetailsUri
            dataSource              = "scriptAction"
            parameters              = @(
                @{ name = "vmName"; value = $VMName }
            )
            useResultsFromRequestId = -1
            fieldType               = @{ dataType = "complex" }
            fields                  = @(
                @{ label = "Scope"; type = @{ dataType = "string" }; id = "scope" },
                @{ label = "Tag";   type = @{ dataType = "string" }; id = "tag" }
            )
            isMultiple              = $true
            requestId               = 1
        },
        @{
            uri                     = $GetVmAppsUri
            dataSource              = "scriptAction"
            parameters              = @(
                @{ name = "vmName";      value = $VMName },
                @{ name = "projectName"; value = $ProjectName }
            )
            useResultsFromRequestId = -1
            fieldType               = @{ dataType = "string" }
            isMultiple              = $true
            requestId               = 2
        }
    )

    $body = "[" + (($bodyArray | ForEach-Object { $_ | ConvertTo-Json -Depth 5 -Compress }) -join ",") + "]"

    try {
        $response = Invoke-RestMethod -Uri $uri -Method Post -Headers $headers -Body $body

        $appApplications = [System.Collections.ArrayList]::new()
        $infraOs        = ""
        $appLayer       = ""
        $vmApplications = ""

        foreach ($result in $response) {
            switch ($result.requestId) {
                1 {
                    if ($result.data -is [array]) {
                        foreach ($item in $result.data) {
                            if ($item.scope -and $item.tag) {
                                if ($item.scope -eq "app-application") {
                                    [void]$appApplications.Add($item.tag)
                                }
                                elseif ($item.scope -eq "infra-os") {
                                    $infraOs = $item.tag
                                }
                                elseif ($item.scope -eq "app-layer") {
                                    $appLayer = $item.tag
                                }
                            }
                        }
                    }
                }
                2 {
                    if ($result.data -is [array]) {
                        $vmApplications = ($result.data | Where-Object { $_ -and $_ -notmatch "^---" }) -join "; "
                    }
                }
            }
        }

        $appApplication = ($appApplications | Select-Object -Unique) -join "; "

        # Compare each tag against each CMDB CI entry
        $match = "Missing Data"
        $matchedApps = @()

        if ($appApplications.Count -gt 0 -and $vmApplications) {
            $ciList = $vmApplications -split ";\s*"
            foreach ($tag in $appApplications) {
                $normTag = ($tag.ToLower().Trim() -replace '[_\s\-\.]+', '')
                foreach ($ci in $ciList) {
                    $normCI = ($ci.ToLower().Trim() -replace '[_\s\-\.]+', '')
                    if ($normTag -and $normCI -and $normTag -eq $normCI) {
                        $matchedApps += $tag
                        break
                    }
                }
            }
            if ($matchedApps.Count -gt 0) {
                if ($appApplications.Count -gt 1) {
                    $match = "Match - Multiple Tags"
                } else {
                    $match = "Match"
                }
            } else {
                $match = "Mismatch"
            }
        }

        $matchedAppsStr = ($matchedApps | Select-Object -Unique) -join "; "

        return [PSCustomObject]@{
            DeploymentName = $DeploymentName
            VMName         = $VMName
            AppApplication = $appApplication
            InfraOS        = $infraOs
            AppLayer       = $appLayer
            CMDBCI         = $vmApplications
            CompareResult  = $match
            Status         = "Success"
        }
    }
    catch {
        return [PSCustomObject]@{
            DeploymentName = $DeploymentName
            VMName         = $VMName
            AppApplication = ""
            InfraOS        = ""
            AppLayer       = ""
            CMDBCI         = ""
            CompareResult  = ""
            Status         = "Failed: $($_.Exception.Message)"
        }
    }
}

# Shared settings (used by both the main match pool and the review phase)
$poolSize = 50
$jobTimeoutSeconds = 120
$stopwatch = [System.Diagnostics.Stopwatch]::StartNew()

if ($ReplayFromCsv) {
    # REPLAY MODE: skip the slow per-VM match pool + NSX fallback; load prior results.
    Write-Log "`n=== REPLAY MODE: loading results from $ReplayFromCsv ===" -Color Cyan
    $results = [System.Collections.Generic.List[object]]::new()
    foreach ($row in (Import-Csv -Path $ReplayFromCsv)) {
        $results.Add([PSCustomObject]@{
            DeploymentName         = [string]$row.DeploymentName
            VMName                 = [string]$row.VMName
            AppApplication         = [string]$row.AppApplication
            InfraOS                = [string]$row.InfraOS
            AppLayer               = [string]$row.AppLayer
            CMDBCI                 = [string]$row.CMDBCI
            CompareResult          = [string]$row.CompareResult
            NSXMatchCMDB           = [string]$row.NSXMatchCMDB
            AppOrSubApp            = ""
            UpstreamToApp          = ""
            MultipleUpstream       = ""
            NoUpstreamRelationship = ""
            Decommissioned         = ""
        })
    }
    $successCount = $results.Count
    $failCount    = 0
    Write-Log "  Loaded $($results.Count) rows - running review phase only" -Color Green
}
else {

# Process with single runspace pool and timeout per job
Write-Log "`n=== PROCESSING $($vmQueue.Count) VMs ($poolSize parallel threads, ${jobTimeoutSeconds}s timeout) ===" -Color Cyan

$runspacePool = [System.Management.Automation.Runspaces.RunspaceFactory]::CreateRunspacePool(1, $poolSize)
$runspacePool.Open()

$results = [System.Collections.Generic.List[object]]::new()
$jobs = [System.Collections.Generic.List[object]]::new()
$completed = 0
$successCount = 0
$failCount = 0

# Queue all jobs
foreach ($vm in $vmQueue) {
    $ps = [PowerShell]::Create().AddScript($scriptBlock)
    $ps.AddArgument($vraServer)          | Out-Null
    $ps.AddArgument($authToken)          | Out-Null
    $ps.AddArgument($showVmDetailsUri)   | Out-Null
    $ps.AddArgument($getVmAppsUri)       | Out-Null
    $ps.AddArgument($vm.VMName)          | Out-Null
    $ps.AddArgument($vm.ProjectId)       | Out-Null
    $ps.AddArgument($vm.ProjectName)     | Out-Null
    $ps.AddArgument($vm.DeploymentName)  | Out-Null
    $ps.RunspacePool = $runspacePool

    $jobs.Add(@{
        PowerShell = $ps
        Handle     = $ps.BeginInvoke()
        VMName     = $vm.VMName
    })
}

# Collect results with timeout
foreach ($job in $jobs) {
    $completed++

    if ($job.Handle.AsyncWaitHandle.WaitOne($jobTimeoutSeconds * 1000)) {
        $result = $job.PowerShell.EndInvoke($job.Handle)

        if ($result) {
            foreach ($r in $result) {
                if ($r.Status -eq "Success") {
                    $successCount++
                    $matchColor = switch ($r.CompareResult) {
                        "Match"    { "Green" }
                        "Mismatch" { "Red" }
                        default    { "Gray" }
                    }

                    # Show what was returned for Missing Data so you can see what's empty
                    if ($r.CompareResult -eq "Missing Data") {
                        $tagVal = if ($r.AppApplication) { $r.AppApplication } else { "(empty)" }
                        $appVal = if ($r.CMDBCI) { $r.CMDBCI } else { "(empty)" }
                        Write-Log "[$completed/$($vmQueue.Count)] $($r.VMName) | Tag: $tagVal | CMDB CI: $appVal | Missing Data" -Color Gray
                    }
                    else {
                        Write-Log "[$completed/$($vmQueue.Count)] $($r.VMName) | $($r.AppApplication) | $($r.CompareResult)" -Color $matchColor
                    }
                }
                else {
                    $failCount++
                    Write-Log "[$completed/$($vmQueue.Count)] $($r.VMName) | FAILED - $($r.Status)" -Color Red
                }

                $results.Add([PSCustomObject]@{
                    DeploymentName        = [string]$r.DeploymentName
                    VMName                = [string]$r.VMName
                    AppApplication        = [string]$r.AppApplication
                    InfraOS               = [string]$r.InfraOS
                    AppLayer              = [string]$r.AppLayer
                    CMDBCI                = [string]$r.CMDBCI
                    CompareResult         = [string]$r.CompareResult
                    # --- NEW review columns (populated in the review phase below) ---
                    NSXMatchCMDB          = ""
                    AppOrSubApp           = ""
                    UpstreamToApp         = ""
                    MultipleUpstream      = ""
                    NoUpstreamRelationship = ""
                    Decommissioned        = ""
                })
            }
        }
    }
    else {
        $failCount++
        Write-Log "[$completed/$($vmQueue.Count)] $($job.VMName) | TIMEOUT after ${jobTimeoutSeconds}s" -Color Red
        $job.PowerShell.Stop()
    }

    $job.PowerShell.Dispose()
}

if ($runspacePool) { $runspacePool.Close(); $runspacePool.Dispose() }
$stopwatch.Stop()

# NSX Fallback - fill in missing AppApplication from NSX VM tags
$missingAppVMs = @($results | Where-Object { -not $_.AppApplication })

if ($missingAppVMs.Count -gt 0) {
    Write-Log "`n=== NSX FALLBACK: $($missingAppVMs.Count) VMs with empty AppApplication ===" -Color Cyan

    # NSX Auth functions (from working NSX firewall script)
    function Connect-NSXManagerFallback {
        param(
            [string]$Server,
            [PSCredential]$Credential,
            [string]$AuthMode = "Local",
            [string]$VIDMDomain = ""
        )

        $headers = @{
            "Content-Type" = "application/json"
            "Accept"       = "application/json"
        }

        if ($AuthMode -eq "Local") {
            $pair   = "{0}:{1}" -f $Credential.UserName, $Credential.GetNetworkCredential().Password
            $bytes  = [System.Text.Encoding]::ASCII.GetBytes($pair)
            $base64 = [System.Convert]::ToBase64String($bytes)
            $headers["Authorization"] = "Basic $base64"
            Write-Log "  NSX authenticating (Local/Basic)..." -Color Cyan
        }
        else {
            Write-Log "  NSX authenticating via vIDM session..." -Color Cyan
            $sessionUri = "https://${Server}/api/session/create"
            $rawUser    = $Credential.UserName
            $password   = $Credential.GetNetworkCredential().Password

            if ($rawUser -match '^(.+)\\(.+)$') { $samName = $Matches[2] }
            elseif ($rawUser -match '^([^@]+)@') { $samName = $Matches[1] }
            else { $samName = $rawUser }

            $usernamesToTry = @(
                $samName
            )

            $authenticated = $false
            foreach ($username in $usernamesToTry) {
                Write-Log "  Trying: $username" -Color Gray
                $body = "j_username=$([uri]::EscapeDataString($username))&j_password=$([uri]::EscapeDataString($password))"

                try {
                    $sessionResponse = Invoke-WebRequest -Uri $sessionUri `
                        -Method Post `
                        -ContentType "application/x-www-form-urlencoded" `
                        -Body $body `
                        -SessionVariable "nsxSession" `
                        -UseBasicParsing `
                        -ErrorAction Stop

                    $xsrfToken = $sessionResponse.Headers["X-XSRF-TOKEN"]
                    if (-not $xsrfToken) {
                        Write-Log "  No X-XSRF-TOKEN for '$username', trying next..." -Color Yellow
                        continue
                    }

                    $headers["X-XSRF-TOKEN"] = $xsrfToken
                    $script:NSXFallbackSession = $nsxSession
                    $authenticated = $true
                    Write-Log "  NSX authenticated as: $username" -Color Green
                    break
                }
                catch {
                    Write-Log "  Failed: $username - $($_.Exception.Message)" -Color Yellow
                    continue
                }
            }

            if (-not $authenticated) {
                throw "NSX vIDM authentication failed for all username formats"
            }
        }

        # Test connectivity
        $testUri = "https://${Server}/policy/api/v1/infra"
        $testParams = @{ Uri = $testUri; Headers = $headers; Method = "Get"; ErrorAction = "Stop" }
        if ($script:NSXFallbackSession) { $testParams["WebSession"] = $script:NSXFallbackSession }
        $null = Invoke-RestMethod @testParams
        Write-Log "  NSX connection verified" -Color Green

        return $headers
    }

    # Switch SSL mode for NSX (NSX requires TrustAllCertsPolicy, not ServerCertificateValidationCallback)
    [System.Net.ServicePointManager]::ServerCertificateValidationCallback = $null
    if (-not ([System.Management.Automation.PSTypeName]'TrustAllCertsPolicy').Type) {
        Add-Type @"
            using System.Net;
            using System.Security.Cryptography.X509Certificates;
            public class TrustAllCertsPolicy : ICertificatePolicy {
                public bool CheckValidationResult(
                    ServicePoint srvPoint, X509Certificate certificate,
                    WebRequest request, int certificateProblem) { return true; }
            }
"@
    }
    [System.Net.ServicePointManager]::CertificatePolicy = New-Object TrustAllCertsPolicy

    # Import NSX credentials
    $script:NSXFallbackSession = $null

    if (Test-Path $NSXCredPath) {
        $nsxCred = Import-Clixml -Path $NSXCredPath
        Write-Log "  Credentials imported from: $NSXCredPath" -Color Green
    } else {
        $nsxCred = Get-Credential -Message "Enter NSX Manager credentials"
        $credDir = Split-Path $NSXCredPath -Parent
        if (-not (Test-Path $credDir)) { New-Item -ItemType Directory -Path $credDir -Force | Out-Null }
        $nsxCred | Export-Clixml -Path $NSXCredPath
        Write-Log "  Credentials saved to: $NSXCredPath" -Color Green
    }

    try {
        $nsxHeaders = Connect-NSXManagerFallback -Server $NSXManager -Credential $nsxCred -AuthMode $NSXAuthMode -VIDMDomain $NSXvIDMDomain

        $nsxFilled = 0

        foreach ($vm in $missingAppVMs) {
            try {
                $nsxUri = "https://${NSXManager}/api/v1/fabric/virtual-machines?display_name=$($vm.VMName)"

                $invokeParams = @{
                    Uri     = $nsxUri
                    Headers = $nsxHeaders
                    Method  = "Get"
                }
                if ($script:NSXFallbackSession) { $invokeParams["WebSession"] = $script:NSXFallbackSession }

                $nsxResponse = Invoke-RestMethod @invokeParams

                if ($nsxResponse.results -and $nsxResponse.results.Count -gt 0) {
                    $nsxVM = $nsxResponse.results[0]

                    if ($nsxVM.tags) {
                        $nsxAppTags = @()
                        foreach ($tag in $nsxVM.tags) {
                            # Strip ST- prefix from NSX tags for consistency
                            $tagValue = $tag.tag -replace '^ST-', ''

                            switch ($tag.scope) {
                                "app-application" {
                                    $nsxAppTags += $tagValue
                                }
                                "infra-os" {
                                    if (-not $vm.InfraOS) { $vm.InfraOS = $tagValue }
                                }
                                "app-layer" {
                                    if (-not $vm.AppLayer) { $vm.AppLayer = $tagValue }
                                }
                            }
                        }

                        if ($nsxAppTags.Count -gt 0) {
                            $vm.AppApplication = ($nsxAppTags | Select-Object -Unique) -join "; "
                            $nsxFilled++
                            Write-Log "  $($vm.VMName) | NSX Tags: $($vm.AppApplication)" -Color Green

                            # Re-run comparison with multiple tags
                            $matchedApps = @()
                            if ($vm.CMDBCI) {
                                $ciList = $vm.CMDBCI -split ";\s*"
                                foreach ($tag in $nsxAppTags) {
                                    $normTag = ($tag.ToLower().Trim() -replace '[_\s\-\.]+', '')
                                    foreach ($ci in $ciList) {
                                        $normCI = ($ci.ToLower().Trim() -replace '[_\s\-\.]+', '')
                                        if ($normTag -and $normCI -and $normTag -eq $normCI) {
                                            $matchedApps += $tag
                                            break
                                        }
                                    }
                                }
                            }

                            if ($matchedApps.Count -gt 0) {
                                if ($nsxAppTags.Count -gt 1) {
                                    $vm.CompareResult = "Match - Multiple Tags"
                                } else {
                                    $vm.CompareResult = "Match"
                                }
                            } else {
                                $vm.CompareResult = "Mismatch"
                            }
                        }
                        else {
                            Write-Log "  $($vm.VMName) | No app-application tag in NSX" -Color Gray
                        }
                    }
                }
                else {
                    Write-Log "  $($vm.VMName) | Not found in NSX" -Color Gray
                }
            }
            catch {
                Write-Log "  $($vm.VMName) | NSX lookup failed: $($_.Exception.Message)" -Color Red
            }

            Start-Sleep -Milliseconds 100
        }

        Write-Log "  NSX filled: $nsxFilled / $($missingAppVMs.Count)" -Color Cyan
    }
    catch {
        Write-Log "  NSX authentication failed: $($_.Exception.Message)" -Color Red
        Write-Log "  Skipping NSX fallback" -Color Yellow
    }
}

}  # end of normal-run branch (main match pool + NSX fallback); skipped in replay mode

# =====================================================================
# CMDB RELATIONSHIP REVIEW PHASE
# ---------------------------------------------------------------------
# Populates: NSXMatchCMDB, AppOrSubApp, UpstreamToApp,
#            MultipleUpstream, NoUpstreamRelationship
# =====================================================================
Write-Log "`n=== CMDB RELATIONSHIP REVIEW ===" -Color Cyan

# --- 1) NSXMatchCMDB : plain text mapping from the existing CompareResult ---
# NSX Tag = CMDB naming  -> Good
# NSX Tag <> CMDB naming  -> No match, review to modify relationship or segment
foreach ($item in $results) {
    # On replay from a CSV that has no CompareResult column, keep the NSXMatchCMDB
    # value already loaded rather than blanking it.
    if (-not $item.CompareResult) { continue }
    switch ($item.CompareResult) {
        "Match"                { $item.NSXMatchCMDB = "Good" }
        "Match - Multiple Tags" { $item.NSXMatchCMDB = "Good" }
        "Mismatch"             { $item.NSXMatchCMDB = "No match, review to modify relationship or segment" }
        "Missing Data"         { $item.NSXMatchCMDB = "Missing Data" }
        default                { $item.NSXMatchCMDB = $item.CompareResult }
    }
}

# Only VMs that resolved a tag can be reviewed (skip failed / empty rows)
$reviewVMs = @($results | Where-Object { $_.AppApplication })

# Debug fast-path: restrict the review to the single debug VM so its raw JSON
# dump lands in seconds instead of after all VMs are processed.
if ($DebugReviewOnly -and $DebugReviewVMName) {
    $reviewVMs = @($reviewVMs | Where-Object { $_.VMName -eq $DebugReviewVMName })
    Write-Log "DEBUG-ONLY review: restricted to '$DebugReviewVMName' ($($reviewVMs.Count) VM)" -Color Yellow
}

# ---------------------------------------------------------------------
# vRO ACTION PROBE (read-only). Set $ProbeVroActions = $true to ask vRO,
# by NAME, which module each review action lives in and whether it is
# reachable via the Action REST API. Writes C:\Logs\vro_action_probe.json
# and prints each action's real module + href, then continues.
# Use this when a call fails with "not resolved in module".
# ---------------------------------------------------------------------
if ($ProbeVroActions) {
    Write-Log "`n=== vRO ACTION PROBE ===" -Color Cyan
    $probeHeaders = @{ "Authorization" = "Bearer $authToken"; "Accept" = "application/json" }
    $probeOut = @{}
    foreach ($pair in @(
        @{ label = "getCagApplications";   uri = $getCagAppsUri },
        @{ label = "returnApplicationVms"; uri = $returnAppVmsUri }
    )) {
        $mod  = $pair.uri.Substring(0, $pair.uri.LastIndexOf('/'))
        $nm   = $pair.uri.Substring($pair.uri.LastIndexOf('/') + 1)
        Write-Log "  Probing '$nm' (expected module '$mod')..." -Color Gray
        try {
            $enc = [uri]::EscapeDataString($nm)
            $searchUri = "https://$vraServer/vco/api/actions?conditions=name=$enc"
            $res = Invoke-RestMethod -Uri $searchUri -Method Get -Headers $probeHeaders -ErrorAction Stop
            $found = @()
            foreach ($item in $res.link) {
                $href = ($item.attributes | Where-Object { $_.name -eq 'itemHref' }).value
                $fqn  = ($item.attributes | Where-Object { $_.name -eq 'fully.qualified.name' -or $_.name -eq 'name' }).value
                if ($href) { $found += [PSCustomObject]@{ href = $href; attrs = $item.attributes } }
                Write-Log "     -> href: $href" -Color DarkGray
            }
            if (-not $found) { Write-Log "     -> vRO returned NO action named '$nm'." -Color Red }
            $probeOut[$nm] = $res
        }
        catch {
            Write-Log "     -> probe failed: $($_.Exception.Message)" -Color Red
            $probeOut[$nm] = @{ error = $_.Exception.Message }
        }
    }
    try {
        $probePath = Join-Path $resultsDir "vro_action_probe.json"
        $probeOut | ConvertTo-Json -Depth 20 | Out-File -FilePath $probePath -Encoding UTF8
        Write-Log "  Probe written to $probePath" -Color Green
    } catch { Write-Log "  Could not write probe file: $($_.Exception.Message)" -Color Yellow }
}

if ($reviewVMs.Count -gt 0) {
    Write-Log "Reviewing $($reviewVMs.Count) VMs with a resolved app tag..." -Color Gray

    $reviewScriptBlock = {
        param($VraServer, $AuthToken, $GetCagUri, $ReturnAppVmsUri, $VMName, $ProjectId, $ProjectName, $AppTag, $RowIndex, $DebugVMName, $ResultsDir)

        [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
        [System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

        $headers = @{
            "Authorization" = "Bearer $AuthToken"
            "Content-Type"  = "application/json"
        }

        # returnApplicationVms takes the application NAME = the NSX tag with underscores
        # converted to spaces (the queried Key looks like "RANZG DATABASE SYSADMIN
        # APPLICATION"). A VM may carry multiple "; "-joined tags; we use the first tag.
        $primaryTag  = ($AppTag -split ';\s*')[0]
        $tagSpaced   = ($primaryTag -replace '_', ' ')

        # These two actions are NOT exposed as form external-values, so they are
        # called directly against the embedded-vRO Action REST API, resolved by
        # MODULE PATH + ACTION NAME (never the numeric action ID, which can change).
        #   $GetCagUri       = "module.path/getCagApplications"
        #   $ReturnAppVmsUri = "module.path/returnApplicationVms"
        # Embedded vRO base = https://<vraServer>/vco/api ; the vRA bearer token is
        # accepted. Each call POSTs to:
        #   /vco/api/categories/<module>/actions/<name>/executions
        # with a { parameters:[ {name,type,value:{<type>:{value}}} ] } body, then
        # reads the execution result out of .value.
        function Invoke-VroAction {
            param($VraServer, $Bearer, $ModuleAndName, $Inputs)
            $module = $ModuleAndName.Substring(0, $ModuleAndName.LastIndexOf('/'))
            $name   = $ModuleAndName.Substring($ModuleAndName.LastIndexOf('/') + 1)
            $h = @{ "Authorization" = "Bearer $Bearer"; "Accept" = "application/json"; "Content-Type" = "application/json" }

            $paramArr = @()
            foreach ($k in $Inputs.Keys) {
                $val = $Inputs[$k]
                if ($val -is [bool]) {
                    $paramArr += @{ name = $k; type = "boolean"; value = @{ boolean = @{ value = $val } } }
                } else {
                    $paramArr += @{ name = $k; type = "string";  value = @{ string  = @{ value = "$val" } } }
                }
            }
            $b = @{ parameters = $paramArr } | ConvertTo-Json -Depth 10

            $encModule = [uri]::EscapeDataString($module)
            $encName   = [uri]::EscapeDataString($name)
            $execUri   = "https://$VraServer/vco/api/categories/$encModule/actions/$encName/executions"

            try {
                return Invoke-RestMethod -Uri $execUri -Method Post -Headers $h -Body $b -ErrorAction Stop
            }
            catch {
                # Fallback: resolve current href by name, then execute that.
                $searchUri = "https://$VraServer/vco/api/actions?conditions=name=$encName"
                $search = Invoke-RestMethod -Uri $searchUri -Method Get -Headers $h -ErrorAction Stop
                $href = $null
                foreach ($item in $search.link) {
                    $hv = ($item.attributes | Where-Object { $_.name -eq 'itemHref' }).value
                    if ($hv) { if ($hv -like "*$module*") { $href = $hv; break }; if (-not $href) { $href = $hv } }
                }
                if (-not $href) { throw "vRO action '$name' not resolvable in module '$module'." }
                return Invoke-RestMethod -Uri (($href.TrimEnd('/')) + "/executions") -Method Post -Headers $h -Body $b -ErrorAction Stop
            }
        }

        # vRO execution result unwrap: string -> .value.string.value ;
        # array -> .value.array.elements[].string.value ; object -> .value.<type>...
        function Get-VroResult {
            param($Exec)
            if ($null -eq $Exec) { return $null }
            $v = $Exec.value
            if ($null -eq $v) { return $Exec }
            if ($v.string) { return $v.string.value }
            if ($v.array)  { return @($v.array.elements | ForEach-Object { if ($_.string) { $_.string.value } else { $_ } }) }
            if ($v.properties) { return $v.properties }   # composite / complex return
            return $v
        }

        $appOrSubApp      = ""
        $upstreamToApp    = ""
        $multipleUpstream = ""
        $noUpstream       = ""
        $decommissioned   = ""

        try {
            # --- Call 1: getCagApplications (projectName + phaseOutEnabled) ---
            $cagExec = Invoke-VroAction -VraServer $VraServer -Bearer $AuthToken -ModuleAndName $GetCagUri -Inputs @{
                projectName     = $ProjectName
                phaseOutEnabled = $true
            }

            # --- Call 2: returnApplicationVms (applicationName = spaced tag) ---
            $vmsExec = Invoke-VroAction -VraServer $VraServer -Bearer $AuthToken -ModuleAndName $ReturnAppVmsUri -Inputs @{
                applicationName = $tagSpaced
            }

            # Debug dump: write BOTH raw execution responses for the targeted VM.
            if ($DebugVMName -and $VMName -eq $DebugVMName) {
                try {
                    $dbgPath = Join-Path $ResultsDir ("review_raw_" + ($VMName -replace '[^\w\.\-]', '_') + ".json")
                    @{ requestId1_getCagApplications = $cagExec; requestId2_returnApplicationVms = $vmsExec } |
                        ConvertTo-Json -Depth 20 | Out-File -FilePath $dbgPath -Encoding UTF8
                } catch { }
            }

            $cagData     = Get-VroResult -Exec $cagExec   # expected: flat string array
            $upstreamCIs = @()
            $ciStatuses  = @()

            # returnApplicationVms result: retrieveCiInfoByKey.Information[] with nested
            # upstreamCIs[] and Status. Unwrap defensively for whatever Get-VroResult returns.
            $payload = Get-VroResult -Exec $vmsExec
            if ($payload -is [array] -and $payload.Count -eq 1) { $payload = $payload[0] }

            $ciRoot = $null
            if     ($payload.retrieveCiInfoByKey)       { $ciRoot = $payload.retrieveCiInfoByKey }
            elseif ($payload.value.retrieveCiInfoByKey) { $ciRoot = $payload.value.retrieveCiInfoByKey }
            elseif ($payload.Information)               { $ciRoot = $payload }
            elseif ($payload.value.Information)         { $ciRoot = $payload.value }

            if ($ciRoot -and $ciRoot.Information) {
                foreach ($info in @($ciRoot.Information)) {
                    if ($info.Status) { $ciStatuses += [string]$info.Status }
                    if ($info.upstreamCIs) { $upstreamCIs += @($info.upstreamCIs) }
                }
            }

            # --- App or Sub-App -------------------------------------------------
            # sub-app -> Good ; app -> Convert to sub-app
            # (split logic inlined - parent-scope functions are not visible in a runspace)
            $apps    = [System.Collections.ArrayList]::new()
            $subApps = [System.Collections.ArrayList]::new()
            $mode    = $null
            if ($cagData -is [array]) {
                foreach ($entry in $cagData) {
                    $text = [string]$entry
                    if ($text -match '^\s*-{2,}') {
                        if ($text -match '(?i)sub') { $mode = 'sub' } else { $mode = 'app' }
                        continue
                    }
                    if ([string]::IsNullOrWhiteSpace($text)) { continue }
                    if     ($mode -eq 'sub') { [void]$subApps.Add($text.Trim()) }
                    elseif ($mode -eq 'app') { [void]$apps.Add($text.Trim()) }
                }
            }
            $normTag  = ($primaryTag.ToLower().Trim() -replace '[_\s\-\.]+', '')
            $inSub    = $false
            $inApp    = $false
            foreach ($s in $subApps) { if ((($s.ToLower().Trim() -replace '[_\s\-\.]+', '')) -eq $normTag) { $inSub = $true; break } }
            foreach ($a in $apps)    { if ((($a.ToLower().Trim() -replace '[_\s\-\.]+', '')) -eq $normTag) { $inApp = $true; break } }

            if     ($inSub) { $appOrSubApp = "Good" }
            elseif ($inApp) { $appOrSubApp = "Convert to sub-app" }
            else            { $appOrSubApp = "Tag not found in CAG list" }

            # --- Upstream analysis ---------------------------------------------
            # Upstream presence/count comes from the upstreamCIs[] arrays nested in
            # Information[]. To count from the getCagApplications Applications-section
            # entries instead, swap the $upCount source below.
            $upCount = @($upstreamCIs).Count
            $classes = @($upstreamCIs | ForEach-Object { [string]$_.UpstreamCICMSClass } | Where-Object { $_ })

            # Upstream to App: upstream is an Application -> Good ; SubApplication -> review
            if ($upCount -gt 0) {
                if ($classes -contains "SubApplication") {
                    $upstreamToApp = "Review Upstream Relationship"
                } elseif ($classes -contains "Application") {
                    $upstreamToApp = "Good"
                } else {
                    $upstreamToApp = "Unknown upstream class"
                }
            }

            # Multiple Upstream
            if     ($upCount -gt 1) { $multipleUpstream = "Review Upstream Relationship, multiple Upstreams exist" }
            elseif ($upCount -eq 1) { $multipleUpstream = "Good" }
            else                    { $multipleUpstream = "No upstream" }

            # Decommissioned check - applies to EITHER an app or a sub-app, regardless
            # of upstream. Status comes from returnApplicationVms (looked up by the NSX tag).
            $isDisposed = @($ciStatuses | Where-Object { $_ -match '(?i)dispos|retir' }).Count -gt 0
            if ($isDisposed) {
                if ($appOrSubApp -eq "Convert to sub-app") {
                    $decommissioned = "App decommissioned (disposed/retired)"
                } else {
                    $decommissioned = "Sub-app decommissioned (disposed/retired)"
                }
            }

            # No Upstream Relationship:
            #   if no upstream -> disposed CI gets the disposed note, otherwise the fix note
            #   if it has an upstream -> leave blank
            if ($upCount -eq 0) {
                if ($isDisposed) {
                    $noUpstream = "Show no upstream, disposed subapp, review"
                } else {
                    $noUpstream = "Show no upstream, review fix upstream relationship"
                }
            }

            return [PSCustomObject]@{
                RowIndex               = $RowIndex
                AppOrSubApp            = $appOrSubApp
                UpstreamToApp          = $upstreamToApp
                MultipleUpstream       = $multipleUpstream
                NoUpstreamRelationship = $noUpstream
                Decommissioned         = $decommissioned
                Error                  = ""
            }
        }
        catch {
            return [PSCustomObject]@{
                RowIndex               = $RowIndex
                AppOrSubApp            = ""
                UpstreamToApp          = ""
                MultipleUpstream       = ""
                NoUpstreamRelationship = ""
                Decommissioned         = ""
                Error                  = $_.Exception.Message
            }
        }
    }

    # Reset SSL callback for vRA (NSX fallback may have changed it)
    [System.Net.ServicePointManager]::CertificatePolicy = $null
    [System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

    $reviewPool = [System.Management.Automation.Runspaces.RunspaceFactory]::CreateRunspacePool(1, $poolSize)
    $reviewPool.Open()
    $reviewJobs = [System.Collections.Generic.List[object]]::new()

    # Build an index map so results come back to the right row
    $indexOf = @{}
    for ($i = 0; $i -lt $results.Count; $i++) { $indexOf[$results[$i]] = $i }

    # Build a VMName -> queue-entry lookup ONCE (first occurrence wins, matching the
    # previous "Select-Object -First 1" behaviour). Replaces a per-VM Where-Object scan.
    $queueByVMName = @{}
    foreach ($qv in $vmQueue) {
        if (-not $queueByVMName.ContainsKey($qv.VMName)) { $queueByVMName[$qv.VMName] = $qv }
    }

    foreach ($item in $reviewVMs) {
        $idx = $indexOf[$item]
        $ps = [PowerShell]::Create().AddScript($reviewScriptBlock)
        $ps.AddArgument($vraServer)        | Out-Null
        $ps.AddArgument($authToken)        | Out-Null
        $ps.AddArgument($getCagAppsUri)    | Out-Null
        $ps.AddArgument($returnAppVmsUri)  | Out-Null
        $ps.AddArgument($item.VMName)      | Out-Null
        # ProjectId/ProjectName are not stored on the result row; resolve from the lookup
        $q = $queueByVMName[$item.VMName]
        $ps.AddArgument($(if ($q) { $q.ProjectId }   else { "" })) | Out-Null
        $ps.AddArgument($(if ($q) { $q.ProjectName } else { "" })) | Out-Null
        $ps.AddArgument($item.AppApplication) | Out-Null
        $ps.AddArgument($idx)              | Out-Null
        $ps.AddArgument($DebugReviewVMName) | Out-Null
        $ps.AddArgument($resultsDir)       | Out-Null
        $ps.RunspacePool = $reviewPool

        $reviewJobs.Add(@{
            PowerShell = $ps
            Handle     = $ps.BeginInvoke()
            VMName     = $item.VMName
        })
    }

    $rDone = 0
    foreach ($job in $reviewJobs) {
        $rDone++
        if ($job.Handle.AsyncWaitHandle.WaitOne($jobTimeoutSeconds * 1000)) {
            $out = $job.PowerShell.EndInvoke($job.Handle)
            if ($out) {
                foreach ($o in $out) {
                    $row = $results[$o.RowIndex]
                    $row.AppOrSubApp            = $o.AppOrSubApp
                    $row.UpstreamToApp          = $o.UpstreamToApp
                    $row.MultipleUpstream       = $o.MultipleUpstream
                    $row.NoUpstreamRelationship = $o.NoUpstreamRelationship
                    $row.Decommissioned         = $o.Decommissioned
                    if ($o.Error) {
                        Write-Log "  [$rDone/$($reviewJobs.Count)] $($job.VMName) | review error: $($o.Error)" -Color Yellow
                    } else {
                        Write-Log "  [$rDone/$($reviewJobs.Count)] $($job.VMName) | $($o.AppOrSubApp) | $($o.MultipleUpstream)" -Color Gray
                    }
                }
            }
        }
        else {
            Write-Log "  [$rDone/$($reviewJobs.Count)] $($job.VMName) | review TIMEOUT" -Color Red
            $job.PowerShell.Stop()
        }
        $job.PowerShell.Dispose()
    }

    if ($reviewPool) { $reviewPool.Close(); $reviewPool.Dispose() }
}
else {
    Write-Log "No VMs with a resolved tag to review." -Color Yellow
}

# Summary
Write-Log "`n=== SUMMARY ===" -Color Cyan
Write-Log "VMs processed: $($vmQueue.Count)" -Color White
Write-Log "Successful:    $successCount" -Color Green
Write-Log "Failed:        $failCount" -Color Red
Write-Log "Matches:       $(($results | Where-Object { $_.CompareResult -eq 'Match' }).Count)" -Color Green
Write-Log "Match (Multi): $(($results | Where-Object { $_.CompareResult -eq 'Match - Multiple Tags' }).Count)" -Color Green
Write-Log "Mismatches:    $(($results | Where-Object { $_.CompareResult -eq 'Mismatch' }).Count)" -Color Red
Write-Log "Missing Data:  $(($results | Where-Object { $_.CompareResult -eq 'Missing Data' }).Count)" -Color Gray
Write-Log "--- Review ---" -Color Cyan
Write-Log "Convert to sub-app:     $(($results | Where-Object { $_.AppOrSubApp -eq 'Convert to sub-app' }).Count)" -Color Yellow
Write-Log "Upstream needs review:  $(($results | Where-Object { $_.UpstreamToApp -eq 'Review Upstream Relationship' }).Count)" -Color Yellow
Write-Log "Multiple upstreams:     $(($results | Where-Object { $_.MultipleUpstream -like 'Review*' }).Count)" -Color Yellow
Write-Log "No upstream:            $(($results | Where-Object { $_.NoUpstreamRelationship -like 'Show no upstream*' }).Count)" -Color Yellow
Write-Log "Decommissioned:         $(($results | Where-Object { $_.Decommissioned }).Count)" -Color Yellow
Write-Log "Time elapsed:  $($stopwatch.Elapsed.ToString('hh\:mm\:ss'))" -Color White

# Export results
$resultsPath = "$resultsDir\CMDBRelations_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"
$results | Select-Object * -ExcludeProperty CompareResult | Export-Csv -Path $resultsPath -NoTypeInformation
Write-Log "`nResults saved: $resultsPath" -Color White

# Email report
if ($SendEmail) {
    Write-Log "`n=== SENDING EMAIL ===" -Color Cyan

    $matchCount        = @($results | Where-Object { $_.CompareResult -eq 'Match' }).Count
    $matchMultiCount   = @($results | Where-Object { $_.CompareResult -eq 'Match - Multiple Tags' }).Count
    $mismatchCount     = @($results | Where-Object { $_.CompareResult -eq 'Mismatch' }).Count
    $missingCount      = @($results | Where-Object { $_.CompareResult -eq 'Missing Data' }).Count
    $totalVMs          = @($results).Count
    $generatedAt       = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'

    $emailBody = "<html>"
    $emailBody += "<body style='font-family: Segoe UI, Arial, sans-serif; color: #333;'>"
    $emailBody += "<h2 style='color: #2c3e50;'>CMDB Relations Comparison Report</h2>"
    $emailBody += "<p>Generated: $generatedAt</p>"
    $emailBody += "<h3 style='color: #2c3e50;'>Summary</h3>"
    $emailBody += "<table style='border-collapse:collapse; margin-bottom:20px;'>"
    $emailBody += "<tr style='background:#2c3e50; color:white;'>"
    $emailBody += "<th style='padding:8px 16px; border:1px solid #ddd; text-align:left;'>Category</th>"
    $emailBody += "<th style='padding:8px 16px; border:1px solid #ddd; text-align:right;'>Count</th>"
    $emailBody += "</tr>"
    $emailBody += "<tr style='background:#e8f5e9;'>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd;'>Match</td>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd; text-align:right; color:green; font-weight:bold;'>$matchCount</td>"
    $emailBody += "</tr>"
    $emailBody += "<tr style='background:#e8f5e9;'>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd;'>Match - Multiple Tags</td>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd; text-align:right; color:green; font-weight:bold;'>$matchMultiCount</td>"
    $emailBody += "</tr>"
    $emailBody += "<tr style='background:#ffebee;'>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd;'>Mismatch</td>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd; text-align:right; color:red; font-weight:bold;'>$mismatchCount</td>"
    $emailBody += "</tr>"
    $emailBody += "<tr style='background:#f5f5f5;'>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd;'>Missing Data</td>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd; text-align:right; color:gray; font-weight:bold;'>$missingCount</td>"
    $emailBody += "</tr>"
    $emailBody += "<tr style='background:#e3f2fd;'>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd; font-weight:bold;'>Total VMs</td>"
    $emailBody += "<td style='padding:6px 16px; border:1px solid #ddd; text-align:right; font-weight:bold;'>$totalVMs</td>"
    $emailBody += "</tr>"
    $emailBody += "</table>"
    $emailBody += "</body></html>"

    try {
        # Reset SSL policies so they don't interfere with SMTP TLS
        [System.Net.ServicePointManager]::ServerCertificateValidationCallback = $null
        [System.Net.ServicePointManager]::CertificatePolicy = $null

        $emailParams = @{
            To = $EmailTo
            From = $EmailFrom
            Subject = $EmailSubject
            Body = $emailBody
            BodyAsHtml = $true
            SmtpServer = $SMTPServer
            Port = $SMTPPort
            UseSsl = $UseSSL
            Attachments = $resultsPath
        }

        Send-MailMessage @emailParams

        Write-Log "Email sent to $EmailTo" -Color Green

        # Clean up CSV after sending
        if (Test-Path $resultsPath) {
            Remove-Item -Path $resultsPath -Force
            Write-Log "CSV cleaned up" -Color Gray
        }
    }
    catch {
        Write-Log "Failed to send email: $($_.Exception.Message)" -Color Red
        Write-Log "CSV retained: $resultsPath" -Color Yellow
    }
}
