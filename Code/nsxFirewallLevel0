# Get all DFW policies
$policies = Get-NsxtPolicySecurityPolicy

# Filter policies that DO NOT contain the rule
$result = foreach ($policy in $policies) {
    $rules = Get-NsxtPolicySecurityRule -SecurityPolicyId $policy.Id
    
    if ($rules.DisplayName -notcontains "In-Any-FRONTEND") {
        $policy
    }
}

$result | Select DisplayName, Id
