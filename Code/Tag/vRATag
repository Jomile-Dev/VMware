# ============================================================================
# DIAGNOSTIC: Dump raw Custom Properties for Cloud.vSphere.Machine resources
# Run this first to see exactly what the constraints field looks like
# ============================================================================

$vraServer = "vra1.yourdomain.com"   # <-- change to your vRA server
$maxDeployments = 5                   # <-- how many deployments to inspect

# ============================================================================

function Disable-SSLValidation {
    if (-not ([System.Management.Automation.PSTypeName]'TrustAllCertsPolicy').Type) {
        Add-Type @"
using System.Net;
using System.Security.Cryptography.X509Certificates;
public class TrustAllCertsPolicy : ICertificatePolicy {
    public bool CheckValidationResult(
        ServicePoint svcPoint, X509Certificate certificate,
        WebRequest request, int certificateProblem) { return true; }
}
"@
        [System.Net.ServicePointManager]::CertificatePolicy = New-Object TrustAllCertsPolicy
    }
    [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
}

Disable-SSLValidation

$credential = Import-Clixml -Path "C:\Creds\aria_vra_cred.xml"
$username   = $credential.UserName
$password   = $credential.GetNetworkCredential().Password

# Auth
$authResp = Invoke-RestMethod -Uri "https://$vraServer/csp/gateway/am/api/login" `
    -Method Post `
    -Headers @{ "Content-Type" = "application/json" } `
    -Body (@{ username = $username; password = $password } | ConvertTo-Json) `
    -ErrorAction Stop

$headers = @{
    "Authorization" = "Bearer $($authResp.cspAuthToken)"
    "Content-Type"  = "application/json"
}

Write-Host "`n=== Fetching first $maxDeployments deployments with VM resources ===" -ForegroundColor Cyan

$resp        = Invoke-RestMethod -Uri "https://$vraServer/deployment/api/deployments?page=0&size=100&expand=resources&apiVersion=2020-08-25" `
    -Method Get -Headers $headers -ErrorAction Stop
$deployments = if ($resp.content) { $resp.content } else { $resp }

$count = 0

foreach ($dep in $deployments) {
    if ($count -ge $maxDeployments) { break }

    $vmResources = $dep.resources | Where-Object { $_.type -eq "Cloud.vSphere.Machine" }
    if (-not $vmResources) { continue }

    Write-Host "`n$('='*80)" -ForegroundColor Yellow
    Write-Host "DEPLOYMENT: $($dep.name)  [$($dep.id)]" -ForegroundColor Yellow
    Write-Host "Status     : $($dep.status)"
    Write-Host "Owner      : $($dep.ownedBy)"

    foreach ($resource in $vmResources) {
        Write-Host "`n  --- VM Resource: $($resource.name) ---" -ForegroundColor Cyan
        Write-Host "  Resource Type: $($resource.type)"
        Write-Host "  Resource ID  : $($resource.id)"

        if ($resource.properties) {
            Write-Host "`n  === ALL PROPERTIES (raw dump) ===" -ForegroundColor Green
            $resource.properties | ConvertTo-Json -Depth 10 | Write-Host

            Write-Host "`n  === PROPERTY NAMES ONLY ===" -ForegroundColor Green
            $resource.properties.PSObject.Properties.Name | ForEach-Object {
                Write-Host "    $_"
            }

            # Specifically highlight constraints if present
            if ($resource.properties.PSObject.Properties['constraints']) {
                Write-Host "`n  >>> CONSTRAINTS FIELD FOUND <<<" -ForegroundColor Magenta
                Write-Host "  Type: $($resource.properties.constraints.GetType().FullName)"
                Write-Host "  Value:"
                $resource.properties.constraints | ConvertTo-Json -Depth 10 | Write-Host
            } else {
                Write-Host "`n  >>> NO 'constraints' field on resource.properties <<<" -ForegroundColor Red
            }

            # Check for any property that mentions "Managed" anywhere
            Write-Host "`n  === SEARCHING ALL PROPERTIES FOR 'Managed' ===" -ForegroundColor Green
            $allPropsJson = $resource.properties | ConvertTo-Json -Depth 10 -Compress
            if ($allPropsJson -match "Managed") {
                $resource.properties.PSObject.Properties | ForEach-Object {
                    $propJson = $_.Value | ConvertTo-Json -Depth 5 -Compress
                    if ($propJson -match "Managed") {
                        Write-Host "  FOUND in property '$($_.Name)': $propJson" -ForegroundColor Magenta
                    }
                }
            } else {
                Write-Host "  'Managed' string not found anywhere in properties" -ForegroundColor Red
            }
        } else {
            Write-Host "  >>> resource.properties is NULL/EMPTY <<<" -ForegroundColor Red
        }
    }

    # Also check deployment-level inputs
    Write-Host "`n  === DEPLOYMENT-LEVEL INPUTS ===" -ForegroundColor Cyan
    if ($dep.inputs) {
        $dep.inputs | ConvertTo-Json -Depth 10 | Write-Host
    } else {
        Write-Host "  (no inputs)"
    }

    $count++
}

Write-Host "`n=== DIAGNOSTIC COMPLETE - $count deployments inspected ===" -ForegroundColor Cyan
