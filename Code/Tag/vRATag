# ============================================================================
# DIAGNOSTIC: Find correct consume API endpoint for Cloud.vSphere.Machine
# Tests multiple URL variations to find the one matching the GUI's 837 count
# ============================================================================

$vraServer = "vra1.yourdomain.com"   # <-- change to your vRA server

# ============================================================================

function Disable-SSLValidation {
    if (-not ([System.Management.Automation.PSTypeName]'TrustAllCertsPolicy').Type) {
        Add-Type @"
using System.Net;
using System.Security.Cryptography.X509Certificates;
public class TrustAllCertsPolicy : ICertificatePolicy {
    public bool CheckValidationResult(
        ServicePoint svcPoint, X509Certificate certificate,
        WebRequest request, int certificateProblem) { return true; }
}
"@
        [System.Net.ServicePointManager]::CertificatePolicy = New-Object TrustAllCertsPolicy
    }
    [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
}

Disable-SSLValidation

$credential = Import-Clixml -Path "C:\Creds\aria_vra_cred.xml"
$username   = $credential.UserName
$password   = $credential.GetNetworkCredential().Password

$authResp = Invoke-RestMethod `
    -Uri "https://$vraServer/csp/gateway/am/api/login" `
    -Method Post `
    -Headers @{ "Content-Type" = "application/json" } `
    -Body (@{ username = $username; password = $password } | ConvertTo-Json) `
    -ErrorAction Stop

$headers = @{
    "Authorization" = "Bearer $($authResp.cspAuthToken)"
    "Content-Type"  = "application/json"
}

Write-Host "`n=== Testing API endpoints for Cloud.vSphere.Machine ===" -ForegroundColor Cyan

$urlsToTest = @(
    # Consume API variations
    "https://$vraServer/consume/api/resources?resourceTypes=%5B%22Cloud.vSphere.Machine%22%5D&page=0&size=5",
    "https://$vraServer/consume/api/resources?resourceTypes=Cloud.vSphere.Machine&page=0&size=5",
    "https://$vraServer/consume/api/resources?`$filter=resourceType+eq+'Cloud.vSphere.Machine'&page=0&size=5",
    "https://$vraServer/consume/api/resources?page=0&size=5&resourceType=Cloud.vSphere.Machine",

    # Deployment API variations
    "https://$vraServer/deployment/api/resources?resourceType=Cloud.vSphere.Machine&apiVersion=2020-08-25&page=0&size=5",
    "https://$vraServer/deployment/api/resources?resourceTypes=%5B%22Cloud.vSphere.Machine%22%5D&apiVersion=2020-08-25&page=0&size=5",
    "https://$vraServer/deployment/api/resources?type=Cloud.vSphere.Machine&apiVersion=2020-08-25&page=0&size=5",

    # IaaS API
    "https://$vraServer/iaas/api/machines?apiVersion=2021-07-15&page=0&size=5",
    "https://$vraServer/iaas/api/resources?type=Cloud.vSphere.Machine&apiVersion=2021-07-15&page=0&size=5"
)

foreach ($url in $urlsToTest) {
    Write-Host "`n--- Testing: $url" -ForegroundColor Yellow
    try {
        $resp = Invoke-RestMethod -Uri $url -Method Get -Headers $headers -ErrorAction Stop

        # Try to figure out count and structure
        $items      = if ($resp.content)       { $resp.content }
                      elseif ($resp.resources)  { $resp.resources }
                      elseif ($resp.items)       { $resp.items }
                      else                       { $resp }

        $totalCount = if ($resp.totalElements) { $resp.totalElements }
                      elseif ($resp.total)      { $resp.total }
                      elseif ($resp.totalCount)  { $resp.totalCount }
                      else                       { "unknown" }

        Write-Host "  SUCCESS - Items on this page : $(@($items).Count)" -ForegroundColor Green
        Write-Host "  Total elements reported      : $totalCount" -ForegroundColor Green
        Write-Host "  Response top-level keys      : $($resp.PSObject.Properties.Name -join ', ')" -ForegroundColor Green

        # Show first item structure if any returned
        if (@($items).Count -gt 0) {
            $first = @($items)[0]
            Write-Host "  First item keys: $($first.PSObject.Properties.Name -join ', ')" -ForegroundColor Cyan

            # Check if constraints/customProperties visible at top level
            foreach ($keyword in @("constraint","customPropert","Managed","tag")) {
                $itemJson = $first | ConvertTo-Json -Depth 10 -Compress
                if ($itemJson -match $keyword) {
                    Write-Host "  [FOUND] '$keyword' in first item" -ForegroundColor Magenta
                } else {
                    Write-Host "  [MISSING] '$keyword' not in first item" -ForegroundColor Gray
                }
            }

            Write-Host "`n  First item full JSON:" -ForegroundColor Cyan
            $first | ConvertTo-Json -Depth 10 | Write-Host
        }
    }
    catch {
        Write-Host "  FAILED: $($_.Exception.Message)" -ForegroundColor Red
    }
}

Write-Host "`n=== DIAGNOSTIC COMPLETE ===" -ForegroundColor Cyan
