# VMware Aria Automation - Bulk CMDB Relations Extractor
# Fetches the update_cmdb_relations Day 2 action form data for all Cloud.vSphere.Machine resources

$vraServer = "vra.yourdomain.com"
$resultsDir = "C:\Logs"

function Write-Log {
    param($Message, $Color = "White")
    Write-Host $Message -ForegroundColor $Color
}

# Configure TLS 1.2
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
[System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

# Authenticate to VMware Aria
Write-Log "=== AUTHENTICATION ===" -Color Cyan
$credential = Get-Credential -Message "Enter VMware Aria Automation credentials"

$authBody = @{
    username = $credential.UserName
    password = $credential.GetNetworkCredential().Password
} | ConvertTo-Json

$authResponse = Invoke-RestMethod -Uri "https://$vraServer/csp/gateway/am/api/login" `
    -Method Post -Headers @{"Content-Type"="application/json"} -Body $authBody

$headers = @{
    "Authorization" = "Bearer $($authResponse.cspAuthToken)"
    "Content-Type"  = "application/json"
}
Write-Log "Authentication successful!" -Color Green

# Get all deployments with pagination
function Get-AllDeployments {
    Write-Log "Fetching all deployments..." -Color Cyan
    $allDeployments = @()
    $page = 0
    $size = 100

    do {
        $uri = "https://$vraServer/deployment/api/deployments?page=$page&size=$size&expand=resources"
        Write-Log "  Page $($page + 1)..." -Color Gray

        $response = Invoke-RestMethod -Uri $uri -Method Get -Headers $headers
        $deployments = if ($response.content) { $response.content } else { $response }
        $allDeployments += $deployments

        $hasMore = ($response.totalPages -and $page -lt $response.totalPages - 1) -or
                   ($deployments.Count -eq $size)
        $page++
    } while ($hasMore)

    Write-Log "Total deployments: $($allDeployments.Count)" -Color Cyan
    return $allDeployments
}

# Get the form/schema data for the update_cmdb_relations action on a resource
function Get-CMDBRelationsData {
    param($DeploymentId, $ResourceId)

    $actionId = "Cloud.vSphere.Machine.custom.update_cmdb_relations"

    try {
        # Get the action request schema - this is what populates the form in the UI
        $uri = "https://$vraServer/deployment/api/deployments/$DeploymentId/resources/$ResourceId/actions/$actionId"
        $response = Invoke-RestMethod -Uri $uri -Method Get -Headers $headers
        return $response
    }
    catch {
        Write-Log "    Error: $($_.Exception.Message)" -Color Red
        return $null
    }
}

# Main processing
$allDeployments = Get-AllDeployments
Write-Log "`n=== FETCHING CMDB RELATIONS DATA ===" -Color Cyan

$results = [System.Collections.Generic.List[object]]::new()
$vmCount = 0
$successCount = 0
$failCount = 0

foreach ($dep in $allDeployments) {
    $machines = @($dep.resources | Where-Object { $_.type -eq "Cloud.vSphere.Machine" })

    if ($machines.Count -eq 0) { continue }

    Write-Log "`nDeployment: $($dep.name)" -Color Yellow

    foreach ($machine in $machines) {
        $vmCount++
        Write-Log "  VM: $($machine.name)" -Color White

        $actionData = Get-CMDBRelationsData -DeploymentId $dep.id -ResourceId $machine.id

        if (-not $actionData) {
            Write-Log "    Action not available or failed" -Color Red
            $failCount++
            $results.Add([PSCustomObject]@{
                DeploymentName = [string]$dep.name
                DeploymentId   = [string]$dep.id
                VMName         = [string]$machine.name
                ResourceId     = [string]$machine.id
                Status         = [string]"Failed/Unavailable"
                RawData        = [string]""
            })
            continue
        }

        $successCount++

        # Dump the full schema response as JSON for review
        $jsonData = $actionData | ConvertTo-Json -Depth 10 -Compress

        Write-Log "    Retrieved action data" -Color Green

        # Build a result row with the raw JSON so you can inspect the structure
        $results.Add([PSCustomObject]@{
            DeploymentName = [string]$dep.name
            DeploymentId   = [string]$dep.id
            VMName         = [string]$machine.name
            ResourceId     = [string]$machine.id
            Status         = [string]"Success"
            RawData        = [string]$jsonData
        })

        Start-Sleep -Milliseconds 200
    }
}

# Summary
Write-Log "`n=== SUMMARY ===" -Color Cyan
Write-Log "Deployments scanned: $($allDeployments.Count)" -Color White
Write-Log "VMs found:           $vmCount" -Color White
Write-Log "Data retrieved:      $successCount" -Color Green
Write-Log "Failed/Unavailable:  $failCount" -Color Red

# Export results
$resultsPath = "$resultsDir\CMDBRelations_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"
$results | Export-Csv -Path $resultsPath -NoTypeInformation
Write-Log "`nResults saved: $resultsPath" -Color White

# Also dump full JSON per VM for easier inspection
$jsonDir = "$resultsDir\CMDBRelations_$(Get-Date -Format 'yyyyMMdd_HHmmss')"
New-Item -ItemType Directory -Path $jsonDir -Force | Out-Null

foreach ($result in ($results | Where-Object { $_.Status -eq "Success" })) {
    $safeName = $result.VMName -replace '[\\/:*?"<>|]', '_'
    $jsonPath = "$jsonDir\$safeName.json"
    $result.RawData | Out-File -FilePath $jsonPath -Encoding UTF8
}
Write-Log "JSON files saved: $jsonDir" -Color White
