# VMware Aria Automation - Bulk CMDB Relations Extractor
# Calls the vRO form external-values endpoint to retrieve CMDB data for all VMs
# Uses runspace pooling for parallel execution (ISE compatible)

$vraServer  = "vra.yourdomain.com"
$resultsDir = "C:\Logs"

# Email Configuration
$SendEmail    = $true
$EmailTo      = "admin@company.com"
$EmailFrom    = "vmware-reports@company.com"
$EmailSubject = "CMDB Relations Comparison Report - $(Get-Date -Format 'yyyy-MM-dd')"
$SMTPServer   = "mail.company.com"
$SMTPPort     = 465
$UseSSL       = $true

# vRO action URIs - update these to match your environment
$showVmDetailsUri = "somethingsomething.something.wrappers/showVmDetails"
$getVmAppsUri     = "somethingsomething.something.returns/getVmApplications"

function Write-Log {
    param($Message, $Color = "White")
    Write-Host $Message -ForegroundColor $Color
}

# Configure TLS 1.2
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
[System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

# Authenticate to VMware Aria
Write-Log "=== AUTHENTICATION ===" -Color Cyan
$credential = Get-Credential -Message "Enter VMware Aria Automation credentials"

$authBody = @{
    username = $credential.UserName
    password = $credential.GetNetworkCredential().Password
} | ConvertTo-Json

$authResponse = Invoke-RestMethod -Uri "https://$vraServer/csp/gateway/am/api/login" `
    -Method Post -Headers @{"Content-Type"="application/json"} -Body $authBody

$authToken = $authResponse.cspAuthToken
Write-Log "Authentication successful!" -Color Green

# Get all VM resources directly via the resources API
function Get-AllVMResources {
    Write-Log "Fetching all Cloud.vSphere.Machine resources..." -Color Cyan

    $headers = @{
        "Authorization" = "Bearer $authToken"
        "Content-Type"  = "application/json"
    }

    $allResources = @()
    $page = 0
    $size = 200

    do {
        $uri = "https://$vraServer/deployment/api/resources?page=$page&size=$size&`$filter=type eq 'Cloud.vSphere.Machine'"
        Write-Log "  Page $($page + 1)..." -Color Gray

        $response = Invoke-RestMethod -Uri $uri -Method Get -Headers $headers
        $resources = if ($response.content) { $response.content } else { $response }
        $allResources += $resources

        $hasMore = ($response.totalPages -and $page -lt $response.totalPages - 1) -or
                   ($resources.Count -eq $size)
        $page++
    } while ($hasMore)

    Write-Log "Total VM resources: $($allResources.Count)" -Color Cyan
    return $allResources
}

# Get deployment details (lightweight, for project info)
function Get-DeploymentDetails {
    param($DeploymentId)

    $headers = @{
        "Authorization" = "Bearer $authToken"
        "Content-Type"  = "application/json"
    }

    $uri = "https://$vraServer/deployment/api/deployments/$DeploymentId"
    return Invoke-RestMethod -Uri $uri -Method Get -Headers $headers
}

# Normalise application name for comparison
function Normalize-AppName {
    param($Name)
    if (-not $Name) { return "" }
    return ($Name.ToLower().Trim() -replace '[_\s\-\.]+', '')
}

# Fetch all VM resources in one go
$allVMs = Get-AllVMResources

# Filter to healthy VMs only
$activeVMs = @($allVMs | Where-Object {
    -not $_.state -or $_.state -in @("OK", "STARTED", "")
})
Write-Log "Active VMs: $($activeVMs.Count) (skipped $($allVMs.Count - $activeVMs.Count) non-active)" -Color Cyan

# Build deployment lookup cache (avoid re-fetching the same deployment)
Write-Log "`n=== LOOKING UP DEPLOYMENT DETAILS ===" -Color Cyan
$depCache = @{}
$vmQueue = [System.Collections.Generic.List[hashtable]]::new()
$vmCount = 0

foreach ($vm in $activeVMs) {
    $vmCount++
    $depId = $vm.deploymentId

    if (-not $depId) { continue }

    # Cache deployment details
    if (-not $depCache.ContainsKey($depId)) {
        if ($vmCount % 50 -eq 0) {
            Write-Log "  Processing VM $vmCount / $($activeVMs.Count)..." -Color Gray
        }
        try {
            $dep = Get-DeploymentDetails -DeploymentId $depId

            # Skip deleted/failed deployments
            if ($dep.status -and $dep.status -in @("DELETE_SUCCESSFUL", "FAILED", "DELETE_INPROGRESS")) {
                $depCache[$depId] = $null
            } else {
                $depCache[$depId] = @{
                    Name        = $dep.name
                    ProjectId   = $dep.projectId
                    ProjectName = $dep.projectName
                }
            }
        }
        catch {
            $depCache[$depId] = $null
        }
    }

    $depInfo = $depCache[$depId]
    if (-not $depInfo) { continue }

    $vmName = if ($vm.properties.resourceName) { $vm.properties.resourceName }
              elseif ($vm.properties.hostname) { $vm.properties.hostname }
              else { $vm.name }

    $vmQueue.Add(@{
        DeploymentName = $depInfo.Name
        VMName         = $vmName
        ProjectId      = $depInfo.ProjectId
        ProjectName    = $depInfo.ProjectName
    })
}

Write-Log "VMs to process: $($vmQueue.Count)" -Color Cyan

# Scriptblock that runs in each runspace
$scriptBlock = {
    param($VraServer, $AuthToken, $ShowVmDetailsUri, $GetVmAppsUri, $VMName, $ProjectId, $ProjectName, $DeploymentName)

    [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
    [System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

    $headers = @{
        "Authorization" = "Bearer $AuthToken"
        "Content-Type"  = "application/json"
    }

    $uri = "https://$VraServer/form-service/api/forms/renderer/external-values?projectId=$ProjectId"

    $bodyArray = @(
        @{
            uri                     = $ShowVmDetailsUri
            dataSource              = "scriptAction"
            parameters              = @(
                @{ name = "vmName"; value = $VMName }
            )
            useResultsFromRequestId = -1
            fieldType               = @{ dataType = "complex" }
            fields                  = @(
                @{ label = "Scope"; type = @{ dataType = "string" }; id = "scope" },
                @{ label = "Tag";   type = @{ dataType = "string" }; id = "tag" }
            )
            isMultiple              = $true
            requestId               = 1
        },
        @{
            uri                     = $GetVmAppsUri
            dataSource              = "scriptAction"
            parameters              = @(
                @{ name = "vmName";      value = $VMName },
                @{ name = "projectName"; value = $ProjectName }
            )
            useResultsFromRequestId = -1
            fieldType               = @{ dataType = "string" }
            isMultiple              = $true
            requestId               = 2
        }
    )

    $body = "[" + (($bodyArray | ForEach-Object { $_ | ConvertTo-Json -Depth 5 -Compress }) -join ",") + "]"

    try {
        $response = Invoke-RestMethod -Uri $uri -Method Post -Headers $headers -Body $body

        $appApplication = ""
        $infraOs        = ""
        $appLayer       = ""
        $vmApplications = ""

        foreach ($result in $response) {
            switch ($result.requestId) {
                1 {
                    if ($result.data -is [array]) {
                        foreach ($item in $result.data) {
                            if ($item.scope -and $item.tag) {
                                switch ($item.scope) {
                                    "app-application" { $appApplication = $item.tag }
                                    "infra-os"        { $infraOs = $item.tag }
                                    "app-layer"       { $appLayer = $item.tag }
                                }
                            }
                        }
                    }
                }
                2 {
                    if ($result.data -is [array]) {
                        $vmApplications = ($result.data | Where-Object { $_ -and $_ -notmatch "^---" }) -join "; "
                    }
                }
            }
        }

        # Normalise and compare
        $norm1 = if ($appApplication) { ($appApplication.ToLower().Trim() -replace '[_\s\-\.]+', '') } else { "" }
        $norm2 = if ($vmApplications) { ($vmApplications.ToLower().Trim() -replace '[_\s\-\.]+', '') } else { "" }
        $match = if ($norm1 -and $norm2) {
            if ($norm1 -eq $norm2) { "Match" } else { "Mismatch" }
        } else { "Missing Data" }

        return [PSCustomObject]@{
            DeploymentName = $DeploymentName
            VMName         = $VMName
            AppApplication = $appApplication
            InfraOS        = $infraOs
            AppLayer       = $appLayer
            VMApplications = $vmApplications
            CompareResult  = $match
            Status         = "Success"
        }
    }
    catch {
        return [PSCustomObject]@{
            DeploymentName = $DeploymentName
            VMName         = $VMName
            AppApplication = ""
            InfraOS        = ""
            AppLayer       = ""
            VMApplications = ""
            CompareResult  = ""
            Status         = "Failed: $($_.Exception.Message)"
        }
    }
}

# Create and run the runspace pool
Write-Log "`n=== PROCESSING $($vmQueue.Count) VMs (10 parallel threads) ===" -Color Cyan
$stopwatch = [System.Diagnostics.Stopwatch]::StartNew()

$runspacePool = [System.Management.Automation.Runspaces.RunspaceFactory]::CreateRunspacePool(1, 10)
$runspacePool.Open()

$jobs = [System.Collections.Generic.List[object]]::new()

foreach ($vm in $vmQueue) {
    $ps = [PowerShell]::Create().AddScript($scriptBlock)
    $ps.AddArgument($vraServer)       | Out-Null
    $ps.AddArgument($authToken)       | Out-Null
    $ps.AddArgument($showVmDetailsUri)| Out-Null
    $ps.AddArgument($getVmAppsUri)    | Out-Null
    $ps.AddArgument($vm.VMName)       | Out-Null
    $ps.AddArgument($vm.ProjectId)    | Out-Null
    $ps.AddArgument($vm.ProjectName)  | Out-Null
    $ps.AddArgument($vm.DeploymentName) | Out-Null
    $ps.RunspacePool = $runspacePool

    $jobs.Add(@{
        PowerShell = $ps
        Handle     = $ps.BeginInvoke()
        VMName     = $vm.VMName
    })
}

# Collect results with progress
$results = [System.Collections.Generic.List[object]]::new()
$completed = 0
$successCount = 0
$failCount = 0

foreach ($job in $jobs) {
    $result = $job.PowerShell.EndInvoke($job.Handle)
    $job.PowerShell.Dispose()

    $completed++

    if ($result) {
        foreach ($r in $result) {
            if ($r.Status -eq "Success") {
                $successCount++
                $matchColor = switch ($r.CompareResult) {
                    "Match"    { "Green" }
                    "Mismatch" { "Red" }
                    default    { "Gray" }
                }
                Write-Log "[$completed/$($vmQueue.Count)] $($r.VMName) | $($r.AppApplication) | $($r.CompareResult)" -Color $matchColor
            }
            else {
                $failCount++
                Write-Log "[$completed/$($vmQueue.Count)] $($r.VMName) | FAILED" -Color Red
            }

            $results.Add([PSCustomObject]@{
                DeploymentName = [string]$r.DeploymentName
                VMName         = [string]$r.VMName
                AppApplication = [string]$r.AppApplication
                InfraOS        = [string]$r.InfraOS
                AppLayer       = [string]$r.AppLayer
                VMApplications = [string]$r.VMApplications
                CompareResult  = [string]$r.CompareResult
            })
        }
    }
}

if ($runspacePool) { $runspacePool.Close(); $runspacePool.Dispose() }
$stopwatch.Stop()

# Summary
Write-Log "`n=== SUMMARY ===" -Color Cyan
Write-Log "VMs processed: $($vmQueue.Count)" -Color White
Write-Log "Successful:    $successCount" -Color Green
Write-Log "Failed:        $failCount" -Color Red
Write-Log "Matches:       $(($results | Where-Object { $_.CompareResult -eq 'Match' }).Count)" -Color Green
Write-Log "Mismatches:    $(($results | Where-Object { $_.CompareResult -eq 'Mismatch' }).Count)" -Color Red
Write-Log "Missing Data:  $(($results | Where-Object { $_.CompareResult -eq 'Missing Data' }).Count)" -Color Gray
Write-Log "Time elapsed:  $($stopwatch.Elapsed.ToString('hh\:mm\:ss'))" -Color White

# Export results
$resultsPath = "$resultsDir\CMDBRelations_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"
$results | Export-Csv -Path $resultsPath -NoTypeInformation
Write-Log "`nResults saved: $resultsPath" -Color White

# Email report
if ($SendEmail) {
    Write-Log "`n=== SENDING EMAIL ===" -Color Cyan

    $matchCount    = ($results | Where-Object { $_.CompareResult -eq 'Match' }).Count
    $mismatchCount = ($results | Where-Object { $_.CompareResult -eq 'Mismatch' }).Count
    $missingCount  = ($results | Where-Object { $_.CompareResult -eq 'Missing Data' }).Count
    $totalVMs      = $results.Count

    # Build mismatch detail rows
    $mismatchRows = ""
    $mismatches = @($results | Where-Object { $_.CompareResult -eq 'Mismatch' })
    foreach ($m in $mismatches) {
        $mismatchRows += @"
        <tr>
            <td style="padding:6px 12px; border:1px solid #ddd;">$($m.DeploymentName)</td>
            <td style="padding:6px 12px; border:1px solid #ddd;">$($m.VMName)</td>
            <td style="padding:6px 12px; border:1px solid #ddd;">$($m.AppApplication)</td>
            <td style="padding:6px 12px; border:1px solid #ddd;">$($m.VMApplications)</td>
        </tr>
"@
    }

    # Build missing data rows
    $missingRows = ""
    $missingData = @($results | Where-Object { $_.CompareResult -eq 'Missing Data' })
    foreach ($m in $missingData) {
        $missingRows += @"
        <tr>
            <td style="padding:6px 12px; border:1px solid #ddd;">$($m.DeploymentName)</td>
            <td style="padding:6px 12px; border:1px solid #ddd;">$($m.VMName)</td>
            <td style="padding:6px 12px; border:1px solid #ddd;">$($m.AppApplication)</td>
            <td style="padding:6px 12px; border:1px solid #ddd;">$($m.VMApplications)</td>
        </tr>
"@
    }

    $emailBody = @"
<html>
<body style="font-family: Segoe UI, Arial, sans-serif; color: #333;">
    <h2 style="color: #2c3e50;">CMDB Relations Comparison Report</h2>
    <p>Generated: $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss') | Duration: $($stopwatch.Elapsed.ToString('hh\:mm\:ss'))</p>

    <h3 style="color: #2c3e50;">Summary</h3>
    <table style="border-collapse:collapse; margin-bottom:20px;">
        <tr style="background:#2c3e50; color:white;">
            <th style="padding:8px 16px; border:1px solid #ddd; text-align:left;">Category</th>
            <th style="padding:8px 16px; border:1px solid #ddd; text-align:right;">Count</th>
        </tr>
        <tr style="background:#e8f5e9;">
            <td style="padding:6px 16px; border:1px solid #ddd;">Match</td>
            <td style="padding:6px 16px; border:1px solid #ddd; text-align:right; color:green; font-weight:bold;">$matchCount</td>
        </tr>
        <tr style="background:#ffebee;">
            <td style="padding:6px 16px; border:1px solid #ddd;">Mismatch</td>
            <td style="padding:6px 16px; border:1px solid #ddd; text-align:right; color:red; font-weight:bold;">$mismatchCount</td>
        </tr>
        <tr style="background:#f5f5f5;">
            <td style="padding:6px 16px; border:1px solid #ddd;">Missing Data</td>
            <td style="padding:6px 16px; border:1px solid #ddd; text-align:right; color:gray; font-weight:bold;">$missingCount</td>
        </tr>
        <tr style="background:#e3f2fd;">
            <td style="padding:6px 16px; border:1px solid #ddd; font-weight:bold;">Total VMs</td>
            <td style="padding:6px 16px; border:1px solid #ddd; text-align:right; font-weight:bold;">$totalVMs</td>
        </tr>
        <tr>
            <td style="padding:6px 16px; border:1px solid #ddd;">Failed API Calls</td>
            <td style="padding:6px 16px; border:1px solid #ddd; text-align:right;">$failCount</td>
        </tr>
    </table>

    $(if ($mismatchCount -gt 0) { @"
    <h3 style="color: #c0392b;">Mismatched VMs ($mismatchCount)</h3>
    <table style="border-collapse:collapse; margin-bottom:20px;">
        <tr style="background:#c0392b; color:white;">
            <th style="padding:8px 12px; border:1px solid #ddd; text-align:left;">Deployment</th>
            <th style="padding:8px 12px; border:1px solid #ddd; text-align:left;">VM Name</th>
            <th style="padding:8px 12px; border:1px solid #ddd; text-align:left;">App (CMDB Tag)</th>
            <th style="padding:8px 12px; border:1px solid #ddd; text-align:left;">App (VM Lookup)</th>
        </tr>
        $mismatchRows
    </table>
"@})

    $(if ($missingCount -gt 0) { @"
    <h3 style="color: #7f8c8d;">VMs with Missing Data ($missingCount)</h3>
    <table style="border-collapse:collapse; margin-bottom:20px;">
        <tr style="background:#7f8c8d; color:white;">
            <th style="padding:8px 12px; border:1px solid #ddd; text-align:left;">Deployment</th>
            <th style="padding:8px 12px; border:1px solid #ddd; text-align:left;">VM Name</th>
            <th style="padding:8px 12px; border:1px solid #ddd; text-align:left;">App (CMDB Tag)</th>
            <th style="padding:8px 12px; border:1px solid #ddd; text-align:left;">App (VM Lookup)</th>
        </tr>
        $missingRows
    </table>
"@})

    <p style="color:#888; font-size:12px;">Full results attached as CSV. This is an automated report.</p>
</body>
</html>
"@

    try {
        $smtpCredPath = "$resultsDir\smtp_cred.xml"
        if (Test-Path $smtpCredPath) {
            $smtpCred = Import-Clixml -Path $smtpCredPath
        } else {
            $smtpCred = Get-Credential -Message "Enter SMTP credentials (will be saved encrypted)"
            $smtpCred | Export-Clixml -Path $smtpCredPath
        }

        Send-MailMessage -From $EmailFrom -To $EmailTo -Subject $EmailSubject `
            -Body $emailBody -BodyAsHtml `
            -SmtpServer $SMTPServer -Port $SMTPPort `
            -UseSsl:$UseSSL -Credential $smtpCred `
            -Attachments $resultsPath -ErrorAction Stop

        Write-Log "Email sent to $EmailTo" -Color Green

        # Clean up CSV after sending
        Remove-Item -Path $resultsPath -Force
        Write-Log "CSV cleaned up" -Color Gray
    }
    catch {
        Write-Log "Failed to send email: $($_.Exception.Message)" -Color Red
        Write-Log "CSV retained: $resultsPath" -Color Yellow
    }
}
