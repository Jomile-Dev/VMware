# VMware Aria Automation - Bulk CMDB Relations Extractor
# Calls the vRO form external-values endpoint to retrieve CMDB data for all VMs

$vraServer = "vra.yourdomain.com"
$resultsDir = "C:\Logs"

# vRO action URIs - update these to match your environment
$showVmDetailsUri    = "somethingsomething.something.wrappers/showVmDetails"
$getVmAppsUri        = "somethingsomething.something.returns/getVmApplications"
$getCagAppsUri       = "somethingsomething.something.returns/getCagApplications"

function Write-Log {
    param($Message, $Color = "White")
    Write-Host $Message -ForegroundColor $Color
}

# Configure TLS 1.2
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
[System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

# Authenticate to VMware Aria
Write-Log "=== AUTHENTICATION ===" -Color Cyan
$credential = Get-Credential -Message "Enter VMware Aria Automation credentials"

$authBody = @{
    username = $credential.UserName
    password = $credential.GetNetworkCredential().Password
} | ConvertTo-Json

$authResponse = Invoke-RestMethod -Uri "https://$vraServer/csp/gateway/am/api/login" `
    -Method Post -Headers @{"Content-Type"="application/json"} -Body $authBody

$headers = @{
    "Authorization" = "Bearer $($authResponse.cspAuthToken)"
    "Content-Type"  = "application/json"
}
Write-Log "Authentication successful!" -Color Green

# Get all deployments with pagination
function Get-AllDeployments {
    Write-Log "Fetching all deployments..." -Color Cyan
    $allDeployments = @()
    $page = 0
    $size = 100

    do {
        $uri = "https://$vraServer/deployment/api/deployments?page=$page&size=$size&expand=resources"
        Write-Log "  Page $($page + 1)..." -Color Gray

        $response = Invoke-RestMethod -Uri $uri -Method Get -Headers $headers
        $deployments = if ($response.content) { $response.content } else { $response }
        $allDeployments += $deployments

        $hasMore = ($response.totalPages -and $page -lt $response.totalPages - 1) -or
                   ($deployments.Count -eq $size)
        $page++
    } while ($hasMore)

    Write-Log "Total deployments: $($allDeployments.Count)" -Color Cyan
    return $allDeployments
}

# Normalise application name for comparison (lowercase, strip underscores, spaces, special chars)
function Normalize-AppName {
    param($Name)
    if (-not $Name) { return "" }
    return ($Name.ToLower().Trim() -replace '[_\s\-\.]+', '')
}

# Call the vRO form external-values endpoint for a specific VM
function Get-VMCMDBData {
    param($VMName, $ProjectId, $ProjectName)

    $uri = "https://$vraServer/form-service/api/forms/renderer/external-values?projectId=$ProjectId"

    $bodyArray = @(
        @{
            uri                     = $showVmDetailsUri
            dataSource              = "scriptAction"
            parameters              = @(
                @{ name = "vmName"; value = $VMName }
            )
            useResultsFromRequestId = -1
            fieldType               = @{ dataType = "complex" }
            fields                  = @(
                @{ label = "Scope"; type = @{ dataType = "string" }; id = "scope" },
                @{ label = "Tag";   type = @{ dataType = "string" }; id = "tag" }
            )
            isMultiple              = $true
            requestId               = 1
        },
        @{
            uri                     = $getVmAppsUri
            dataSource              = "scriptAction"
            parameters              = @(
                @{ name = "vmName";      value = $VMName },
                @{ name = "projectName"; value = $ProjectName }
            )
            useResultsFromRequestId = -1
            fieldType               = @{ dataType = "string" }
            isMultiple              = $true
            requestId               = 2
        }
    )

    # Force proper JSON array serialisation in PS 5.1
    $body = "[" + (($bodyArray | ForEach-Object { $_ | ConvertTo-Json -Depth 5 -Compress }) -join ",") + "]"

    try {
        $response = Invoke-RestMethod -Uri $uri -Method Post -Headers $headers -Body $body
        return $response
    }
    catch {
        Write-Log "    Error: $($_.Exception.Message)" -Color Red
        return $null
    }
}

# Parse the response into a single row per VM
function Parse-CMDBResponse {
    param($Response)

    $appApplication = ""
    $infraOs        = ""
    $appLayer       = ""
    $vmApplications = ""

    foreach ($result in $Response) {
        switch ($result.requestId) {
            # requestId 1 - scope/tag objects
            1 {
                if ($result.data -is [array]) {
                    foreach ($item in $result.data) {
                        if ($item.scope -and $item.tag) {
                            switch ($item.scope) {
                                "app-application" { $appApplication = $item.tag }
                                "infra-os"        { $infraOs = $item.tag }
                                "app-layer"       { $appLayer = $item.tag }
                            }
                        }
                    }
                }
            }
            # requestId 2 - VM applications (plain string array)
            2 {
                if ($result.data -is [array]) {
                    $vmApplications = ($result.data | Where-Object { $_ -and $_ -notmatch "^---" }) -join "; "
                }
            }
        }
    }

    # Compare request 1 (app-application tag) vs request 2 (VM applications) after normalising
    $norm1 = Normalize-AppName -Name $appApplication
    $norm2 = Normalize-AppName -Name $vmApplications
    $match = if ($norm1 -and $norm2) {
        if ($norm1 -eq $norm2) { "Match" } else { "Mismatch" }
    } else { "Missing Data" }

    return [PSCustomObject]@{
        AppApplication  = [string]$appApplication
        InfraOS         = [string]$infraOs
        AppLayer        = [string]$appLayer
        VMApplications  = [string]$vmApplications
        CompareResult   = [string]$match
    }
}

# Main processing
$allDeployments = Get-AllDeployments
Write-Log "`n=== FETCHING CMDB DATA ===" -Color Cyan

$results = [System.Collections.Generic.List[object]]::new()
$vmCount = 0
$successCount = 0
$failCount = 0

foreach ($dep in $allDeployments) {
    # Skip failed or deleted deployments
    if ($dep.status -and $dep.status -in @("DELETE_SUCCESSFUL", "FAILED", "DELETE_INPROGRESS")) {
        continue
    }

    $machines = @($dep.resources | Where-Object { $_.type -eq "Cloud.vSphere.Machine" })

    if ($machines.Count -eq 0) { continue }

    Write-Log "`nDeployment: $($dep.name) [$($dep.status)]" -Color Yellow

    foreach ($machine in $machines) {
        # Skip failed or missing VMs
        if ($machine.state -and $machine.state -notin @("OK", "STARTED", "")) {
            Write-Log "  VM: $($machine.name) - Skipped ($($machine.state))" -Color Gray
            continue
        }

        $vmCount++
        $vmName = if ($machine.properties.resourceName) { $machine.properties.resourceName }
                  elseif ($machine.properties.hostname) { $machine.properties.hostname }
                  else { $machine.name }
        Write-Log "  VM: $vmName" -Color White

        $response = Get-VMCMDBData -VMName $vmName -ProjectId $dep.projectId -ProjectName $dep.projectName

        if (-not $response) {
            $failCount++
            continue
        }

        $successCount++
        $parsed = Parse-CMDBResponse -Response $response

        $matchColor = if ($parsed.CompareResult -eq "Match") { "Green" }
                      elseif ($parsed.CompareResult -eq "Mismatch") { "Red" }
                      else { "Gray" }

        Write-Log "    App: $($parsed.AppApplication) | VM Apps: $($parsed.VMApplications) | $($parsed.CompareResult)" -Color $matchColor

        $results.Add([PSCustomObject]@{
            DeploymentName  = [string]$dep.name
            VMName          = [string]$vmName
            AppApplication  = [string]$parsed.AppApplication
            InfraOS         = [string]$parsed.InfraOS
            AppLayer        = [string]$parsed.AppLayer
            VMApplications  = [string]$parsed.VMApplications
            CompareResult   = [string]$parsed.CompareResult
        })

        Start-Sleep -Milliseconds 300
    }
}

# Summary
Write-Log "`n=== SUMMARY ===" -Color Cyan
Write-Log "Deployments scanned: $($allDeployments.Count)" -Color White
Write-Log "VMs processed:       $vmCount" -Color White
Write-Log "Successful:          $successCount" -Color Green
Write-Log "Failed:              $failCount" -Color Red

# Export results
$resultsPath = "$resultsDir\CMDBRelations_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"
$results | Export-Csv -Path $resultsPath -NoTypeInformation
Write-Log "`nResults saved: $resultsPath" -Color White
