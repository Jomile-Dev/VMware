<?xml version="1.0" encoding="UTF-8"?>
<!--
  VMware Aria Operations 8.18.6
  Dashboard: CPU Contention & Overprovisioning — VI Workload Domains
  Import via: Dashboards -> Actions -> Import Dashboard
  
  BEFORE IMPORTING:
    1. Create a custom group scoping to VI workload domains only:
       Environment -> Groups -> + Add Group
       Name: "VI Workload Domains"
       Group Type: Custom
       Membership: Tag = vcf:domain:workload  (adjust to match your tag policy)
    2. Replace GROUP_ID_PLACEHOLDER below with the actual group UUID
       from: Administration -> Configuration -> Groups -> copy UUID from URL
    3. Adjust cluster names in alert definitions to match your environment
-->

<dashboardList>
  <dashboard id="cpu-contention-vi-dashboard" version="8.18.6">
    <name>CPU Contention &amp; Overprovisioning — VI Workload Domains</name>
    <description>Single-pane view of CPU demand, N-1 failure headroom, CPU Ready contention, vCPU:pCPU ratio, and host heatmap scoped to VI workload domain clusters only. Suitable for both engineering and management audiences.</description>
    <widgetList>

      <!-- ============================================================ -->
      <!-- ROW 1: SCOREBOARD WIDGETS — 4 headline KPIs                  -->
      <!-- ============================================================ -->

      <widget id="scoreboard-clusters-at-risk" type="scoreboard" row="0" col="0" rowSpan="2" colSpan="3">
        <name>Clusters breaching N-1 capacity</name>
        <description>Count of VI clusters that exceed 100% CPU demand when one host is removed (N-1 scenario)</description>
        <config>
          <objectScope>
            <groupId>GROUP_ID_PLACEHOLDER</groupId>
            <objectType>ClusterComputeResource</objectType>
          </objectScope>
          <metric>summary|capacityRemainingUsingDemandMetric</metric>
          <thresholds>
            <threshold color="red"    operator="lt" value="0"  label="BREACH — N-1 fails"/>
            <threshold color="yellow" operator="lt" value="15" label="MARGINAL — low headroom"/>
            <threshold color="green"  operator="gte" value="15" label="OK"/>
          </thresholds>
          <aggregation>count_critical</aggregation>
          <displayFormat>COUNT_CRITICAL_OF_TOTAL</displayFormat>
        </config>
      </widget>

      <widget id="scoreboard-vcpu-pcpu-ratio" type="scoreboard" row="0" col="3" rowSpan="2" colSpan="3">
        <name>Peak vCPU : pCPU ratio (VI clusters)</name>
        <description>Highest vCPU to pCPU ratio observed across all VI workload domain hosts. Policy threshold: 3:1</description>
        <config>
          <objectScope>
            <groupId>GROUP_ID_PLACEHOLDER</groupId>
            <objectType>HostSystem</objectType>
          </objectScope>
          <metric>cpu|vcpusPerCore</metric>
          <thresholds>
            <threshold color="red"    operator="gt" value="3.0"  label="Overcommit — exceeds 3:1 policy"/>
            <threshold color="yellow" operator="gt" value="2.5"  label="Warning — approaching limit"/>
            <threshold color="green"  operator="lte" value="2.5" label="OK"/>
          </thresholds>
          <aggregation>max</aggregation>
          <displayFormat>MAX_VALUE</displayFormat>
          <unit>ratio</unit>
        </config>
      </widget>

      <widget id="scoreboard-cpu-ready" type="scoreboard" row="0" col="6" rowSpan="2" colSpan="3">
        <name>Clusters with CPU Ready &gt; 5%</name>
        <description>Number of VI clusters where at least one VM has CPU Ready above the 5% contention threshold</description>
        <config>
          <objectScope>
            <groupId>GROUP_ID_PLACEHOLDER</groupId>
            <objectType>ClusterComputeResource</objectType>
          </objectScope>
          <metric>cpu|readyPct</metric>
          <thresholds>
            <threshold color="red"    operator="gt" value="10" label="Critical contention"/>
            <threshold color="yellow" operator="gt" value="5"  label="Active contention"/>
            <threshold color="green"  operator="lte" value="5" label="OK"/>
          </thresholds>
          <aggregation>count_critical</aggregation>
          <displayFormat>COUNT_CRITICAL_OF_TOTAL</displayFormat>
        </config>
      </widget>

      <widget id="scoreboard-peak-demand" type="scoreboard" row="0" col="9" rowSpan="2" colSpan="3">
        <name>Worst cluster CPU demand</name>
        <description>Highest current CPU demand across all VI workload clusters, with N-1 projected value annotated</description>
        <config>
          <objectScope>
            <groupId>GROUP_ID_PLACEHOLDER</groupId>
            <objectType>ClusterComputeResource</objectType>
          </objectScope>
          <metric>cpu|demandmhz</metric>
          <thresholds>
            <threshold color="red"    operator="gt" value="85" label="Critical — N-1 will breach 100%"/>
            <threshold color="yellow" operator="gt" value="70" label="Warning — limited N-1 headroom"/>
            <threshold color="green"  operator="lte" value="70" label="OK"/>
          </thresholds>
          <aggregation>max_percent_of_capacity</aggregation>
          <displayFormat>PERCENTAGE</displayFormat>
        </config>
      </widget>

      <!-- ============================================================ -->
      <!-- ROW 2: DEMAND BAR CHART + N-1 HEADROOM TABLE                 -->
      <!-- ============================================================ -->

      <widget id="topn-cluster-demand" type="topN" row="2" col="0" rowSpan="5" colSpan="7">
        <name>CPU demand — current vs N-1 projection per cluster</name>
        <description>Horizontal bar chart comparing live CPU demand to N-1 projected demand for each VI cluster. Bars exceeding 100% indicate HA cannot protect workloads on a single host failure.</description>
        <config>
          <objectScope>
            <groupId>GROUP_ID_PLACEHOLDER</groupId>
            <objectType>ClusterComputeResource</objectType>
          </objectScope>
          <metrics>
            <metric id="current" key="cpu|demandmhz" label="Current demand %" displayAs="percent_of_capacity"/>
            <metric id="n1proj"  key="summary|capacityRemainingUsingDemandMetric" label="N-1 projected %" displayAs="inverse_percent_of_capacity"/>
          </metrics>
          <topN>10</topN>
          <sortBy>current</sortBy>
          <sortOrder>desc</sortOrder>
          <thresholds>
            <threshold metric="current" color="red"    operator="gt" value="85"/>
            <threshold metric="current" color="yellow" operator="gt" value="70"/>
            <threshold metric="n1proj"  color="red"    operator="gt" value="100" label="N-1 BREACH"/>
            <threshold metric="n1proj"  color="yellow" operator="gt" value="85"  label="N-1 MARGINAL"/>
          </thresholds>
          <showLegend>true</showLegend>
          <referenceLines>
            <referenceLine value="100" label="N-1 breach threshold" color="red" style="dashed"/>
            <referenceLine value="85"  label="Warning threshold"    color="yellow" style="dashed"/>
          </referenceLines>
        </config>
      </widget>

      <widget id="list-n1-headroom" type="list" row="2" col="7" rowSpan="5" colSpan="5">
        <name>N-1 host failure — headroom check</name>
        <description>Per-cluster table showing current CPU demand vs projected demand after losing one host. Red = cluster cannot survive host failure. Use this to prioritise remediation.</description>
        <config>
          <objectScope>
            <groupId>GROUP_ID_PLACEHOLDER</groupId>
            <objectType>ClusterComputeResource</objectType>
          </objectScope>
          <columns>
            <column key="object|name"                               label="Cluster"         width="180"/>
            <column key="cpu|demandmhz"                             label="Current %"       width="90"  displayAs="percent_of_capacity" colorThreshold="true"/>
            <column key="summary|capacityRemainingUsingDemandMetric" label="N-1 headroom %"  width="110" displayAs="value" colorThreshold="true"/>
            <column key="cpu|vcpusPerCore"                          label="vCPU:pCPU"       width="90"  displayAs="ratio"/>
          </columns>
          <thresholds>
            <threshold column="summary|capacityRemainingUsingDemandMetric" color="red"    operator="lt" value="0"   badge="BREACH"/>
            <threshold column="summary|capacityRemainingUsingDemandMetric" color="yellow" operator="lt" value="15"  badge="MARGINAL"/>
            <threshold column="summary|capacityRemainingUsingDemandMetric" color="green"  operator="gte" value="15" badge="OK"/>
          </thresholds>
          <sortBy>summary|capacityRemainingUsingDemandMetric</sortBy>
          <sortOrder>asc</sortOrder>
          <showBadges>true</showBadges>
        </config>
      </widget>

      <!-- ============================================================ -->
      <!-- ROW 3: TOP VMs BY CPU READY + vCPU:pCPU + HEATMAP           -->
      <!-- ============================================================ -->

      <widget id="topn-vm-cpu-ready" type="topN" row="7" col="0" rowSpan="5" colSpan="4">
        <name>CPU Ready % — top offending VMs</name>
        <description>VMs with the highest CPU Ready percentage across all VI clusters. Above 5% = active contention (VMs waiting for physical CPU time). Above 10% = severe — investigate immediately.</description>
        <config>
          <objectScope>
            <groupId>GROUP_ID_PLACEHOLDER</groupId>
            <objectType>VirtualMachine</objectType>
          </objectScope>
          <metrics>
            <metric id="ready" key="cpu|readyPct" label="CPU Ready %" displayAs="percent"/>
          </metrics>
          <topN>15</topN>
          <sortBy>ready</sortBy>
          <sortOrder>desc</sortOrder>
          <thresholds>
            <threshold color="red"    operator="gt" value="10" label="Severe contention"/>
            <threshold color="yellow" operator="gt" value="5"  label="Active contention"/>
            <threshold color="green"  operator="lte" value="5" label="OK"/>
          </thresholds>
          <referenceLines>
            <referenceLine value="5"  label="5% contention threshold" color="yellow" style="dashed"/>
            <referenceLine value="10" label="10% critical threshold"  color="red"    style="dashed"/>
          </referenceLines>
          <showObjectType>true</showObjectType>
          <showParentCluster>true</showParentCluster>
        </config>
      </widget>

      <widget id="list-vcpu-pcpu-hosts" type="list" row="7" col="4" rowSpan="5" colSpan="4">
        <name>vCPU : pCPU ratio — per host (VI clusters)</name>
        <description>Per-host overcommit ratio. Policy limit is 3:1. Hosts above this threshold are overprovisioned and will cause CPU Ready contention during peak demand. Under N-1 the ratio on surviving hosts rises further.</description>
        <config>
          <objectScope>
            <groupId>GROUP_ID_PLACEHOLDER</groupId>
            <objectType>HostSystem</objectType>
          </objectScope>
          <columns>
            <column key="object|name"        label="Host"          width="200"/>
            <column key="cpu|vcpusPerCore"   label="vCPU:pCPU"     width="100" displayAs="ratio" colorThreshold="true"/>
            <column key="cpu|demandmhz"      label="CPU demand %"  width="110" displayAs="percent_of_capacity" colorThreshold="true"/>
            <column key="cpu|readyPct"       label="CPU Ready %"   width="100" displayAs="percent" colorThreshold="true"/>
          </columns>
          <thresholds>
            <threshold column="cpu|vcpusPerCore" color="red"    operator="gt"  value="3.0" label="Policy breach"/>
            <threshold column="cpu|vcpusPerCore" color="yellow" operator="gt"  value="2.5" label="Approaching limit"/>
            <threshold column="cpu|vcpusPerCore" color="green"  operator="lte" value="2.5" label="OK"/>
          </thresholds>
          <sortBy>cpu|vcpusPerCore</sortBy>
          <sortOrder>desc</sortOrder>
          <referenceLines>
            <referenceLine value="3.0" label="3:1 policy limit" color="red" style="dashed"/>
          </referenceLines>
        </config>
      </widget>

      <widget id="heatmap-host-demand" type="heatmap" row="7" col="8" rowSpan="5" colSpan="4">
        <name>CPU demand heatmap — all VI hosts (7-day peak)</name>
        <description>Each cell represents one ESXi host. Colour shows peak CPU demand over the last 7 days. Red cells are hosts that have already exceeded safe operating thresholds — any one of these failing triggers an N-1 crisis on its cluster.</description>
        <config>
          <objectScope>
            <groupId>GROUP_ID_PLACEHOLDER</groupId>
            <objectType>HostSystem</objectType>
          </objectScope>
          <metric>cpu|demandmhz</metric>
          <metricDisplayAs>percent_of_capacity</metricDisplayAs>
          <timeRange>LAST_7_DAYS</timeRange>
          <aggregation>max</aggregation>
          <groupBy>parent_cluster</groupBy>
          <thresholds>
            <threshold color="green"  operator="lt"  value="75"  label="OK"/>
            <threshold color="yellow" operator="lt"  value="100" label="Warning"/>
            <threshold color="red"    operator="gte" value="100" label="Critical"/>
          </thresholds>
          <cellSize>medium</cellSize>
          <showObjectName>true</showObjectName>
          <showGroupLabel>true</showGroupLabel>
        </config>
      </widget>

      <!-- ============================================================ -->
      <!-- ROW 4: CPU CoStop — SMP VM contention                        -->
      <!-- ============================================================ -->

      <widget id="topn-vm-costop" type="topN" row="12" col="0" rowSpan="4" colSpan="6">
        <name>CPU CoStop % — SMP VM co-scheduling contention</name>
        <description>Multi-vCPU VMs waiting for all vCPUs to be scheduled simultaneously. High CoStop means large VMs (4+ vCPU) are competing for CPU slots — a direct result of overprovisioning on hosts already above 3:1 ratio.</description>
        <config>
          <objectScope>
            <groupId>GROUP_ID_PLACEHOLDER</groupId>
            <objectType>VirtualMachine</objectType>
          </objectScope>
          <metrics>
            <metric id="costop" key="cpu|costopPct" label="CPU CoStop %" displayAs="percent"/>
          </metrics>
          <topN>10</topN>
          <sortBy>costop</sortBy>
          <sortOrder>desc</sortOrder>
          <thresholds>
            <threshold color="red"    operator="gt"  value="3"  label="Severe co-scheduling issue"/>
            <threshold color="yellow" operator="gt"  value="1"  label="Elevated CoStop"/>
            <threshold color="green"  operator="lte" value="1"  label="OK"/>
          </thresholds>
          <showObjectType>true</showObjectType>
          <showParentCluster>true</showParentCluster>
        </config>
      </widget>

      <widget id="scoreboard-costop-summary" type="scoreboard" row="12" col="6" rowSpan="4" colSpan="6">
        <name>CoStop summary — VMs with SMP contention</name>
        <description>Count of virtual machines experiencing CPU CoStop above threshold. These VMs have more vCPUs than the overprovisioned hosts can schedule simultaneously.</description>
        <config>
          <objectScope>
            <groupId>GROUP_ID_PLACEHOLDER</groupId>
            <objectType>VirtualMachine</objectType>
          </objectScope>
          <metric>cpu|costopPct</metric>
          <thresholds>
            <threshold color="red"    operator="gt"  value="3" label="Severe"/>
            <threshold color="yellow" operator="gt"  value="1" label="Warning"/>
            <threshold color="green"  operator="lte" value="1" label="OK"/>
          </thresholds>
          <aggregation>count_critical</aggregation>
          <displayFormat>COUNT_CRITICAL_OF_TOTAL</displayFormat>
        </config>
      </widget>

    </widgetList>

    <!-- ============================================================ -->
    <!-- ALERT DEFINITIONS — import these to trigger on breach        -->
    <!-- ============================================================ -->

    <alertDefinitions>

      <alertDefinition id="alert-n1-capacity-breach">
        <name>N-1 capacity breach — VI cluster cannot survive host failure</name>
        <description>Fires when a VI workload domain cluster has insufficient CPU capacity to absorb workload if a single ESXi host fails. Immediate action required: either reduce VM count/sizing or add hosts before planned maintenance.</description>
        <severity>CRITICAL</severity>
        <impact>RISK</impact>
        <objectType>ClusterComputeResource</objectType>
        <groupScope>GROUP_ID_PLACEHOLDER</groupScope>
        <symptoms>
          <symptom id="sym-n1-breach" type="metric">
            <metric>summary|capacityRemainingUsingDemandMetric</metric>
            <operator>lt</operator>
            <threshold>0</threshold>
            <waitCycles>1</waitCycles>
            <cancelCycles>3</cancelCycles>
            <severity>CRITICAL</severity>
            <message>Cluster {object_name} has {metric_value}% N-1 headroom — host failure will overload remaining hosts</message>
          </symptom>
        </symptoms>
        <recommendations>
          <recommendation>Run Capacity What-If analysis to quantify shortfall</recommendation>
          <recommendation>Review vCPU:pCPU ratio — reduce overcommit before next maintenance window</recommendation>
          <recommendation>Consider DRS rules to redistribute VMs across clusters</recommendation>
          <recommendation>Evaluate adding capacity (hosts) to restore N-1 headroom above 15%</recommendation>
        </recommendations>
      </alertDefinition>

      <alertDefinition id="alert-vcpu-pcpu-ratio">
        <name>vCPU:pCPU ratio exceeds 3:1 policy — host overprovisioned</name>
        <description>Fires when an ESXi host in a VI workload domain cluster exceeds the 3:1 vCPU to physical core ratio policy. Under N-1 conditions the ratio on surviving hosts increases by approximately 1/N, making contention significantly worse.</description>
        <severity>WARNING</severity>
        <impact>EFFICIENCY</impact>
        <objectType>HostSystem</objectType>
        <groupScope>GROUP_ID_PLACEHOLDER</groupScope>
        <symptoms>
          <symptom id="sym-ratio-warn" type="metric">
            <metric>cpu|vcpusPerCore</metric>
            <operator>gt</operator>
            <threshold>3.0</threshold>
            <waitCycles>2</waitCycles>
            <cancelCycles>3</cancelCycles>
            <severity>WARNING</severity>
            <message>Host {object_name} vCPU:pCPU ratio is {metric_value}:1 — exceeds 3:1 policy limit</message>
          </symptom>
          <symptom id="sym-ratio-crit" type="metric">
            <metric>cpu|vcpusPerCore</metric>
            <operator>gt</operator>
            <threshold>4.0</threshold>
            <waitCycles>1</waitCycles>
            <cancelCycles>3</cancelCycles>
            <severity>CRITICAL</severity>
            <message>Host {object_name} vCPU:pCPU ratio is {metric_value}:1 — significantly overprovisioned, contention likely</message>
          </symptom>
        </symptoms>
        <recommendations>
          <recommendation>Identify top CPU-consuming VMs on this host via the CPU Ready top-N widget</recommendation>
          <recommendation>Use DRS to migrate high-vCPU VMs to less overcommitted hosts</recommendation>
          <recommendation>Review VM right-sizing — remove unused vCPUs from VMs with low CPU utilisation</recommendation>
        </recommendations>
      </alertDefinition>

      <alertDefinition id="alert-cpu-ready-contention">
        <name>CPU Ready contention — VMs starved of physical CPU time</name>
        <description>Fires when cluster-level average CPU Ready exceeds 5%. This is a direct symptom of overprovisioning — VMs are scheduled but cannot run because all physical cores are busy. Correlates with vCPU:pCPU ratio breaches.</description>
        <severity>WARNING</severity>
        <impact>PERFORMANCE</impact>
        <objectType>ClusterComputeResource</objectType>
        <groupScope>GROUP_ID_PLACEHOLDER</groupScope>
        <symptoms>
          <symptom id="sym-ready-warn" type="metric">
            <metric>cpu|readyPct</metric>
            <operator>gt</operator>
            <threshold>5</threshold>
            <waitCycles>3</waitCycles>
            <cancelCycles>5</cancelCycles>
            <severity>WARNING</severity>
            <message>Cluster {object_name} CPU Ready is {metric_value}% — VMs experiencing scheduling delays</message>
          </symptom>
          <symptom id="sym-ready-crit" type="metric">
            <metric>cpu|readyPct</metric>
            <operator>gt</operator>
            <threshold>10</threshold>
            <waitCycles>2</waitCycles>
            <cancelCycles>3</cancelCycles>
            <severity>CRITICAL</severity>
            <message>Cluster {object_name} CPU Ready is {metric_value}% — severe contention, application performance impact expected</message>
          </symptom>
        </symptoms>
        <recommendations>
          <recommendation>Use Top-N CPU Ready widget to identify worst-affected VMs immediately</recommendation>
          <recommendation>Check vCPU:pCPU ratio on hosts in this cluster — reduce overcommit ratio</recommendation>
          <recommendation>Review DRS aggressiveness setting — increase to level 4 or 5 to rebalance load faster</recommendation>
          <recommendation>Consider CPU reservations for Tier-1 workloads (SAP, Oracle, SQL) to guarantee scheduling</recommendation>
        </recommendations>
      </alertDefinition>

      <alertDefinition id="alert-cluster-demand-high">
        <name>VI cluster CPU demand exceeds 80% — N-1 failure risk elevated</name>
        <description>Fires when a VI workload domain cluster is running above 80% CPU demand during normal operations. At this level a single host failure under N-1 will push the cluster to or beyond 100% capacity, causing widespread VM performance degradation.</description>
        <severity>WARNING</severity>
        <impact>RISK</impact>
        <objectType>ClusterComputeResource</objectType>
        <groupScope>GROUP_ID_PLACEHOLDER</groupScope>
        <symptoms>
          <symptom id="sym-demand-warn" type="metric">
            <metric>cpu|demandmhz</metric>
            <operator>gt_percent_capacity</operator>
            <threshold>80</threshold>
            <waitCycles>3</waitCycles>
            <cancelCycles>5</cancelCycles>
            <severity>WARNING</severity>
            <message>Cluster {object_name} CPU demand is {metric_value}% of capacity — N-1 failure will exceed 100%</message>
          </symptom>
          <symptom id="sym-demand-crit" type="metric">
            <metric>cpu|demandmhz</metric>
            <operator>gt_percent_capacity</operator>
            <threshold>90</threshold>
            <waitCycles>1</waitCycles>
            <cancelCycles>3</cancelCycles>
            <severity>CRITICAL</severity>
            <message>Cluster {object_name} CPU demand is {metric_value}% — critically overloaded, host failure will cause immediate outage risk</message>
          </symptom>
        </symptoms>
        <recommendations>
          <recommendation>Run N-1 What-If scenario in Capacity planning immediately</recommendation>
          <recommendation>Review and reduce vCPU allocations on non-production VMs in this cluster</recommendation>
          <recommendation>Evaluate cross-cluster vMotion of non-critical workloads to reduce load</recommendation>
          <recommendation>Escalate to capacity planning — additional hosts required before next maintenance window</recommendation>
        </recommendations>
      </alertDefinition>

    </alertDefinitions>

    <!-- ============================================================ -->
    <!-- DASHBOARD LAYOUT METADATA                                    -->
    <!-- ============================================================ -->

    <layout>
      <columns>12</columns>
      <defaultTimeRange>LAST_24_HOURS</defaultTimeRange>
      <refreshInterval>300</refreshInterval>
      <tags>
        <tag>cpu-contention</tag>
        <tag>n1-analysis</tag>
        <tag>vi-workload</tag>
        <tag>vcf</tag>
        <tag>capacity</tag>
      </tags>
    </layout>

    <accessControl>
      <shareWithAllUsers>true</shareWithAllUsers>
      <editableByOwnerOnly>false</editableByOwnerOnly>
    </accessControl>

  </dashboard>
</dashboardList>
