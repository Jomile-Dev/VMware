# VM CPU and Memory Hot Add Configuration Script - Enhanced Version
# Specify the CSV file path here
$CSVPath = "C:\path\to\your\vmlist.csv"

# Specify the report file path here
$ReportPath = "C:\Reports\VM_Configuration_Report_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"

# Default shutdown timeout in minutes (can be overridden per VM via optional ShutdownTimeoutMinutes CSV column)
$DefaultShutdownTimeoutMinutes = 8

Write-Host "Starting VM Configuration Update Script (Enhanced Parallel Mode)..." -ForegroundColor Green
Write-Host "Script started at: $(Get-Date)" -ForegroundColor Gray

# Set PowerCLI configuration to ignore certificate warnings
Write-Host "Configuring PowerCLI settings..." -ForegroundColor Yellow
try {
    Set-PowerCLIConfiguration -InvalidCertificateAction Ignore -Confirm:$false -Scope Session
    Write-Host "PowerCLI configuration set successfully" -ForegroundColor Green
} catch {
    Write-Warning "Failed to set PowerCLI configuration: $($_.Exception.Message)"
}

# vCenter connection parameters - REPLACE WITH YOUR ACTUAL SERVER NAMES
$vCenterServers = @(
    "vcenter1.domain.com",
    "vcenter2.domain.com", 
    "vcenter3.domain.com"
)

# DEBUG: Show what we're working with
Write-Host "DEBUG: Original vCenter servers:" -ForegroundColor Yellow
$vCenterServers | ForEach-Object { Write-Host "  - '$_'" -ForegroundColor Gray }

Write-Host "Starting VM Configuration Update Process" -ForegroundColor Cyan
Write-Host "CSV File: $CSVPath" -ForegroundColor Yellow
Write-Host "Report will be saved to: $ReportPath" -ForegroundColor Yellow

# Validate CSV file exists
Write-Host "Checking CSV file..." -ForegroundColor Yellow
if (!(Test-Path $CSVPath)) {
    Write-Error "CSV file not found at path: $CSVPath"
    Read-Host "Press Enter to exit"
    exit 1
}
Write-Host "CSV file found successfully" -ForegroundColor Green

# Read and validate CSV file
Write-Host "Reading CSV file..." -ForegroundColor Yellow
try {
    $VMList = Import-Csv -Path $CSVPath
    Write-Host "Successfully imported CSV with $($VMList.Count) VMs" -ForegroundColor Green
    
    if ($VMList.Count -eq 0) {
        Write-Error "CSV file is empty or contains no data rows"
        Read-Host "Press Enter to exit"
        exit 1
    }
} catch {
    Write-Error "Failed to import CSV file: $($_.Exception.Message)"
    Read-Host "Press Enter to exit"
    exit 1
}

# Validate CSV headers
Write-Host "Validating CSV headers..." -ForegroundColor Yellow
$requiredHeaders = @("VMName", "PowerState", "CPUHotAddEnabled", "MemoryHotAddEnabled", "CPUCountBefore", "CPUCountAfter", "MemoryGBBefore", "MemoryGBAfter")
$csvHeaders = $VMList[0].PSObject.Properties.Name
$missingHeaders = $requiredHeaders | Where-Object { $_ -notin $csvHeaders }

if ($missingHeaders) {
    Write-Error "Missing required CSV headers: $($missingHeaders -join ', ')"
    Write-Host "Required headers: $($requiredHeaders -join ', ')" -ForegroundColor Yellow
    Read-Host "Press Enter to exit"
    exit 1
}
Write-Host "CSV headers validated successfully" -ForegroundColor Green

# ============================================================================
# ENHANCED CSV DATA VALIDATION
# Validates numeric fields, checks for duplicate VM names, and validates the
# optional ShutdownTimeoutMinutes column if present.
# ============================================================================
Write-Host "Validating CSV row data..." -ForegroundColor Yellow

$csvErrors = @()
$rowIndex = 0

# Check for duplicate VM names (two jobs fighting over the same VM will cause failures)
$duplicateVMs = $VMList | Group-Object -Property VMName | Where-Object { $_.Count -gt 1 }
if ($duplicateVMs) {
    foreach ($dup in $duplicateVMs) {
        $csvErrors += "Duplicate VMName '$($dup.Name)' appears $($dup.Count) times. Each VM must appear only once to prevent parallel job conflicts."
    }
}

# Validate each row
foreach ($vmEntry in $VMList) {
    $rowIndex++
    $rowLabel = "Row $rowIndex ($($vmEntry.VMName))"

    # VMName must not be blank
    if ([string]::IsNullOrWhiteSpace($vmEntry.VMName)) {
        $csvErrors += "$rowLabel - VMName is empty or whitespace"
        continue
    }

    # Numeric field validation - TryParse catches non-numeric strings, range check catches nonsense values
    $numericFields = @(
        @{ Name = "CPUCountBefore";    Value = $vmEntry.CPUCountBefore;    Min = 1;  Max = 768   },
        @{ Name = "CPUCountAfter";     Value = $vmEntry.CPUCountAfter;     Min = 1;  Max = 768   },
        @{ Name = "MemoryGBBefore";    Value = $vmEntry.MemoryGBBefore;    Min = 1;  Max = 24576  },
        @{ Name = "MemoryGBAfter";     Value = $vmEntry.MemoryGBAfter;     Min = 1;  Max = 24576  }
    )

    foreach ($field in $numericFields) {
        $parsed = 0
        if (-not [int]::TryParse($field.Value, [ref]$parsed)) {
            $csvErrors += "$rowLabel - $($field.Name) value '$($field.Value)' is not a valid integer"
        } elseif ($parsed -lt $field.Min -or $parsed -gt $field.Max) {
            $csvErrors += "$rowLabel - $($field.Name) value $parsed is outside the valid range ($($field.Min)-$($field.Max))"
        }
    }

    # Optional ShutdownTimeoutMinutes column - validate if present and non-empty
    if ($vmEntry.PSObject.Properties.Name -contains "ShutdownTimeoutMinutes") {
        if (-not [string]::IsNullOrWhiteSpace($vmEntry.ShutdownTimeoutMinutes)) {
            $parsedTimeout = 0
            if (-not [int]::TryParse($vmEntry.ShutdownTimeoutMinutes, [ref]$parsedTimeout)) {
                $csvErrors += "$rowLabel - ShutdownTimeoutMinutes value '$($vmEntry.ShutdownTimeoutMinutes)' is not a valid integer"
            } elseif ($parsedTimeout -lt 1 -or $parsedTimeout -gt 30) {
                $csvErrors += "$rowLabel - ShutdownTimeoutMinutes value $parsedTimeout is outside the valid range (1-30)"
            }
        }
    }
}

if ($csvErrors.Count -gt 0) {
    Write-Host "`nCSV VALIDATION FAILED - $($csvErrors.Count) error(s) found:" -ForegroundColor Red
    foreach ($err in $csvErrors) {
        Write-Host "  X $err" -ForegroundColor Red
    }
    Write-Host "`nPlease fix the CSV and re-run the script." -ForegroundColor Yellow
    Read-Host "Press Enter to exit"
    exit 1
}

Write-Host "CSV row data validated successfully ($($VMList.Count) VMs, no duplicates, all numeric values valid)" -ForegroundColor Green

# Connect to vCenter servers
Write-Host "Preparing to connect to vCenter servers..." -ForegroundColor Yellow
$Credential = Get-Credential -Message "Enter vCenter credentials"

if (!$Credential) {
    Write-Error "No credentials provided. Exiting."
    Read-Host "Press Enter to exit"
    exit 1
}

# Simplified validation - no filtering
Write-Host "Validating vCenter server list..." -ForegroundColor Yellow
$validVCenterServers = @()

foreach ($server in $vCenterServers) {
    if (-not [string]::IsNullOrWhiteSpace($server)) {
        $cleanServer = $server.Trim()
        if ($cleanServer -ne "") {
            $validVCenterServers += $cleanServer
            Write-Host "  + Added: '$cleanServer'" -ForegroundColor Green
        }
    }
}

if ($validVCenterServers.Count -eq 0) {
    Write-Error "No valid vCenter servers found in the list. Please update the vCenterServers array with your actual server names."
    Write-Host "Current servers in array:" -ForegroundColor Red
    $vCenterServers | ForEach-Object { Write-Host "  - '$_'" -ForegroundColor Red }
    Write-Host "Please replace placeholder server names with your actual vCenter server FQDNs or IP addresses" -ForegroundColor Yellow
    Read-Host "Press Enter to exit"
    exit 1
}

$connectedServers = @()

Write-Host "Attempting to connect to vCenter servers..." -ForegroundColor Yellow
foreach ($vc in $validVCenterServers) {
    Write-Host "Connecting to $vc..." -ForegroundColor Gray
    try {
        Connect-VIServer -Server $vc -Credential $Credential -ErrorAction Stop
        Write-Host "Connected to $vc" -ForegroundColor Green
        $connectedServers += $vc
    } catch {
        Write-Warning "Failed to connect to $vc : $($_.Exception.Message)"
    }
}

if ($connectedServers.Count -eq 0) {
    Write-Error "Failed to connect to any vCenter servers"
    Read-Host "Press Enter to exit"
    exit 1
}

Write-Host "Successfully connected to $($connectedServers.Count) vCenter server(s)" -ForegroundColor Green

# Prepare server list for jobs AFTER we have connections
Write-Host "Preparing server list for jobs..." -ForegroundColor Yellow
$finalServerArray = $connectedServers
Write-Host "Will pass $($finalServerArray.Count) servers to jobs: $($finalServerArray -join ', ')" -ForegroundColor Yellow

# Display confirmation with per-VM shutdown timeout
Write-Host ("`n" + "=" * 80) -ForegroundColor Yellow
Write-Host "VM CONFIGURATION CHANGE CONFIRMATION" -ForegroundColor Yellow
Write-Host ("=" * 80) -ForegroundColor Yellow

foreach ($vmEntry in $VMList) {
    $timeoutDisplay = $DefaultShutdownTimeoutMinutes
    if ($vmEntry.PSObject.Properties.Name -contains "ShutdownTimeoutMinutes" -and -not [string]::IsNullOrWhiteSpace($vmEntry.ShutdownTimeoutMinutes)) {
        $timeoutDisplay = $vmEntry.ShutdownTimeoutMinutes
    }
    Write-Host "VM: $($vmEntry.VMName) | CPU: $($vmEntry.CPUCountBefore) -> $($vmEntry.CPUCountAfter) | Memory: $($vmEntry.MemoryGBBefore)GB -> $($vmEntry.MemoryGBAfter)GB | Shutdown Timeout: ${timeoutDisplay}m | Hot Add: Enabled" -ForegroundColor Cyan
}

Write-Host "`nTotal VMs: $($VMList.Count) | Processing: PARALLEL" -ForegroundColor Yellow
Write-Host "WARNING: VMs will be shut down and reconfigured!" -ForegroundColor Red
Write-Host "`nPress ENTER to continue or CTRL+C to cancel..." -ForegroundColor White
Read-Host

# Create robust script block for parallel processing
$vmProcessingScript = {
    param($vmData, $vCenterList, $username, $password, $jobId, $defaultShutdownTimeout)
    
    # Create a unique log identifier
    $logPrefix = "[$($vmData.VMName)][Job$jobId]"
    $progressLog = @()
    
    function Add-ProgressLog {
        param($Message, $LogLevel = "INFO")
        $timestamp = Get-Date -Format "HH:mm:ss.fff"
        $logEntry = "$timestamp $logPrefix [$LogLevel] $Message"
        $script:progressLog += $logEntry
        
        # Create structured output for console processing
        $output = [PSCustomObject]@{
            Type = "ProgressUpdate"
            VMName = $vmData.VMName
            JobId = $jobId
            Timestamp = $timestamp
            LogLevel = $LogLevel
            Message = $Message
            FullLogEntry = $logEntry
        }
        Write-Output $output
    }
    
    try {
        Add-ProgressLog "STARTING - Initializing job environment" "START"
        
        # Recreate credential securely
        $securePassword = ConvertTo-SecureString -String $password -AsPlainText -Force
        $jobCredential = New-Object System.Management.Automation.PSCredential($username, $securePassword)
        
        # Import PowerCLI with complete banner suppression
        $moduleLoaded = $false
        $retryCount = 0
        
        $originalVerbosePreference = $VerbosePreference
        $originalInformationPreference = $InformationPreference
        $originalWarningPreference = $WarningPreference
        
        $VerbosePreference = "SilentlyContinue"
        $InformationPreference = "SilentlyContinue" 
        $WarningPreference = "SilentlyContinue"
        
        while (-not $moduleLoaded -and $retryCount -lt 3) {
            try {
                $null = Import-Module VMware.PowerCLI -Force -Global -ErrorAction Stop -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                
                $null = Set-PowerCLIConfiguration -InvalidCertificateAction Ignore -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                $null = Set-PowerCLIConfiguration -DisplayDeprecationWarnings $false -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                $null = Set-PowerCLIConfiguration -ParticipateInCEIP $false -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                $null = Set-PowerCLIConfiguration -DefaultVIServerMode Single -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                $null = Set-PowerCLIConfiguration -WebOperationTimeoutSeconds 300 -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                
                $moduleLoaded = $true
                Add-ProgressLog "INITIALIZED - PowerCLI loaded successfully (banner completely suppressed)" "SUCCESS"
            } catch {
                if (Get-Module -ListAvailable -Name VMware.VimAutomation.Core) {
                    try {
                        $null = Import-Module VMware.VimAutomation.Core -Force -Global -ErrorAction Stop -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        $null = Import-Module VMware.VimAutomation.Common -Force -Global -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        
                        $null = Set-PowerCLIConfiguration -InvalidCertificateAction Ignore -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        $null = Set-PowerCLIConfiguration -DisplayDeprecationWarnings $false -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        $null = Set-PowerCLIConfiguration -ParticipateInCEIP $false -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        $null = Set-PowerCLIConfiguration -DefaultVIServerMode Single -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        
                        $moduleLoaded = $true
                        Add-ProgressLog "INITIALIZED - PowerCLI legacy modules loaded (banner completely suppressed)" "SUCCESS"
                    } catch {
                        $retryCount++
                        Add-ProgressLog "MODULE_RETRY - Legacy import attempt $retryCount failed: $($_.Exception.Message)" "WARN"
                        Start-Sleep -Seconds 2
                    }
                } else {
                    throw "PowerCLI modules not found"
                }
            }
        }
        
        $VerbosePreference = $originalVerbosePreference
        $InformationPreference = $originalInformationPreference
        $WarningPreference = $originalWarningPreference
        
        if (-not $moduleLoaded) {
            throw "Failed to load PowerCLI after 3 attempts"
        }
        
        # Initialize result object - now includes PowerOnVerified field
        $result = [PSCustomObject]@{
            Type = "FinalResult"
            VMName = $vmData.VMName
            JobId = $jobId
            Status = "Success"
            PowerOnVerified = $false
            OriginalPowerState = $vmData.PowerState
            OriginalCPUCount = $vmData.CPUCountBefore
            TargetCPUCount = $vmData.CPUCountAfter
            OriginalMemoryGB = $vmData.MemoryGBBefore
            TargetMemoryGB = $vmData.MemoryGBAfter
            NewCPUCount = ""
            NewCoresPerSocket = ""
            NewMemoryGB = ""
            NewCPUHotAddEnabled = ""
            NewMemoryHotAddEnabled = ""
            FinalPowerState = ""
            ErrorMessage = ""
            StartTime = Get-Date
            EndTime = $null
            ProcessingTimeMinutes = 0
            ProgressLog = $progressLog
        }
        
        # Connect to vCenter servers with enhanced validation and debugging
        Add-ProgressLog "CONNECTING - Attempting vCenter connections" "INFO"
        $jobConnections = @()
        $vmServer = $null
        
        if (-not $vCenterList -or $vCenterList.Count -eq 0) {
            throw "vCenter server list is empty or null in job parameter"
        }
        
        Add-ProgressLog "DEBUG - Received vCenter list count: $($vCenterList.Count)" "INFO"
        Add-ProgressLog "DEBUG - vCenter list type: $($vCenterList.GetType().Name)" "INFO"
        
        # Handle both array and single string inputs
        $serverListToProcess = @()
        if ($vCenterList -is [array]) {
            $serverListToProcess = $vCenterList
        } elseif ($vCenterList -is [string]) {
            $serverListToProcess = @($vCenterList)
        } else {
            $serverListToProcess = @($vCenterList)
        }
        
        Add-ProgressLog "DEBUG - Processing $($serverListToProcess.Count) servers" "INFO"
        for ($i = 0; $i -lt $serverListToProcess.Count; $i++) {
            Add-ProgressLog "DEBUG - Server[$i]: '$($serverListToProcess[$i])'" "INFO"
        }
        
        $validServers = @()
        foreach ($server in $serverListToProcess) {
            if (-not [string]::IsNullOrWhiteSpace($server)) {
                $cleanServer = $server.ToString().Trim()
                if ($cleanServer -ne "" -and $cleanServer -ne "test.test.test" -and $cleanServer -notlike "*domain.com") {
                    $validServers += $cleanServer
                    Add-ProgressLog "VCENTER_VALID - Added server: '$cleanServer'" "INFO"
                } else {
                    Add-ProgressLog "VCENTER_SKIP - Skipped placeholder server: '$cleanServer'" "WARN"
                }
            } else {
                Add-ProgressLog "VCENTER_SKIP - Skipped empty/null server" "WARN"
            }
        }
        
        if ($validServers.Count -eq 0) {
            throw "No valid vCenter servers found after cleaning. Original list: $($serverListToProcess -join ', ')"
        }
        
        Add-ProgressLog "VCENTER_LIST - Will attempt to connect to $($validServers.Count) servers: $($validServers -join ', ')" "INFO"
        
        foreach ($vcServer in $validServers) {
            try {
                Add-ProgressLog "CONNECT_ATTEMPT - Connecting to '$vcServer'" "INFO"
                
                if ([string]::IsNullOrWhiteSpace($vcServer) -or $vcServer -eq "test.test.test") {
                    Add-ProgressLog "CONNECT_SKIP - Invalid server name: '$vcServer'" "WARN"
                    continue
                }
                
                $connection = Connect-VIServer -Server $vcServer -Credential $jobCredential -Force -ErrorAction Stop -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false
                
                if ($connection -and $connection.IsConnected) {
                    $jobConnections += $vcServer
                    Add-ProgressLog "CONNECTED - Successfully connected to '$vcServer'" "SUCCESS"
                    
                    $testVM = Get-VM -Name $vmData.VMName -Server $vcServer -ErrorAction SilentlyContinue
                    if ($testVM) {
                        Add-ProgressLog "VM_LOCATED - Found VM on $vcServer" "SUCCESS"
                        $vmServer = $vcServer
                        break
                    }
                } else {
                    Add-ProgressLog "CONNECT_FAILED - Connection object is null or not connected for $vcServer" "ERROR"
                }
            } catch {
                Add-ProgressLog "CONNECT_FAILED - $vcServer : $($_.Exception.Message)" "ERROR"
            }
        }
        
        if ($jobConnections.Count -eq 0) {
            throw "No vCenter connections established. Check server names and credentials."
        }
        
        # Locate the VM
        Add-ProgressLog "SEARCHING - Looking for VM across $($jobConnections.Count) connected servers" "INFO"
        $targetVM = $null
        
        if (-not $vmServer) {
            foreach ($server in $jobConnections) {
                try {
                    $targetVM = Get-VM -Name $vmData.VMName -Server $server -ErrorAction Stop
                    if ($targetVM -and $targetVM.Name -eq $vmData.VMName) {
                        $vmServer = $server
                        Add-ProgressLog "VM_FOUND - Located '$($targetVM.Name)' on $server (Current Power: $($targetVM.PowerState), CPUs: $($targetVM.NumCpu), Memory: $($targetVM.MemoryGB)GB)" "SUCCESS"
                        break
                    } else {
                        $targetVM = $null
                    }
                } catch {
                    Add-ProgressLog "VM_SEARCH - Not found on $server, continuing search..." "INFO"
                    $targetVM = $null
                }
            }
        } else {
            $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
        }
        
        if (-not $targetVM -or -not $vmServer) {
            throw "VM '$($vmData.VMName)' not found on any connected vCenter server"
        }
        
        if (-not $targetVM.Name) {
            throw "VM object is invalid - Name property is missing"
        }
        
        # Determine per-VM shutdown timeout (CSV override or script default)
        $shutdownTimeoutMinutes = $defaultShutdownTimeout
        if ($vmData.PSObject.Properties.Name -contains "ShutdownTimeoutMinutes" -and -not [string]::IsNullOrWhiteSpace($vmData.ShutdownTimeoutMinutes)) {
            $shutdownTimeoutMinutes = [int]$vmData.ShutdownTimeoutMinutes
        }
        Add-ProgressLog "SHUTDOWN_TIMEOUT - Using ${shutdownTimeoutMinutes} minute shutdown timeout for this VM" "INFO"
        
        # PHASE 1: Shutdown if needed with null checks
        if ($targetVM -and $targetVM.PowerState -eq "PoweredOn") {
            Add-ProgressLog "SHUTDOWN_START - Initiating graceful shutdown (VMware Tools required, timeout: ${shutdownTimeoutMinutes}m)" "INFO"
            
            try {
                Shutdown-VMGuest -VM $targetVM -Confirm:$false -ErrorAction Stop
                Add-ProgressLog "SHUTDOWN_INITIATED - Graceful shutdown command sent" "SUCCESS"
            } catch {
                Add-ProgressLog "SHUTDOWN_FALLBACK - Graceful shutdown failed, will force power off: $($_.Exception.Message)" "WARN"
                Stop-VM -VM $targetVM -Confirm:$false -ErrorAction Stop
            }
            
            $shutdownTimeout = (Get-Date).AddMinutes($shutdownTimeoutMinutes)
            $shutdownStart = Get-Date
            
            while ($targetVM -and $targetVM.PowerState -ne "PoweredOff" -and (Get-Date) -lt $shutdownTimeout) {
                Start-Sleep -Seconds 5
                
                try {
                    $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                    $elapsed = [math]::Round(((Get-Date) - $shutdownStart).TotalSeconds)
                    
                    if ($elapsed % 30 -eq 0) {
                        Add-ProgressLog "SHUTDOWN_WAIT - Shutdown in progress (${elapsed}s elapsed, State: $($targetVM.PowerState))" "INFO"
                    }
                } catch {
                    Add-ProgressLog "SHUTDOWN_ERROR - Failed to refresh VM status during shutdown" "WARN"
                    break
                }
            }
            
            # Force shutdown if still running
            if ($targetVM -and $targetVM.PowerState -ne "PoweredOff") {
                Add-ProgressLog "SHUTDOWN_FORCE - Timeout reached (${shutdownTimeoutMinutes}m), forcing power off" "WARN"
                try {
                    Stop-VM -VM $targetVM -Confirm:$false -ErrorAction Stop
                    Start-Sleep -Seconds 5
                    $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                } catch {
                    Add-ProgressLog "SHUTDOWN_FORCE_ERROR - Failed to force power off: $($_.Exception.Message)" "ERROR"
                }
            }
            
            if ($targetVM) {
                $shutdownDuration = [math]::Round(((Get-Date) - $shutdownStart).TotalSeconds)
                Add-ProgressLog "SHUTDOWN_COMPLETE - VM powered off (took ${shutdownDuration}s, Final State: $($targetVM.PowerState))" "SUCCESS"
            }
        } else {
            Add-ProgressLog "SHUTDOWN_SKIP - VM already powered off or invalid, proceeding to reconfiguration" "INFO"
        }
        
        # PHASE 2: Reconfigure VM with automatic fallback
        Add-ProgressLog "CONFIG_START - Beginning VM reconfiguration" "INFO"
        
        Start-Sleep -Seconds 8
        
        $targetCPUs = [int]$vmData.CPUCountAfter
        $targetMemoryGB = [int]$vmData.MemoryGBAfter
        $configurationSuccessful = $false
        $vmView = $null
        
        # TRY APPROACH 1: vSphere API (preferred method)
        try {
            Add-ProgressLog "CONFIG_API_ATTEMPT - Attempting vSphere API configuration..." "INFO"
            
            $freshVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
            $vmView = Get-View -VIObject $freshVM -ErrorAction Stop
            
            Add-ProgressLog "CONFIG_API_SUCCESS - API objects obtained successfully" "SUCCESS"
            
            $configSpec = New-Object VMware.Vim.VirtualMachineConfigSpec
            $configSpec.NumCPUs = $targetCPUs
            $configSpec.MemoryMB = $targetMemoryGB * 1024
            $configSpec.CpuHotAddEnabled = $true
            $configSpec.MemoryHotAddEnabled = $true
            
            $task = $vmView.ReconfigVM($configSpec)
            Add-ProgressLog "CONFIG_API_TASK - API reconfiguration task submitted (CPU: $targetCPUs, Memory: ${targetMemoryGB}GB)" "INFO"
            
            $taskInfo = Get-View $task -ErrorAction Stop
            $timeout = (Get-Date).AddMinutes(5)
            
            while ($taskInfo.Info.State -eq "running" -and (Get-Date) -lt $timeout) {
                Start-Sleep -Seconds 5
                $taskInfo.UpdateViewData()
            }
            
            if ($taskInfo.Info.State -eq "success") {
                Add-ProgressLog "CONFIG_API_COMPLETE - vSphere API reconfiguration successful" "SUCCESS"
                $configurationSuccessful = $true
            } else {
                Add-ProgressLog "CONFIG_API_INCOMPLETE - API task state: $($taskInfo.Info.State), will try PowerCLI approach" "WARN"
            }
            
        } catch {
            Add-ProgressLog "CONFIG_API_FALLBACK - vSphere API approach failed: $($_.Exception.Message)" "INFO"
            Add-ProgressLog "CONFIG_API_FALLBACK - This is normal, will use PowerCLI cmdlets instead" "INFO"
        }
        
        # APPROACH 2: PowerCLI Cmdlets (always works, used as fallback)
        if (-not $configurationSuccessful) {
            try {
                Add-ProgressLog "CONFIG_CMDLET_START - Using PowerCLI cmdlets for configuration..." "INFO"
                
                $cmdletVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                
                Add-ProgressLog "CONFIG_CMDLET_RESOURCES - Setting CPUs to $targetCPUs and Memory to ${targetMemoryGB}GB..." "INFO"
                Set-VM -VM $cmdletVM -NumCpu $targetCPUs -MemoryGB $targetMemoryGB -Confirm:$false -ErrorAction Stop
                
                Add-ProgressLog "CONFIG_CMDLET_SUCCESS - CPU and Memory configuration applied successfully via PowerCLI" "SUCCESS"
                $configurationSuccessful = $true
                
                try {
                    Add-ProgressLog "CONFIG_HOTADD_ATTEMPT - Attempting to enable hot add features..." "INFO"
                    
                    Start-Sleep -Seconds 3
                    $hotAddVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                    $hotAddView = Get-View -VIObject $hotAddVM -ErrorAction Stop
                    
                    $hotAddSpec = New-Object VMware.Vim.VirtualMachineConfigSpec
                    $hotAddSpec.CpuHotAddEnabled = $true
                    $hotAddSpec.MemoryHotAddEnabled = $true
                    
                    $hotAddView.ReconfigVM($hotAddSpec) | Out-Null
                    Add-ProgressLog "CONFIG_HOTADD_SUCCESS - Hot Add features enabled successfully" "SUCCESS"
                    
                } catch {
                    Add-ProgressLog "CONFIG_HOTADD_SKIP - Could not enable hot add: $($_.Exception.Message)" "INFO"
                    Add-ProgressLog "CONFIG_HOTADD_MANUAL - Hot Add can be enabled manually if needed" "INFO"
                }
                
            } catch {
                Add-ProgressLog "CONFIG_CMDLET_ERROR - PowerCLI cmdlet approach failed: $($_.Exception.Message)" "ERROR"
                throw "Both API and PowerCLI approaches failed: $($_.Exception.Message)"
            }
        }
        
        if ($configurationSuccessful) {
            Add-ProgressLog "CONFIG_COMPLETE - VM reconfiguration completed successfully" "SUCCESS"
        } else {
            throw "Configuration was not completed successfully"
        }
        
        # PHASE 3: Power on the VM after configuration
        Add-ProgressLog "POWERON_START - Initiating startup sequence" "INFO"
        
        Start-Sleep -Seconds 3
        
        try {
            $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
            
            if (-not $targetVM) {
                throw "Cannot retrieve VM object for power operations"
            }
            
            Add-ProgressLog "POWERON_VM_STATE - Current VM state: $($targetVM.PowerState)" "INFO"
            
            if ($targetVM.PowerState -eq "PoweredOff") {
                Add-ProgressLog "POWERON_EXECUTE - VM is PoweredOff, starting power on sequence" "INFO"
                
                Start-VM -VM $targetVM -Confirm:$false -ErrorAction Stop
                Add-ProgressLog "POWERON_INITIATED - Power on command sent successfully" "SUCCESS"
                
                $powerOnTimeout = (Get-Date).AddMinutes(2)
                $powerOnStart = Get-Date
                
                while ($targetVM.PowerState -ne "PoweredOn" -and (Get-Date) -lt $powerOnTimeout) {
                    Start-Sleep -Seconds 5
                    try {
                        $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                        if ($targetVM) {
                            $elapsed = [math]::Round(((Get-Date) - $powerOnStart).TotalSeconds)
                            
                            if ($elapsed % 30 -eq 0) {
                                Add-ProgressLog "POWERON_PROGRESS - Power on in progress (${elapsed}s elapsed, State: $($targetVM.PowerState))" "INFO"
                            }
                            
                            if ($targetVM.PowerState -eq "PoweredOn") {
                                Add-ProgressLog "POWERON_SUCCESS - VM powered on (${elapsed}s)" "SUCCESS"
                                $result.PowerOnVerified = $true
                                break
                            }
                        }
                    } catch {
                        Add-ProgressLog "POWERON_STATUS_ERROR - Error checking power status: $($_.Exception.Message)" "WARN"
                        break
                    }
                }
                
                # Final verification
                try {
                    $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                    $powerOnDuration = [math]::Round(((Get-Date) - $powerOnStart).TotalSeconds)
                    
                    if ($targetVM -and $targetVM.PowerState -eq "PoweredOn") {
                        Add-ProgressLog "POWERON_VERIFIED - VM successfully powered on (${powerOnDuration}s total)" "SUCCESS"
                        $result.PowerOnVerified = $true
                    } else {
                        Add-ProgressLog "POWERON_TIMEOUT - VM did not power on within timeout (${powerOnDuration}s, State: $($targetVM.PowerState))" "WARN"
                        Add-ProgressLog "POWERON_TIMEOUT - VM may still be starting up in background" "INFO"
                        $result.PowerOnVerified = $false
                    }
                } catch {
                    Add-ProgressLog "POWERON_FINAL_CHECK_ERROR - Error during final power state verification: $($_.Exception.Message)" "WARN"
                    $result.PowerOnVerified = $false
                }
                
            } elseif ($targetVM.PowerState -eq "PoweredOn") {
                Add-ProgressLog "POWERON_ALREADY - VM is already powered on" "SUCCESS"
                $result.PowerOnVerified = $true
            } else {
                Add-ProgressLog "POWERON_UNEXPECTED_STATE - VM is in unexpected state: $($targetVM.PowerState)" "WARN"
                try {
                    Start-VM -VM $targetVM -Confirm:$false -ErrorAction Stop
                    Add-ProgressLog "POWERON_FORCED - Power on command sent from unexpected state" "INFO"
                    
                    Start-Sleep -Seconds 15
                    $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                    Add-ProgressLog "POWERON_FORCED_RESULT - Power state after forced start: $($targetVM.PowerState)" "INFO"
                    $result.PowerOnVerified = ($targetVM.PowerState -eq "PoweredOn")
                    
                } catch {
                    Add-ProgressLog "POWERON_FORCE_FAILED - Failed to power on from unexpected state: $($_.Exception.Message)" "WARN"
                    $result.PowerOnVerified = $false
                }
            }
            
        } catch {
            Add-ProgressLog "POWERON_ERROR - Power on failed: $($_.Exception.Message)" "ERROR"
            $result.PowerOnVerified = $false
        }
        
        # PHASE 4: Set final configuration values
        Add-ProgressLog "FINALIZE - Setting final configuration values from successful reconfiguration" "INFO"
        
        try {
            $finalConfigVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
            $result.NewCPUCount = $finalConfigVM.NumCpu
            $result.NewCoresPerSocket = $finalConfigVM.CoresPerSocket
            $result.NewMemoryGB = $finalConfigVM.MemoryGB
            Add-ProgressLog "FINAL_CONFIG_RETRIEVED - Retrieved actual configuration from VM object" "SUCCESS"
        } catch {
            $result.NewCPUCount = $targetCPUs
            $result.NewCoresPerSocket = "Unknown"
            $result.NewMemoryGB = $targetMemoryGB
            Add-ProgressLog "FINAL_CONFIG_FALLBACK - Using target values (could not retrieve actual config)" "WARN"
        }
        
        $result.NewCPUHotAddEnabled = $true
        $result.NewMemoryHotAddEnabled = $true
        
        Add-ProgressLog "FINAL_CONFIG - CPUs: $($result.NewCPUCount), Cores/Socket: $($result.NewCoresPerSocket), Memory: $($result.NewMemoryGB)GB" "SUCCESS"
        Add-ProgressLog "FINAL_CONFIG - Hot Add CPU: $($result.NewCPUHotAddEnabled), Hot Add Memory: $($result.NewMemoryHotAddEnabled)" "SUCCESS"
        
        # Get final power state
        try {
            $finalVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
            $result.FinalPowerState = $finalVM.PowerState
            Add-ProgressLog "FINAL_POWER_STATE - $($result.FinalPowerState)" "INFO"
        } catch {
            $result.FinalPowerState = "Unknown"
            Add-ProgressLog "FINAL_POWER_STATE - Unknown (could not retrieve VM)" "WARN"
        }
        
        # Determine final status: "CompletedWithWarning" means configured but VM didn't confirm power-on
        if (-not $result.PowerOnVerified -and $result.OriginalPowerState -eq "PoweredOn") {
            $result.Status = "CompletedWithWarning"
            Add-ProgressLog "STATUS - Configuration applied but VM power-on could not be verified" "WARN"
        }
        
        $result.EndTime = Get-Date
        $result.ProcessingTimeMinutes = [math]::Round(($result.EndTime - $result.StartTime).TotalMinutes, 2)
        
        Add-ProgressLog "SUCCESS - Processing completed in $($result.ProcessingTimeMinutes) minutes (PowerOnVerified: $($result.PowerOnVerified))" "SUCCESS"
        
        Add-ProgressLog "CLEANUP - Using shared connections, no cleanup required" "INFO"
        
    } catch {
        $result.Status = "Failed"
        $result.ErrorMessage = $_.Exception.Message
        $result.EndTime = Get-Date
        if ($result.StartTime) {
            $result.ProcessingTimeMinutes = [math]::Round(($result.EndTime - $result.StartTime).TotalMinutes, 2)
        }
        Add-ProgressLog "FAILED - $($_.Exception.Message)" "ERROR"
        
        Add-ProgressLog "ERROR_CLEANUP - Using shared connections, no cleanup required" "INFO"
    }
    
    $result.ProgressLog = $progressLog
    
    Write-Output $result
}

# Extract credentials for job parameters
