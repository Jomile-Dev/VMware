    $poweredOff = ($results | Where-Object { $_.FinalPowerState -eq "PoweredOff" }).Count
    $unknown = ($results | Where-Object { $_.FinalPowerState -notin @("PoweredOn", "PoweredOff") }).Count
    $verifiedOn = ($results | Where-Object { $_.PowerOnVerified -eq $true }).Count
    
    Write-Host "Final Power States:" -ForegroundColor Yellow
