    $results | Select-Object VMName, Status, PowerOnVerified, OriginalCPUCount, NewCPUCount, NewCoresPerSocket, OriginalMemoryGB, NewMemoryGB, `
        @{Name="CPUHotAdd";Expression={$_.NewCPUHotAddEnabled}}, `
