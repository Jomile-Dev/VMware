        Write-Host ("=" * 40) -ForegroundColor Red
        $failures | Select-Object VMName, ErrorMessage, ProcessingTimeMinutes | Format-Table -AutoSize -Wrap
    }
    
    # Show warnings if any - these are VMs that were configured but didn't confirm power-on
    $warningResults = $results | Where-Object { $_.Status -eq "CompletedWithWarning" }
    if ($warningResults) {
