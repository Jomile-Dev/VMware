# VM CPU and Memory Hot Add Configuration Script - Fixed Version
# Specify the CSV file path here
$CSVPath = "C:\path\to\your\vmlist.csv"

# Specify the report file path here
$ReportPath = "C:\Reports\VM_Configuration_Report_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"

Write-Host "Starting VM Configuration Update Script (Enhanced Parallel Mode)..." -ForegroundColor Green
Write-Host "Script started at: $(Get-Date)" -ForegroundColor Gray

# Set PowerCLI configuration to ignore certificate warnings
Write-Host "Configuring PowerCLI settings..." -ForegroundColor Yellow
try {
    Set-PowerCLIConfiguration -InvalidCertificateAction Ignore -Confirm:$false -Scope Session
    Write-Host "PowerCLI configuration set successfully" -ForegroundColor Green
} catch {
    Write-Warning "Failed to set PowerCLI configuration: $($_.Exception.Message)"
}

# vCenter connection parameters - REPLACE WITH YOUR ACTUAL SERVER NAMES
$vCenterServers = @(
    "vcenter1.domain.com",
    "vcenter2.domain.com", 
    "vcenter3.domain.com"
)

Write-Host "DEBUG: Original vCenter servers:" -ForegroundColor Yellow
$vCenterServers | ForEach-Object { Write-Host "  - '$_'" -ForegroundColor Gray }

Write-Host "Starting VM Configuration Update Process" -ForegroundColor Cyan
Write-Host "CSV File: $CSVPath" -ForegroundColor Yellow
Write-Host "Report will be saved to: $ReportPath" -ForegroundColor Yellow

# Validate CSV file exists
Write-Host "Checking CSV file..." -ForegroundColor Yellow
if (!(Test-Path $CSVPath)) {
    Write-Error "CSV file not found at path: $CSVPath"
    Read-Host "Press Enter to exit"
    exit 1
}
Write-Host "CSV file found successfully" -ForegroundColor Green

# Read and validate CSV file
Write-Host "Reading CSV file..." -ForegroundColor Yellow
try {
    $VMList = Import-Csv -Path $CSVPath
    Write-Host "Successfully imported CSV with $($VMList.Count) VMs" -ForegroundColor Green
    if ($VMList.Count -eq 0) {
        Write-Error "CSV file is empty or contains no data rows"
        Read-Host "Press Enter to exit"
        exit 1
    }
} catch {
    Write-Error "Failed to import CSV file: $($_.Exception.Message)"
    Read-Host "Press Enter to exit"
    exit 1
}

# Validate CSV headers
Write-Host "Validating CSV headers..." -ForegroundColor Yellow
$requiredHeaders = @("VMName", "PowerState", "CPUHotAddEnabled", "MemoryHotAddEnabled", "CPUCountBefore", "CPUCountAfter", "MemoryGBBefore", "MemoryGBAfter")
$csvHeaders = $VMList[0].PSObject.Properties.Name
$missingHeaders = $requiredHeaders | Where-Object { $_ -notin $csvHeaders }
if ($missingHeaders) {
    Write-Error "Missing required CSV headers: $($missingHeaders -join ', ')"
    Write-Host "Required headers: $($requiredHeaders -join ', ')" -ForegroundColor Yellow
    Read-Host "Press Enter to exit"
    exit 1
}
Write-Host "CSV headers validated successfully" -ForegroundColor Green

# Connect to vCenter servers
Write-Host "Preparing to connect to vCenter servers..." -ForegroundColor Yellow
$Credential = Get-Credential -Message "Enter vCenter credentials"
if (!$Credential) {
    Write-Error "No credentials provided. Exiting."
    Read-Host "Press Enter to exit"
    exit 1
}

Write-Host "Validating vCenter server list..." -ForegroundColor Yellow
$validVCenterServers = @()
foreach ($server in $vCenterServers) {
    if (-not [string]::IsNullOrWhiteSpace($server)) {
        $cleanServer = $server.Trim()
        if ($cleanServer -ne "") {
            $validVCenterServers += $cleanServer
            Write-Host "  ✓ Added: '$cleanServer'" -ForegroundColor Green
        }
    }
}

if ($validVCenterServers.Count -eq 0) {
    Write-Error "No valid vCenter servers found in the list."
    Read-Host "Press Enter to exit"
    exit 1
}

$connectedServers = @()
Write-Host "Attempting to connect to vCenter servers..." -ForegroundColor Yellow
foreach ($vc in $validVCenterServers) {
    Write-Host "Connecting to $vc..." -ForegroundColor Gray
    try {
        Connect-VIServer -Server $vc -Credential $Credential -ErrorAction Stop
        Write-Host "Connected to $vc" -ForegroundColor Green
        $connectedServers += $vc
    } catch {
        Write-Warning "Failed to connect to $vc : $($_.Exception.Message)"
    }
}

if ($connectedServers.Count -eq 0) {
    Write-Error "Failed to connect to any vCenter servers"
    Read-Host "Press Enter to exit"
    exit 1
}

Write-Host "Successfully connected to $($connectedServers.Count) vCenter server(s)" -ForegroundColor Green

Write-Host "Preparing server list for jobs..." -ForegroundColor Yellow
$finalServerArray = $connectedServers
Write-Host "Will pass $($finalServerArray.Count) servers to jobs: $($finalServerArray -join ', ')" -ForegroundColor Yellow

# Display confirmation
Write-Host "`n$('=' * 80)" -ForegroundColor Yellow
Write-Host "VM CONFIGURATION CHANGE CONFIRMATION" -ForegroundColor Yellow
Write-Host "$('=' * 80)" -ForegroundColor Yellow
foreach ($vmEntry in $VMList) {
    Write-Host "VM: $($vmEntry.VMName) | CPU: $($vmEntry.CPUCountBefore) -> $($vmEntry.CPUCountAfter) | Memory: $($vmEntry.MemoryGBBefore)GB -> $($vmEntry.MemoryGBAfter)GB | Hot Add: Enabled" -ForegroundColor Cyan
}
Write-Host "`nTotal VMs: $($VMList.Count) | Processing: PARALLEL" -ForegroundColor Yellow
Write-Host "WARNING: VMs will be shut down and reconfigured!" -ForegroundColor Red
Write-Host "`nPress ENTER to continue or CTRL+C to cancel..." -ForegroundColor White
Read-Host

# ============================================================
# SCRIPT BLOCK FOR PARALLEL JOB PROCESSING
# ============================================================
$vmProcessingScript = {
    param($vmData, $vCenterList, $username, $password, $jobId)
    
    $logPrefix = "[$($vmData.VMName)][Job$jobId]"
    $progressLog = @()
    
    function Add-ProgressLog {
        param($Message, $LogLevel = "INFO")
        $timestamp = Get-Date -Format "HH:mm:ss.fff"
        $logEntry = "$timestamp $logPrefix [$LogLevel] $Message"
        $script:progressLog += $logEntry
        
        $output = [PSCustomObject]@{
            Type         = "ProgressUpdate"
            VMName       = $vmData.VMName
            JobId        = $jobId
            Timestamp    = $timestamp
            LogLevel     = $LogLevel
            Message      = $Message
            FullLogEntry = $logEntry
        }
        Write-Output $output
    }
    
    try {
        Add-ProgressLog "STARTING - Initializing job environment" "START"
        
        $securePassword = ConvertTo-SecureString -String $password -AsPlainText -Force
        $jobCredential = New-Object System.Management.Automation.PSCredential($username, $securePassword)
        
        $moduleLoaded = $false
        $retryCount = 0
        $originalVerbosePreference     = $VerbosePreference
        $originalInformationPreference = $InformationPreference
        $originalWarningPreference     = $WarningPreference
        $VerbosePreference     = "SilentlyContinue"
        $InformationPreference = "SilentlyContinue" 
        $WarningPreference     = "SilentlyContinue"
        
        while (-not $moduleLoaded -and $retryCount -lt 3) {
            try {
                $null = Import-Module VMware.PowerCLI -Force -Global -ErrorAction Stop -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                $null = Set-PowerCLIConfiguration -InvalidCertificateAction Ignore -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                $null = Set-PowerCLIConfiguration -DisplayDeprecationWarnings $false -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                $null = Set-PowerCLIConfiguration -ParticipateInCEIP $false -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                $null = Set-PowerCLIConfiguration -DefaultVIServerMode Single -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                $null = Set-PowerCLIConfiguration -WebOperationTimeoutSeconds 300 -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                $moduleLoaded = $true
                Add-ProgressLog "INITIALIZED - PowerCLI loaded successfully" "SUCCESS"
            } catch {
                if (Get-Module -ListAvailable -Name VMware.VimAutomation.Core) {
                    try {
                        $null = Import-Module VMware.VimAutomation.Core -Force -Global -ErrorAction Stop -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        $null = Import-Module VMware.VimAutomation.Common -Force -Global -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        $null = Set-PowerCLIConfiguration -InvalidCertificateAction Ignore -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        $null = Set-PowerCLIConfiguration -DisplayDeprecationWarnings $false -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        $null = Set-PowerCLIConfiguration -ParticipateInCEIP $false -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        $null = Set-PowerCLIConfiguration -DefaultVIServerMode Single -Confirm:$false -Scope Session -ErrorAction SilentlyContinue -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false 6>$null 3>$null 2>$null
                        $moduleLoaded = $true
                        Add-ProgressLog "INITIALIZED - PowerCLI legacy modules loaded" "SUCCESS"
                    } catch {
                        $retryCount++
                        Add-ProgressLog "MODULE_RETRY - Legacy import attempt $retryCount failed: $($_.Exception.Message)" "WARN"
                        Start-Sleep -Seconds 2
                    }
                } else {
                    throw "PowerCLI modules not found"
                }
            }
        }
        
        $VerbosePreference     = $originalVerbosePreference
        $InformationPreference = $originalInformationPreference
        $WarningPreference     = $originalWarningPreference
        
        if (-not $moduleLoaded) {
            throw "Failed to load PowerCLI after 3 attempts"
        }
        
        $result = [PSCustomObject]@{
            Type                    = "FinalResult"
            VMName                  = $vmData.VMName
            JobId                   = $jobId
            Status                  = "Success"
            OriginalPowerState      = $vmData.PowerState
            OriginalCPUCount        = $vmData.CPUCountBefore
            TargetCPUCount          = $vmData.CPUCountAfter
            OriginalMemoryGB        = $vmData.MemoryGBBefore
            TargetMemoryGB          = $vmData.MemoryGBAfter
            NewCPUCount             = ""
            NewCoresPerSocket       = ""
            NewMemoryGB             = ""
            NewCPUHotAddEnabled     = ""
            NewMemoryHotAddEnabled  = ""
            FinalPowerState         = "Unknown"
            ErrorMessage            = ""
            StartTime               = Get-Date
            EndTime                 = $null
            ProcessingTimeMinutes   = 0
            ProgressLog             = $progressLog
        }
        
        Add-ProgressLog "CONNECTING - Attempting vCenter connections" "INFO"
        $jobConnections = @()
        $vmServer = $null
        
        if (-not $vCenterList -or $vCenterList.Count -eq 0) {
            throw "vCenter server list is empty or null in job parameter"
        }
        
        Add-ProgressLog "DEBUG - Received vCenter list count: $($vCenterList.Count)" "INFO"
        
        $serverListToProcess = @()
        if ($vCenterList -is [array]) { $serverListToProcess = $vCenterList }
        elseif ($vCenterList -is [string]) { $serverListToProcess = @($vCenterList) }
        else { $serverListToProcess = @($vCenterList) }
        
        $validServers = @()
        foreach ($server in $serverListToProcess) {
            if (-not [string]::IsNullOrWhiteSpace($server)) {
                $cleanServer = $server.ToString().Trim()
                if ($cleanServer -ne "") {
                    $validServers += $cleanServer
                    Add-ProgressLog "VCENTER_VALID - Added server: '$cleanServer'" "INFO"
                }
            }
        }
        
        if ($validServers.Count -eq 0) {
            throw "No valid vCenter servers found after cleaning."
        }
        
        Add-ProgressLog "VCENTER_LIST - Will attempt $($validServers.Count) servers: $($validServers -join ', ')" "INFO"
        
        foreach ($vcServer in $validServers) {
            try {
                Add-ProgressLog "CONNECT_ATTEMPT - Connecting to '$vcServer'" "INFO"
                if ([string]::IsNullOrWhiteSpace($vcServer)) {
                    Add-ProgressLog "CONNECT_SKIP - Invalid server name" "WARN"
                    continue
                }
                $connection = Connect-VIServer -Server $vcServer -Credential $jobCredential -Force -ErrorAction Stop -WarningAction SilentlyContinue -InformationAction SilentlyContinue -Verbose:$false
                if ($connection -and $connection.IsConnected) {
                    $jobConnections += $vcServer
                    Add-ProgressLog "CONNECTED - Successfully connected to '$vcServer'" "SUCCESS"
                    $testVM = Get-VM -Name $vmData.VMName -Server $vcServer -ErrorAction SilentlyContinue
                    if ($testVM) {
                        Add-ProgressLog "VM_LOCATED - Found VM on $vcServer" "SUCCESS"
                        $vmServer = $vcServer
                        break
                    }
                }
            } catch {
                Add-ProgressLog "CONNECT_FAILED - $vcServer : $($_.Exception.Message)" "ERROR"
            }
        }
        
        if ($jobConnections.Count -eq 0) {
            throw "No vCenter connections established."
        }
        
        Add-ProgressLog "SEARCHING - Looking for VM across $($jobConnections.Count) connected servers" "INFO"
        $targetVM = $null
        
        if (-not $vmServer) {
            foreach ($server in $jobConnections) {
                try {
                    $targetVM = Get-VM -Name $vmData.VMName -Server $server -ErrorAction Stop
                    if ($targetVM -and $targetVM.Name -eq $vmData.VMName) {
                        $vmServer = $server
                        Add-ProgressLog "VM_FOUND - Located '$($targetVM.Name)' on $server (Power: $($targetVM.PowerState), CPUs: $($targetVM.NumCpu), Memory: $($targetVM.MemoryGB)GB)" "SUCCESS"
                        break
                    } else { $targetVM = $null }
                } catch {
                    Add-ProgressLog "VM_SEARCH - Not found on $server" "INFO"
                    $targetVM = $null
                }
            }
        } else {
            $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
        }
        
        if (-not $targetVM -or -not $vmServer) {
            throw "VM '$($vmData.VMName)' not found on any connected vCenter server"
        }
        
        # ---- PHASE 1: Shutdown ----
        if ($targetVM -and $targetVM.PowerState -eq "PoweredOn") {
            Add-ProgressLog "SHUTDOWN_START - Initiating graceful shutdown" "INFO"
            try {
                Shutdown-VMGuest -VM $targetVM -Confirm:$false -ErrorAction Stop
                Add-ProgressLog "SHUTDOWN_INITIATED - Graceful shutdown command sent" "SUCCESS"
            } catch {
                Add-ProgressLog "SHUTDOWN_FALLBACK - Graceful failed, forcing power off: $($_.Exception.Message)" "WARN"
                Stop-VM -VM $targetVM -Confirm:$false -ErrorAction Stop
            }
            
            $shutdownTimeout = (Get-Date).AddMinutes(8)
            $shutdownStart   = Get-Date
            
            while ($targetVM -and $targetVM.PowerState -ne "PoweredOff" -and (Get-Date) -lt $shutdownTimeout) {
                Start-Sleep -Seconds 5
                try {
                    $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                    $elapsed  = [math]::Round(((Get-Date) - $shutdownStart).TotalSeconds)
                    if ($elapsed % 30 -eq 0) {
                        Add-ProgressLog "SHUTDOWN_WAIT - ${elapsed}s elapsed, State: $($targetVM.PowerState)" "INFO"
                    }
                } catch {
                    Add-ProgressLog "SHUTDOWN_ERROR - Failed to refresh VM status" "WARN"
                    break
                }
            }
            
            if ($targetVM -and $targetVM.PowerState -ne "PoweredOff") {
                Add-ProgressLog "SHUTDOWN_FORCE - Timeout reached, forcing power off" "WARN"
                try {
                    Stop-VM -VM $targetVM -Confirm:$false -ErrorAction Stop
                    Start-Sleep -Seconds 5
                    $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                } catch {
                    Add-ProgressLog "SHUTDOWN_FORCE_ERROR - $($_.Exception.Message)" "ERROR"
                }
            }
            
            $shutdownDuration = [math]::Round(((Get-Date) - $shutdownStart).TotalSeconds)
            Add-ProgressLog "SHUTDOWN_COMPLETE - VM off (took ${shutdownDuration}s, State: $($targetVM.PowerState))" "SUCCESS"
        } else {
            Add-ProgressLog "SHUTDOWN_SKIP - VM already powered off, proceeding" "INFO"
        }
        
        # ---- PHASE 2: Reconfigure ----
        Add-ProgressLog "CONFIG_START - Beginning VM reconfiguration" "INFO"
        Start-Sleep -Seconds 8
        
        $targetCPUs    = [int]$vmData.CPUCountAfter
        $targetMemoryGB = [int]$vmData.MemoryGBAfter
        $configurationSuccessful = $false
        
        # Approach 1: vSphere API
        try {
            Add-ProgressLog "CONFIG_API_ATTEMPT - Trying vSphere API configuration" "INFO"
            $freshVM   = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
            $vmView    = Get-View -VIObject $freshVM -ErrorAction Stop
            $configSpec = New-Object VMware.Vim.VirtualMachineConfigSpec
            $configSpec.NumCPUs             = $targetCPUs
            $configSpec.MemoryMB            = $targetMemoryGB * 1024
            $configSpec.CpuHotAddEnabled    = $true
            $configSpec.MemoryHotAddEnabled = $true
            $task     = $vmView.ReconfigVM($configSpec)
            Add-ProgressLog "CONFIG_API_TASK - Task submitted (CPU: $targetCPUs, Memory: ${targetMemoryGB}GB)" "INFO"
            
            $taskInfo = Get-View $task -ErrorAction Stop
            $timeout  = (Get-Date).AddMinutes(5)
            while ($taskInfo.Info.State -eq "running" -and (Get-Date) -lt $timeout) {
                Start-Sleep -Seconds 5
                $taskInfo.UpdateViewData()
            }
            
            if ($taskInfo.Info.State -eq "success") {
                Add-ProgressLog "CONFIG_API_COMPLETE - vSphere API reconfiguration successful" "SUCCESS"
                $configurationSuccessful = $true
            } else {
                Add-ProgressLog "CONFIG_API_INCOMPLETE - State: $($taskInfo.Info.State), falling back to PowerCLI" "WARN"
            }
        } catch {
            Add-ProgressLog "CONFIG_API_FALLBACK - $($_.Exception.Message), trying PowerCLI" "INFO"
        }
        
        # Approach 2: PowerCLI cmdlets
        if (-not $configurationSuccessful) {
            try {
                Add-ProgressLog "CONFIG_CMDLET_START - Using PowerCLI cmdlets" "INFO"
                $cmdletVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                Set-VM -VM $cmdletVM -NumCpu $targetCPUs -MemoryGB $targetMemoryGB -Confirm:$false -ErrorAction Stop
                Add-ProgressLog "CONFIG_CMDLET_SUCCESS - CPU and Memory set via PowerCLI" "SUCCESS"
                $configurationSuccessful = $true
                
                try {
                    Add-ProgressLog "CONFIG_HOTADD_ATTEMPT - Enabling hot add" "INFO"
                    Start-Sleep -Seconds 3
                    $hotAddVM   = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                    $hotAddView = Get-View -VIObject $hotAddVM -ErrorAction Stop
                    $hotAddSpec = New-Object VMware.Vim.VirtualMachineConfigSpec
                    $hotAddSpec.CpuHotAddEnabled    = $true
                    $hotAddSpec.MemoryHotAddEnabled = $true
                    $hotAddView.ReconfigVM($hotAddSpec) | Out-Null
                    Add-ProgressLog "CONFIG_HOTADD_SUCCESS - Hot Add features enabled" "SUCCESS"
                } catch {
                    Add-ProgressLog "CONFIG_HOTADD_SKIP - $($_.Exception.Message) (can be enabled manually)" "INFO"
                }
            } catch {
                Add-ProgressLog "CONFIG_CMDLET_ERROR - $($_.Exception.Message)" "ERROR"
                throw "Both API and PowerCLI approaches failed: $($_.Exception.Message)"
            }
        }
        
        if (-not $configurationSuccessful) {
            throw "Configuration was not completed successfully"
        }
        Add-ProgressLog "CONFIG_COMPLETE - VM reconfiguration done" "SUCCESS"
        
        # ---- PHASE 3: Power On ----
        Add-ProgressLog "POWERON_START - Initiating startup sequence" "INFO"
        Start-Sleep -Seconds 3
        
        try {
            $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
            Add-ProgressLog "POWERON_VM_STATE - Current state: $($targetVM.PowerState)" "INFO"
            
            if ($targetVM.PowerState -eq "PoweredOff") {
                Start-VM -VM $targetVM -Confirm:$false -ErrorAction Stop
                Add-ProgressLog "POWERON_INITIATED - Power on command sent" "SUCCESS"
                
                $powerOnTimeout = (Get-Date).AddMinutes(3)
                $powerOnStart   = Get-Date
                
                while ($targetVM.PowerState -ne "PoweredOn" -and (Get-Date) -lt $powerOnTimeout) {
                    Start-Sleep -Seconds 5
                    try {
                        $targetVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                        $elapsed  = [math]::Round(((Get-Date) - $powerOnStart).TotalSeconds)
                        if ($elapsed % 30 -eq 0) {
                            Add-ProgressLog "POWERON_PROGRESS - ${elapsed}s elapsed, State: $($targetVM.PowerState)" "INFO"
                        }
                        if ($targetVM.PowerState -eq "PoweredOn") {
                            Add-ProgressLog "POWERON_SUCCESS - VM powered on (${elapsed}s)" "SUCCESS"
                            break
                        }
                    } catch {
                        Add-ProgressLog "POWERON_STATUS_ERROR - $($_.Exception.Message)" "WARN"
                        break
                    }
                }
                
                # Final power-on verification with extended wait
                # Give VMware a few extra seconds to fully update the power state
                Start-Sleep -Seconds 5
                try {
                    $verifyVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                    $powerOnDuration = [math]::Round(((Get-Date) - $powerOnStart).TotalSeconds)
                    $result.FinalPowerState = $verifyVM.PowerState
                    if ($verifyVM.PowerState -eq "PoweredOn") {
                        Add-ProgressLog "POWERON_VERIFIED - VM is PoweredOn (${powerOnDuration}s total)" "SUCCESS"
                    } else {
                        Add-ProgressLog "POWERON_TIMEOUT - Final state: $($verifyVM.PowerState) after ${powerOnDuration}s" "WARN"
                    }
                } catch {
                    Add-ProgressLog "POWERON_FINAL_CHECK_ERROR - $($_.Exception.Message)" "WARN"
                    $result.FinalPowerState = "Unknown"
                }
                
            } elseif ($targetVM.PowerState -eq "PoweredOn") {
                Add-ProgressLog "POWERON_ALREADY - VM is already PoweredOn" "SUCCESS"
                $result.FinalPowerState = "PoweredOn"
            } else {
                Add-ProgressLog "POWERON_UNEXPECTED_STATE - State: $($targetVM.PowerState), attempting Start-VM" "WARN"
                try {
                    Start-VM -VM $targetVM -Confirm:$false -ErrorAction Stop
                    Add-ProgressLog "POWERON_FORCED - Power on sent from unexpected state" "INFO"
                    Start-Sleep -Seconds 20
                    $checkVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
                    $result.FinalPowerState = $checkVM.PowerState
                    Add-ProgressLog "POWERON_FORCED_RESULT - State: $($checkVM.PowerState)" "INFO"
                } catch {
                    Add-ProgressLog "POWERON_FORCE_FAILED - $($_.Exception.Message)" "WARN"
                    $result.FinalPowerState = $targetVM.PowerState
                }
            }
        } catch {
            Add-ProgressLog "POWERON_ERROR - $($_.Exception.Message)" "ERROR"
            # Attempt one final state check even on error
            try {
                $fallbackVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction SilentlyContinue
                if ($fallbackVM) { $result.FinalPowerState = $fallbackVM.PowerState }
            } catch { }
        }
        
        # ---- PHASE 4: Finalize ----
        Add-ProgressLog "FINALIZE - Retrieving final configuration values" "INFO"
        try {
            $finalConfigVM            = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction Stop
            $result.NewCPUCount       = $finalConfigVM.NumCpu
            $result.NewCoresPerSocket = $finalConfigVM.CoresPerSocket
            $result.NewMemoryGB       = $finalConfigVM.MemoryGB
            # Capture power state here too as a safety net
            if ($result.FinalPowerState -eq "Unknown") {
                $result.FinalPowerState = $finalConfigVM.PowerState
            }
            Add-ProgressLog "FINAL_CONFIG_RETRIEVED - Got actual config from VM" "SUCCESS"
        } catch {
            $result.NewCPUCount       = $targetCPUs
            $result.NewCoresPerSocket = "Unknown"
            $result.NewMemoryGB       = $targetMemoryGB
            Add-ProgressLog "FINAL_CONFIG_FALLBACK - Using target values: $($_.Exception.Message)" "WARN"
        }
        
        $result.NewCPUHotAddEnabled    = $true
        $result.NewMemoryHotAddEnabled = $true
        
        Add-ProgressLog "FINAL_CONFIG - CPUs: $($result.NewCPUCount), Cores/Socket: $($result.NewCoresPerSocket), Memory: $($result.NewMemoryGB)GB" "SUCCESS"
        Add-ProgressLog "FINAL_CONFIG - Hot Add CPU: $($result.NewCPUHotAddEnabled), Hot Add Memory: $($result.NewMemoryHotAddEnabled)" "SUCCESS"
        Add-ProgressLog "FINAL_POWER  - Power State: $($result.FinalPowerState)" "SUCCESS"
        
        $result.EndTime               = Get-Date
        $result.ProcessingTimeMinutes = [math]::Round(($result.EndTime - $result.StartTime).TotalMinutes, 2)
        Add-ProgressLog "SUCCESS - Completed in $($result.ProcessingTimeMinutes) minutes" "SUCCESS"
        
    } catch {
        $result.Status       = "Failed"
        $result.ErrorMessage = $_.Exception.Message
        $result.EndTime      = Get-Date
        if ($result.StartTime) {
            $result.ProcessingTimeMinutes = [math]::Round(($result.EndTime - $result.StartTime).TotalMinutes, 2)
        }
        # Final state check on failure
        try {
            $errVM = Get-VM -Name $vmData.VMName -Server $vmServer -ErrorAction SilentlyContinue
            if ($errVM) { $result.FinalPowerState = $errVM.PowerState }
        } catch { }
        Add-ProgressLog "FAILED - $($_.Exception.Message)" "ERROR"
    }
    
    $result.ProgressLog = $progressLog
    Write-Output $result
}

# ============================================================
# PARALLEL JOB LAUNCHER + MONITOR
# ============================================================
$Username        = $Credential.UserName
$Password        = $Credential.GetNetworkCredential().Password
$jobs            = @()
$maxJobs         = 4
$jobCounter      = 1
$scriptStartTime = Get-Date
$results         = @()
$processedJobs   = @()

# KEY FIX: Track which log entries we've already printed per job
# Using a hashtable of HashSets for O(1) lookup
$seenLogEntries = @{}

Write-Host "`n$('=' * 80)" -ForegroundColor Cyan
Write-Host "STARTING PARALLEL PROCESSING" -ForegroundColor Cyan
Write-Host "$('=' * 80)" -ForegroundColor Cyan
Write-Host "Maximum concurrent jobs: $maxJobs" -ForegroundColor Yellow
Write-Host "Real-time monitoring enabled - progress will stream throughout" -ForegroundColor Yellow

if ($finalServerArray.Count -eq 0) {
    Write-Error "No connected vCenter servers available for jobs!"
    Read-Host "Press Enter to exit"
    exit 1
}

# ---- Helper: flush new progress updates from ALL jobs ----
function Flush-JobProgress {
    param($jobList, $seenEntries)
    
    foreach ($jobInfo in $jobList) {
        if ($jobInfo.Job.State -eq 'Completed' -or $jobInfo.Job.State -eq 'Running') {
            # Consume output WITHOUT -Keep so we don't re-read old entries
            $updates = Receive-Job -Job $jobInfo.Job -Keep | Where-Object { $_.Type -eq "ProgressUpdate" }
            foreach ($update in $updates) {
                $jid = $update.JobId
                if (-not $seenEntries.ContainsKey($jid)) {
                    $seenEntries[$jid] = [System.Collections.Generic.HashSet[string]]::new()
                }
                if ($seenEntries[$jid].Add($update.FullLogEntry)) {
                    $color = switch ($update.LogLevel) {
                        "START"   { "Cyan" }
                        "SUCCESS" { "Green" }
                        "ERROR"   { "Red" }
                        "WARN"    { "Yellow" }
                        default   { "Gray" }
                    }
                    Write-Host $update.FullLogEntry -ForegroundColor $color
                }
            }
        }
    }
}

# ---- Helper: print running status summary ----
$lastSummaryUpdate = Get-Date
function Print-StatusSummary {
    param($jobList, $processedList, $resultList, $totalVMs, $startTime)
    
    $completed    = $processedList.Count
    $running      = @($jobList | Where-Object { $_.Job.State -eq 'Running' }).Count
    $remaining    = $totalVMs - $completed
    $elapsedTotal = [math]::Round(((Get-Date) - $startTime).TotalMinutes, 1)
    $successCount = @($resultList | Where-Object { $_.Status -eq 'Success' }).Count
    
    Write-Host "`n$('=' * 60)" -ForegroundColor Yellow
    Write-Host "*** STATUS UPDATE - $elapsedTotal min elapsed ***" -ForegroundColor Yellow -BackgroundColor DarkYellow
    Write-Host "$('=' * 60)" -ForegroundColor Yellow
    Write-Host "Progress    : $completed of $totalVMs VMs completed" -ForegroundColor Green
    Write-Host "Running     : $running jobs active" -ForegroundColor Cyan
    Write-Host "Remaining   : $remaining VMs" -ForegroundColor Yellow
    if ($completed -gt 0) {
        $pct = [math]::Round($successCount / $completed * 100, 1)
        Write-Host "Success Rate: $pct% ($successCount/$completed)" -ForegroundColor $(if ($pct -eq 100) { "Green" } else { "Yellow" })
    }
    if ($running -gt 0) {
        Write-Host "`nCurrently processing:" -ForegroundColor Cyan
        $jobList | Where-Object { $_.Job.State -eq 'Running' } | ForEach-Object {
            $el = [math]::Round(((Get-Date) - $_.StartTime).TotalMinutes, 1)
            Write-Host "   • $($_.VMName) (Job $($_.JobId) - ${el}m elapsed)" -ForegroundColor White
        }
    }
    Write-Host "$('=' * 60)" -ForegroundColor Yellow
}

# ---- Helper: collect and display result from a completed job ----
function Collect-JobResult {
    param($completedJob, $jobList, [ref]$resultList, [ref]$processedList, $seenEntries)
    
    $jobInfo = $jobList | Where-Object { $_.Job.Id -eq $completedJob.Id }
    if (-not $jobInfo) { return }
    
    # Flush any final progress lines
    Flush-JobProgress -jobList @($jobInfo) -seenEntries $seenEntries
    
    Write-Host "`n$('=' * 50)" -ForegroundColor Magenta
    Write-Host "JOB COMPLETE: $($jobInfo.VMName)" -ForegroundColor Magenta -BackgroundColor DarkMagenta
    Write-Host "$('=' * 50)" -ForegroundColor Magenta
    
    try {
        $jobOutput = Receive-Job -Job $completedJob -ErrorAction Stop
        $vmResult  = $jobOutput | Where-Object { $_.Type -eq "FinalResult" } | Select-Object -Last 1
        if ($vmResult) {
            $resultList.Value  += $vmResult
            $duration           = [math]::Round(((Get-Date) - $jobInfo.StartTime).TotalMinutes, 2)
            if ($vmResult.Status -eq "Success") {
                Write-Host "✓ SUCCESS: $($vmResult.VMName)" -ForegroundColor Green
                Write-Host "  CPUs: $($vmResult.OriginalCPUCount) → $($vmResult.NewCPUCount) | Memory: $($vmResult.OriginalMemoryGB)GB → $($vmResult.NewMemoryGB)GB" -ForegroundColor Green
                Write-Host "  Final Power State: $($vmResult.FinalPowerState)" -ForegroundColor Green
                Write-Host "  Time: $duration minutes" -ForegroundColor Green
            } else {
                Write-Host "✗ FAILED: $($vmResult.VMName) - $($vmResult.ErrorMessage)" -ForegroundColor Red
                Write-Host "  Final Power State: $($vmResult.FinalPowerState)" -ForegroundColor Yellow
                Write-Host "  Time: $duration minutes" -ForegroundColor Red
            }
        } else {
            Write-Warning "No FinalResult found for VM: $($jobInfo.VMName)"
        }
    } catch {
        Write-Warning "Error collecting job $($completedJob.Id): $_"
    }
    
    Remove-Job -Job $completedJob -Force
    $processedList.Value += $completedJob.Id
}

# ---- Launch all jobs ----
Write-Host "`nLaunching jobs for $($VMList.Count) VMs..." -ForegroundColor Cyan

foreach ($vmEntry in $VMList) {
    
    # Wait for a free slot, flushing progress the whole time
    while ((Get-Job -State Running).Count -ge $maxJobs) {
        Start-Sleep -Seconds 1
        Flush-JobProgress -jobList $jobs -seenEntries $seenLogEntries
        
        $completedJobs = Get-Job | Where-Object { $_.State -ne 'Running' -and $_.Id -notin $processedJobs }
        foreach ($cj in $completedJobs) {
            Collect-JobResult -completedJob $cj -jobList $jobs -resultList ([ref]$results) -processedList ([ref]$processedJobs) -seenEntries $seenLogEntries
        }
        
        if (((Get-Date) - $lastSummaryUpdate).TotalSeconds -ge 20) {
            Print-StatusSummary -jobList $jobs -processedList $processedJobs -resultList $results -totalVMs $VMList.Count -startTime $scriptStartTime
            $lastSummaryUpdate = Get-Date
        }
    }
    
    # Launch the new job
    Write-Host "`nDEBUG: Starting job $jobCounter for $($vmEntry.VMName) with $($finalServerArray.Count) servers" -ForegroundColor Gray
    try {
        $job = Start-Job -ScriptBlock $vmProcessingScript -ArgumentList $vmEntry, $finalServerArray, $Username, $Password, $jobCounter
        $jobs += [PSCustomObject]@{
            Job       = $job
            VMName    = $vmEntry.VMName
            JobId     = $jobCounter
            StartTime = Get-Date
        }
        Write-Host "LAUNCHED JOB $jobCounter → $($vmEntry.VMName)" -ForegroundColor Cyan -BackgroundColor DarkBlue
        Write-Host "   CPU: $($vmEntry.CPUCountBefore) → $($vmEntry.CPUCountAfter) | Memory: $($vmEntry.MemoryGBBefore)GB → $($vmEntry.MemoryGBAfter)GB" -ForegroundColor White
        $jobCounter++
        Start-Sleep -Milliseconds 500
    } catch {
        Write-Error "FAILED to start job for $($vmEntry.VMName): $($_.Exception.Message)"
    }
}

Write-Host "`n$('=' * 80)" -ForegroundColor Green
Write-Host "ALL $($VMList.Count) JOBS LAUNCHED - WAITING FOR COMPLETION" -ForegroundColor Green
Write-Host "$('=' * 80)" -ForegroundColor Green

# ---- Drain loop: wait for all remaining jobs to finish ----
# Use $VMList.Count as the target so we're never comparing against a stale $jobs array
while ($processedJobs.Count -lt $VMList.Count) {
    Start-Sleep -Seconds 1
    Flush-JobProgress -jobList $jobs -seenEntries $seenLogEntries
    
    $completedJobs = Get-Job | Where-Object { $_.State -ne 'Running' -and $_.Id -notin $processedJobs }
    foreach ($cj in $completedJobs) {
        Collect-JobResult -completedJob $cj -jobList $jobs -resultList ([ref]$results) -processedList ([ref]$processedJobs) -seenEntries $seenLogEntries
    }
    
    if (((Get-Date) - $lastSummaryUpdate).TotalSeconds -ge 20) {
        Print-StatusSummary -jobList $jobs -processedList $processedJobs -resultList $results -totalVMs $VMList.Count -startTime $scriptStartTime
        $lastSummaryUpdate = Get-Date
    }
    
    # Safety exit: if no jobs exist at all (all failed to launch), don't loop forever
    if ((Get-Job).Count -eq 0 -and $processedJobs.Count -eq 0) {
        Write-Warning "No jobs found - all Start-Job calls may have failed. Exiting monitor loop."
        break
    }
}

# ============================================================
# FINAL REPORT
# ============================================================
$totalScriptTime = [math]::Round(((Get-Date) - $scriptStartTime).TotalMinutes, 2)

Write-Host "`n$('=' * 80)" -ForegroundColor Green
Write-Host "*** ALL JOBS COMPLETE - FINAL REPORT ***" -ForegroundColor Green -BackgroundColor DarkGreen
Write-Host "$('=' * 80)" -ForegroundColor Green

if ($results.Count -gt 0) {
    $results | Export-Csv -Path $ReportPath -NoTypeInformation
    
    $successful = ($results | Where-Object { $_.Status -eq "Success" }).Count
    $failed     = ($results | Where-Object { $_.Status -eq "Failed" }).Count
    $avgTime    = [math]::Round(($results | Measure-Object ProcessingTimeMinutes -Average).Average, 2)
    $maxTime    = [math]::Round(($results | Measure-Object ProcessingTimeMinutes -Maximum).Maximum, 2)
    $minTime    = [math]::Round(($results | Measure-Object ProcessingTimeMinutes -Minimum).Minimum, 2)
    
    Write-Host "`nSUMMARY:" -ForegroundColor Cyan -BackgroundColor DarkCyan
    Write-Host "$('=' * 50)" -ForegroundColor Cyan
    Write-Host "Total VMs Processed : $($results.Count)" -ForegroundColor Yellow
    Write-Host "Successful          : $successful" -ForegroundColor Green
    Write-Host "Failed              : $failed" -ForegroundColor Red
    Write-Host "Success Rate        : $([math]::Round($successful / [math]::Max($results.Count,1) * 100, 1))%" -ForegroundColor $(if ($successful -eq $results.Count) { "Green" } else { "Yellow" })
    Write-Host "Total Runtime       : $totalScriptTime minutes" -ForegroundColor Yellow
    Write-Host "Avg Time per VM     : $avgTime min | Min: $minTime min | Max: $maxTime min" -ForegroundColor Yellow
    Write-Host "Report saved to     : $ReportPath" -ForegroundColor Cyan
    Write-Host "$('=' * 50)" -ForegroundColor Cyan
    
    Write-Host "`nDETAILED RESULTS:" -ForegroundColor Cyan
    $results | Select-Object VMName, Status,
        OriginalCPUCount, NewCPUCount, NewCoresPerSocket,
        OriginalMemoryGB, NewMemoryGB,
        @{Name="CPUHotAdd";Expression={$_.NewCPUHotAddEnabled}},
        @{Name="MemHotAdd";Expression={$_.NewMemoryHotAddEnabled}},
        FinalPowerState, ProcessingTimeMinutes |
        Format-Table -AutoSize
    
    $failures = $results | Where-Object { $_.Status -eq "Failed" }
    if ($failures) {
        Write-Host "`nFAILURE DETAILS:" -ForegroundColor Red -BackgroundColor DarkRed
        $failures | Select-Object VMName, ErrorMessage, FinalPowerState, ProcessingTimeMinutes | Format-Table -AutoSize -Wrap
    }
    
    # ---- POWER STATE SUMMARY (fixed) ----
    Write-Host "`n$('=' * 50)" -ForegroundColor Cyan
    Write-Host "POWER STATE SUMMARY" -ForegroundColor Cyan -BackgroundColor DarkCyan
    Write-Host "$('=' * 50)" -ForegroundColor Cyan
    
    $poweredOn  = @($results | Where-Object { $_.FinalPowerState -eq "PoweredOn" }).Count
    $poweredOff = @($results | Where-Object { $_.FinalPowerState -eq "PoweredOff" }).Count
    $unknown    = @($results | Where-Object { $_.FinalPowerState -notin @("PoweredOn","PoweredOff") }).Count
    
    Write-Host "Powered On  : $poweredOn" -ForegroundColor Green
    Write-Host "Powered Off : $poweredOff" -ForegroundColor Red
    if ($unknown -gt 0) {
        Write-Host "Unknown     : $unknown" -ForegroundColor Yellow
        Write-Host "  (VMs with unknown state - verify manually):" -ForegroundColor Yellow
        $results | Where-Object { $_.FinalPowerState -notin @("PoweredOn","PoweredOff") } |
            Select-Object VMName, FinalPowerState, Status | Format-Table -AutoSize
    }
    
    $originallyOff = @($results | Where-Object { $_.OriginalPowerState -eq "PoweredOff" })
    if ($originallyOff.Count -gt 0) {
        Write-Host "`nVMs originally powered off before script ran:" -ForegroundColor Yellow
        $originallyOff | Select-Object VMName, OriginalPowerState, FinalPowerState, Status | Format-Table -AutoSize
    } else {
        Write-Host "`nAll VMs were powered on when the script started." -ForegroundColor Green
    }
    Write-Host "$('=' * 50)" -ForegroundColor Cyan

} else {
    Write-Warning "No results collected — check for job execution errors above."
}

# Disconnect from vCenter
Write-Host "`nDisconnecting from vCenter servers..." -ForegroundColor Yellow
foreach ($server in $connectedServers) {
    try {
        Disconnect-VIServer -Server $server -Confirm:$false -ErrorAction SilentlyContinue
        Write-Host "Disconnected from $server" -ForegroundColor Green
    } catch {
        Write-Warning "Failed to disconnect from $server"
    }
}

Write-Host "`nScript completed at: $(Get-Date)" -ForegroundColor Green
Write-Host "Total runtime: $totalScriptTime minutes" -ForegroundColor Cyan
Write-Host "`nPress Enter to exit..." -ForegroundColor Yellow
Read-Host
