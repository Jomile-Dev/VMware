    Write-Host "  Powered Off: $poweredOff" -ForegroundColor Red
    if ($unknown -gt 0) {
        Write-Host "  Unknown: $unknown" -ForegroundColor Yellow
    }
    
    # List VMs that were originally powered off
    $originallyOff = $results | Where-Object { $_.OriginalPowerState -eq "PoweredOff" }
    if ($originallyOff.Count -gt 0) {
        Write-Host "`nVMs that were ORIGINALLY POWERED OFF:" -ForegroundColor Yellow
        $originallyOff | Select-Object VMName, OriginalPowerState, FinalPowerState, PowerOnVerified, Status | Format-Table -AutoSize
    } else {
        Write-Host "`nAll VMs were originally powered on" -ForegroundColor Green
    }
    
} else {
