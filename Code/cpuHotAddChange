Write-Host ("=" * 80) -ForegroundColor Green
Write-Host "Active PowerShell jobs: $((Get-Job -State Running).Count)" -ForegroundColor Yellow

# Enhanced job monitoring with index-based real-time updates
$lastSummaryUpdate = Get-Date

while ($jobs.Count -gt $processedJobs.Count) {
    Show-NewJobUpdates -RunningJobs (Get-Job -State Running) -LastSeenIndex $jobLastSeenIndex
    Complete-FinishedJobs -AllJobs $jobs -Results ([ref]$results) -ProcessedJobs ([ref]$processedJobs)
    
    # Comprehensive status update every 20 seconds
    $currentTime = Get-Date
    if (($currentTime - $lastSummaryUpdate).TotalSeconds -ge 20) {
        $completed = $processedJobs.Count
        $running = (Get-Job -State Running).Count
        $total = $jobs.Count
        $remaining = $total - $completed
        $elapsedTotal = [math]::Round(($currentTime - $scriptStartTime).TotalMinutes, 1)
        
        Write-Host ("`n" + "=" * 60) -ForegroundColor Yellow
        Write-Host "*** COMPREHENSIVE STATUS UPDATE - $elapsedTotal minutes elapsed ***" -ForegroundColor Yellow -BackgroundColor DarkYellow
        Write-Host ("=" * 60) -ForegroundColor Yellow
        Write-Host "Progress: Completed $completed of $total VMs" -ForegroundColor Green
        Write-Host "Currently Running: $running jobs" -ForegroundColor Cyan
        Write-Host "Remaining: $remaining VMs left to process" -ForegroundColor Yellow
        if ($completed -gt 0) {
            $successCount = ($results | Where-Object { $_.Status -in @("Success", "CompletedWithWarning") }).Count
            Write-Host "Success Rate: $([math]::Round($successCount / $completed * 100, 1))%" -ForegroundColor Green
        }
        
        if ($running -gt 0) {
            Write-Host "`nCURRENTLY PROCESSING:" -ForegroundColor Cyan
            $runningJobsInfo = $jobs | Where-Object { $_.Job.State -eq 'Running' }
            foreach ($runningJob in $runningJobsInfo) {
                $elapsed = [math]::Round(($currentTime - $runningJob.StartTime).TotalMinutes, 1)
                Write-Host "   - $($runningJob.VMName) (Job $($runningJob.JobId) - ${elapsed}m elapsed)" -ForegroundColor White
            }
        }
        
        Write-Host ("=" * 60) -ForegroundColor Yellow
        Write-Host ""
        
        $lastSummaryUpdate = $currentTime
    }
    
    Start-Sleep -Seconds 1
}

# Final processing and comprehensive reporting
$totalScriptTime = [math]::Round(((Get-Date) - $scriptStartTime).TotalMinutes, 2)

Write-Host ("`n" + "=" * 80) -ForegroundColor Green
Write-Host "*** ALL JOBS COMPLETED - GENERATING COMPREHENSIVE FINAL REPORT ***" -ForegroundColor Green -BackgroundColor DarkGreen
