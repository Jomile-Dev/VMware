# ============================================================================
# IMPROVED MONITORING: Index-based tracking replaces the old -notcontains on
# a growing array. Each job's last-seen output index is tracked in a hashtable
# so the loop processes only new messages - O(1) per new entry instead of O(n).
# ============================================================================
$jobLastSeenIndex = @{}

# Simple validation
if ($finalServerArray.Count -eq 0) {
    Write-Error "No connected vCenter servers available for jobs!"
    Read-Host "Press Enter to exit"
    exit 1
}

Write-Host "Passing $($finalServerArray.Count) servers to jobs: $($finalServerArray -join ', ')" -ForegroundColor Green

# Helper function: process real-time updates from running jobs using index-based tracking
function Show-NewJobUpdates {
    param($RunningJobs, [hashtable]$LastSeenIndex)
    
    foreach ($runningJob in $RunningJobs) {
        $allOutput = Receive-Job -Job $runningJob -Keep
        $updates = @($allOutput | Where-Object { $_.Type -eq "ProgressUpdate" })
        
        $lastIdx = 0
        if ($LastSeenIndex.ContainsKey($runningJob.Id)) {
            $lastIdx = $LastSeenIndex[$runningJob.Id]
        }
        
        for ($i = $lastIdx; $i -lt $updates.Count; $i++) {
            $update = $updates[$i]
            
            $color = switch ($update.LogLevel) {
                "START"   { "Cyan"   }
                "SUCCESS" { "Green"  }
                "ERROR"   { "Red"    }
                "WARN"    { "Yellow" }
                default   { "Gray"   }
            }
            
            Write-Host $update.FullLogEntry -ForegroundColor $color
        }
        
        $LastSeenIndex[$runningJob.Id] = $updates.Count
    }
}

# Helper function: process completed jobs - handles all three statuses
function Complete-FinishedJobs {
    param($AllJobs, [ref]$Results, [ref]$ProcessedJobs)
    
    $completedJobs = Get-Job | Where-Object { $_.State -ne 'Running' -and $_.Id -notin $ProcessedJobs.Value }
    foreach ($completedJob in $completedJobs) {
        $jobInfo = $AllJobs | Where-Object { $_.Job.Id -eq $completedJob.Id }
        if ($jobInfo) {
            Write-Host "`n>>> PROCESSING COMPLETED JOB FOR VM: $($jobInfo.VMName) <<<" -ForegroundColor Magenta
            
            try {
                $jobOutput = Receive-Job -Job $completedJob -ErrorAction Stop
                $vmResult = $jobOutput | Where-Object { $_.Type -eq "FinalResult" } | Select-Object -Last 1
                
                if ($vmResult) {
                    $Results.Value += $vmResult
                    $duration = [math]::Round(((Get-Date) - $jobInfo.StartTime).TotalMinutes, 2)
                    
                    if ($vmResult.Status -eq "Success") {
                        Write-Host "[OK] SUCCESS: $($vmResult.VMName)" -ForegroundColor Green
                        Write-Host "  -- Configuration: $($vmResult.NewCPUCount) CPUs ($($vmResult.NewCoresPerSocket) cores/socket), $($vmResult.NewMemoryGB)GB RAM" -ForegroundColor Green
                        Write-Host "  -- Power State: $($vmResult.FinalPowerState) (PowerOn Verified: $($vmResult.PowerOnVerified))" -ForegroundColor Green
                        Write-Host "  -- Processing Time: $duration minutes" -ForegroundColor Green
                    } elseif ($vmResult.Status -eq "CompletedWithWarning") {
                        Write-Host "[!!] COMPLETED WITH WARNING: $($vmResult.VMName)" -ForegroundColor Yellow
                        Write-Host "  -- Configuration: $($vmResult.NewCPUCount) CPUs ($($vmResult.NewCoresPerSocket) cores/socket), $($vmResult.NewMemoryGB)GB RAM" -ForegroundColor Yellow
                        Write-Host "  -- Power State: $($vmResult.FinalPowerState) (PowerOn Verified: $($vmResult.PowerOnVerified))" -ForegroundColor Yellow
                        Write-Host "  -- VM was configured but did not confirm power-on within timeout" -ForegroundColor Yellow
                        Write-Host "  -- Processing Time: $duration minutes" -ForegroundColor Yellow
                    } else {
                        Write-Host "[XX] FAILED: $($vmResult.VMName)" -ForegroundColor Red
                        Write-Host "  -- Error: $($vmResult.ErrorMessage)" -ForegroundColor Red
                        Write-Host "  -- Processing Time: $duration minutes" -ForegroundColor Red
                    }
                } else {
                    Write-Warning "Could not extract result for VM: $($jobInfo.VMName)"
                }
            } catch {
                Write-Warning "Error processing job $($completedJob.Id): $_"
            }
            
            Remove-Job -Job $completedJob -Force
            $ProcessedJobs.Value += $completedJob.Id
            
            Write-Host ">>> JOB PROCESSING COMPLETE <<<`n" -ForegroundColor Magenta
        }
    }
}

# Start jobs in batches with validated server list
foreach ($vmEntry in $VMList) {
    # Wait for available slot
    while ((Get-Job -State Running).Count -ge $maxJobs) {
        Start-Sleep -Seconds 1
        
        Show-NewJobUpdates -RunningJobs (Get-Job -State Running) -LastSeenIndex $jobLastSeenIndex
        Complete-FinishedJobs -AllJobs $jobs -Results ([ref]$results) -ProcessedJobs ([ref]$processedJobs)
    }
    
    Write-Host "DEBUG: Starting job $jobCounter with server array count: $($finalServerArray.Count)" -ForegroundColor Gray
    Write-Host "DEBUG: Server array contents: $($finalServerArray -join ', ')" -ForegroundColor Gray
    
    try {
        $job = Start-Job -ScriptBlock $vmProcessingScript -ArgumentList $vmEntry, $finalServerArray, $Username, $Password, $jobCounter, $DefaultShutdownTimeoutMinutes
        
        $jobs += [PSCustomObject]@{
            Job = $job
            VMName = $vmEntry.VMName 
            JobId = $jobCounter
            StartTime = Get-Date
        }
        
        Write-Host "`nLAUNCHED JOB $jobCounter FOR VM: $($vmEntry.VMName)" -ForegroundColor Cyan -BackgroundColor DarkBlue
        Write-Host "   PowerShell Job ID: $($job.Id) | Target CPUs: $($vmEntry.CPUCountBefore) -> $($vmEntry.CPUCountAfter) | Memory: $($vmEntry.MemoryGBBefore)GB -> $($vmEntry.MemoryGBAfter)GB" -ForegroundColor White
        $jobCounter++
        
        Start-Sleep -Milliseconds 500
        
    } catch {
        Write-Error "CRITICAL ERROR: Failed to start job for VM $($vmEntry.VMName): $($_.Exception.Message)"
        Write-Host "Server array being passed: $($finalServerArray -join ', ')" -ForegroundColor Red
    }
}

Write-Host ("`n" + "=" * 80) -ForegroundColor Green
