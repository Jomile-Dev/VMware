$urls = @(
    "https://example.com",
    "https://example.com",
    "https://example.com"
)

foreach ($Url in $urls) {
    $uri = [System.Uri]$Url
    $hostname = $uri.Host
    $port = if ($uri.Port -eq -1) { 443 } else { $uri.Port }

    $tcpClient = [System.Net.Sockets.TcpClient]::new($hostname, $port)
    $sslStream = [System.Net.Security.SslStream]::new($tcpClient.GetStream(), $false, { $true })
    $sslStream.AuthenticateAsClient($hostname)
    $cert = [System.Security.Cryptography.X509Certificates.X509Certificate2]::new($sslStream.RemoteCertificate)

    $hashBytes = [System.Security.Cryptography.SHA256]::Create().ComputeHash($cert.RawData)
    $fingerprint = ($hashBytes | ForEach-Object { $_.ToString("X2") }) -join ""

    Write-Host "URL:         $Url"
    Write-Host "SHA-256:     $fingerprint"
    Write-Host ""

    $sslStream.Dispose()
    $tcpClient.Dispose()
}$Url = "https://example.com"

