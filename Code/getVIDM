# Replace the entire vRA groups section with this
$skip     = 0
$pageSize = 200

do {
    $resp = Invoke-RestMethod `
        -Uri "https://$vraServer/iaas/api/projects?apiVersion=2021-07-15&`$top=$pageSize&`$skip=$skip" `
        -Method GET `
        -Headers $vraHeaders `
        -ErrorAction Stop

    $items = if ($resp.content) { $resp.content } else { $resp }

    if ($items -and @($items).Count -gt 0) {
        foreach ($project in $items) {
            # Pull groups from project members
            $project.members | Where-Object { $_.type -eq "group" } |
                ForEach-Object { $vraGroupNames += $_.email.Trim() }

            $project.administrators | Where-Object { $_.type -eq "group" } |
                ForEach-Object { $vraGroupNames += $_.email.Trim() }

            $project.viewers | Where-Object { $_.type -eq "group" } |
                ForEach-Object { $vraGroupNames += $_.email.Trim() }
        }
        $skip += $pageSize
        if (@($items).Count -lt $pageSize) { break }
    }
    else { break }
} while ($true)

$vraGroupNames = $vraGroupNames | Sort-Object -Unique
Write-Log "Retrieved $($vraGroupNames.Count) groups from projects on $vraServer" "SUCCESS"
