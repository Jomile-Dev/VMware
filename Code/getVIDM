# Bypass self-signed SSL certificates
add-type @"
    using System.Net;
    using System.Security.Cryptography.X509Certificates;
    public class TrustAllCertsPolicy : ICertificatePolicy {
        public bool CheckValidationResult(
            ServicePoint srvPoint, X509Certificate certificate,
            WebRequest request, int certificateProblem) {
            return true; }}
"@
[System.Net.ServicePointManager]::CertificatePolicy = New-Object TrustAllCertsPolicy

# Your vIDM details
$vidmFQDN     = "your-vidm.domain.com"
$username     = "admin"        # System Domain local account
$password     = "your_password"
$clientId     = "your_client_id"    # From Remote App Access
$clientSecret = "your_shared_secret" # From Remote App Access

$loginBody = @{
    username   = $username
    password   = $password
    issueToken = "true"
} | ConvertTo-Json

$loginResponse = Invoke-RestMethod `
    -Uri "https://$vidmFQDN/SAAS/API/1.0/REST/auth/system/login" `
    -Method POST `
    -Headers @{ "Content-Type" = "application/json"; "Accept" = "application/json" } `
    -Body $loginBody

$sessionToken = $loginResponse.sessionToken
Write-Host "Session Token retrieved: $($sessionToken.Substring(0,20))..."

$base64Creds = [Convert]::ToBase64String(
    [Text.Encoding]::ASCII.GetBytes("${clientId}:${clientSecret}"))

$tokenResponse = Invoke-RestMethod `
    -Uri "https://$vidmFQDN/SAAS/auth/oauthtoken" `
    -Method POST `
    -Headers @{
        "Authorization" = "Basic $base64Creds"
        "Content-Type"  = "application/x-www-form-urlencoded"
        "Accept"        = "application/json"
    } `
    -Body "grant_type=client_credentials"

$accessToken = $tokenResponse.access_token
Write-Host "Access Token retrieved successfully"

$directories = Invoke-RestMethod `
    -Uri "https://$vidmFQDN/SAAS/jersey/manager/api/connectormanagement/directoryconfigs" `
    -Method GET `
    -Headers @{
        "Authorization" = "HZN $sessionToken"
        "Accept"        = "application/json"
    }

Write-Host "=== Directories Found ==="
foreach ($dir in $directories.items) {
    Write-Host "Name : $($dir.name)"
    Write-Host "Type : $($dir.type)"
    Write-Host "ID   : $($dir.directoryId)"
    Write-Host "---"
}

# Filter groups by directory name — change "YourDirectoryName" to match yours
$targetDirectory = "YourDirectoryName"

$groups = Invoke-RestMethod `
    -Uri "https://$vidmFQDN/SAAS/jersey/manager/api/scim/Groups?count=500" `
    -Method GET `
    -Headers @{
        "Authorization" = "Bearer $accessToken"
        "Accept"        = "application/json"
    }

Write-Host "=== Groups in $targetDirectory ==="
$filteredGroups = $groups.Resources | Where-Object {
    $_.displayName -ne $null
}

foreach ($group in $filteredGroups) {
    Write-Host "Group : $($group.displayName)"
    Write-Host "ID    : $($group.id)"
    Write-Host "---"
}

# Export to CSV
$filteredGroups | Select-Object displayName, id |
    Export-Csv -Path ".\vidm_groups.csv" -NoTypeInformation
Write-Host "Exported to vidm_groups.csv"

# Replace with actual group ID from Step 5
$groupId = "your-group-id-here"

$groupDetails = Invoke-RestMethod `
    -Uri "https://$vidmFQDN/SAAS/jersey/manager/api/scim/Groups/$groupId" `
    -Method GET `
    -Headers @{
        "Authorization" = "Bearer $accessToken"
        "Accept"        = "application/json"
    }

Write-Host "=== Members of $($groupDetails.displayName) ==="
foreach ($member in $groupDetails.members) {
    Write-Host "Member: $($member.display) | ID: $($member.value)"
}
