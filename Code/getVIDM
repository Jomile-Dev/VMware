# Paste your cspAuthToken from Step 1 here
$token = "your-cspAuthToken-here"

Invoke-RestMethod `
    -Uri "https://$vraServer/csp/gateway/am/api/loggedin/user/orgs" `
    -Method GET `
    -Headers @{ 
        "Authorization" = "Bearer $token"
        "Content-Type"  = "application/json" 
    } | ConvertTo-Json -Depth 5
