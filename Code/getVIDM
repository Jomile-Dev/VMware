# Step 1 — Login gets us everything we need in one shot
$loginResp = Invoke-RestMethod `
    -Uri "https://$vraServer/csp/gateway/am/api/login?access_token" `
    -Method POST `
    -Headers @{ "Content-Type" = "application/json" } `
    -Body (@{ username = $vraUser; password = $vraPass } | ConvertTo-Json) `
    -ErrorAction Stop

# Use cspAuthToken directly — no exchange needed
$vraHeaders = @{
    "Authorization" = "Bearer $($loginResp.cspAuthToken)"
    "Content-Type"  = "application/json"
}
Write-Log "Authenticated to $vraServer" "SUCCESS"
