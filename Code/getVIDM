$clientId     = "ps-script"        # whatever you named it
$clientSecret = "your-secret-here"  # the generated secret

$base64Creds = [Convert]::ToBase64String(
    [Text.Encoding]::ASCII.GetBytes("${clientId}:${clientSecret}"))

$loginResponse = Invoke-RestMethod `
    -Uri "https://$vidmFQDN/SAAS/auth/oauthtoken" `
    -Method POST `
    -Headers @{
        "Authorization" = "Basic $base64Creds"
        "Content-Type"  = "application/x-www-form-urlencoded"
        "Accept"        = "application/json"
    } `
    -Body "grant_type=password&username=$username&password=$password&domain=$domain"

$loginResponse | ConvertTo-Json -Depth 5
