$vraServer = "vra1.yourdomain.com"

$cred     = Get-Credential -Message "Enter vRA credentials"
$username = $cred.UserName
$password = $cred.GetNetworkCredential().Password

# vRA 8.x refresh token request
$authResp = Invoke-RestMethod `
    -Uri "https://$vraServer/csp/gateway/am/api/login?access_token" `
    -Method POST `
    -Headers @{ "Content-Type" = "application/json" } `
    -Body (@{ username = $username; password = $password } | ConvertTo-Json)

$authResp | ConvertTo-Json -Depth 5
