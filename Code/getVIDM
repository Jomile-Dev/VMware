# Extract org ID from reflink
$refLink = $org.refLinks | Select-Object -First 1
$orgId   = $refLink -replace ".*/orgs/([^/]+).*", '$1'
Write-Host "Org ID: $orgId"

# Test enterprise groups
$resp = Invoke-RestMethod `
    -Uri "https://$vraServer/csp/gateway/am/api/orgs/$orgId/groups?groupType=ENTERPRISE&take=5&skip=0" `
    -Method GET `
    -Headers $orgHeaders

$resp | ConvertTo-Json -Depth 5
