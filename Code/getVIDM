# Just run this on its own to inspect the login response
$loginResponse = Invoke-RestMethod `
    -Uri "https://$vidmFQDN/SAAS/auth/login" `
    -Method POST `
    -Headers @{ 
        "Content-Type" = "application/json"
        "Accept"       = "application/json"
    } `
    -Body (@{ username = $username; password = $password; domain = $domain; issueToken = "true" } | ConvertTo-Json)

# Dump the full response so we can see what token fields come back
$loginResponse | ConvertTo-Json -Depth 10
