$loginResponse = Invoke-RestMethod `
    -Uri "https://$vidmFQDN/SAAS/API/1.0/REST/auth/login" `
    -Method POST `
    -Headers @{ 
        "Content-Type" = "application/json"
        "Accept"       = "application/json"
        "X-Request-For-Tenant" = "$domain"
    } `
    -Body (@{ 
        username   = $username
        password   = $password
        domain     = $domain
        issueToken = "true" 
    } | ConvertTo-Json)

$loginResponse | ConvertTo-Json -Depth 5
