# Exact same auth as the working deployment script
$vraServer = "your-vra-server"

$credential = Get-Credential -Message "Enter vRA credentials"
$username = $credential.UserName
$password = $credential.GetNetworkCredential().Password

$authResp = Invoke-RestMethod `
    -Uri "https://$vraServer/csp/gateway/am/api/login" `
    -Method POST `
    -Headers @{ "Content-Type" = "application/json" } `
    -Body (@{ username = $username; password = $password } | ConvertTo-Json)

$vraHeaders = @{
    "Authorization" = "Bearer $($authResp.cspAuthToken)"
    "Content-Type"  = "application/json"
}

# Test with the one endpoint we know works from deployment script
$test = Invoke-RestMethod `
    -Uri "https://$vraServer/deployment/api/deployments?page=0&size=1" `
    -Method GET `
    -Headers $vraHeaders

Write-Host "Deployment test worked: $($test.content.Count) result"

# Now test IAM
$orgTest = Invoke-RestMethod `
    -Uri "https://$vraServer/csp/gateway/am/api/loggedin/user/orgs" `
    -Method GET `
    -Headers $vraHeaders

$orgTest | ConvertTo-Json -Depth 3
