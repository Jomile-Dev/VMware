# Use the access_token from the exchange response
$orgHeaders = @{
    "Authorization" = "Bearer $($tokenResp.access_token)"
    "Content-Type"  = "application/json"
}

# Test org lookup
$org = Invoke-RestMethod `
    -Uri "https://$vraServer/csp/gateway/am/api/loggedin/user/orgs" `
    -Method GET `
    -Headers $orgHeaders

$org | ConvertTo-Json -Depth 5
